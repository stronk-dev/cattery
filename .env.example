# Directus
DIRECTUS_SECRET=change-me-to-a-random-string
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-me
DIRECTUS_PUBLIC_URL=http://localhost:8055

# Steward (contact form)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@example.com
TO_EMAIL=contact@example.com
FORMS_ALLOWED_ORIGINS=http://localhost
EMAIL_SUBJECT_PREFIX="Cattery Contactformulier"

# Turnstile (optional — leave empty to use fallback bot detection)
TURNSTILE_FORMS_SECRET_KEY=
TURNSTILE_SITE_KEY=

# Rebuild webhook
REBUILD_TOKEN=change-me-to-a-random-string

# Astro build (also read from this file)
SITE_URL=https://cats.stronk.tech
DIRECTUS_URL=http://localhost:8055
PUBLIC_TAMA_UI_MODE=sidebar
