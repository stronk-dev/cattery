---
import Base from '../../layouts/Base.astro';
import BlogCard from '../../components/BlogCard.astro';
import { fetchBlogBerichten, fetchSiteInstellingen } from '../../lib/directus';

let site, posts;
try {
  [site, posts] = await Promise.all([
    fetchSiteInstellingen(),
    fetchBlogBerichten(),
  ]);
} catch {
  site = { cattery_naam: 'Cattery' } as any;
  posts = [];
}
---

<Base title="Blog" siteInstellingen={site}>
  <section class="section">
    <div class="container">
      <div class="page-header">
        <h1>Blog</h1>
        <p class="page-intro">
          Lees onze laatste berichten over onze katten, kittens en het fokkersleven.
        </p>
      </div>

      {posts.length > 0 ? (
        <div class="grid grid-2" style="margin-top: var(--space-xl);">
          {posts.map(post => <BlogCard post={post} />)}
        </div>
      ) : (
        <p class="empty-state">
          Er zijn nog geen berichten gepubliceerd. Kom binnenkort terug voor nieuws en updates.
        </p>
      )}
    </div>
  </section>
</Base>

<style>
  .page-header {
    text-align: center;
    margin-bottom: var(--space-xl);
    max-width: 600px;
    margin-inline: auto;
  }

  .page-header h1 {
    margin-bottom: var(--space-md);
  }

  .page-intro {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .empty-state {
    color: var(--color-text-muted);
    text-align: center;
    margin-top: var(--space-lg);
    font-size: 1.05rem;
  }
</style>
