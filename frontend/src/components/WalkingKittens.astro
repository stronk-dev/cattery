---
---

<div class="kittens-stage" id="kittens-stage">
  <template id="kitten-template">
    <div class="kitten" aria-hidden="true">
      <div class="kitten-body">
        <div class="kitten-head">
          <div class="kitten-ear kitten-ear--far"></div>
          <div class="kitten-ear kitten-ear--near"></div>
          <div class="kitten-eye"></div>
          <div class="kitten-nose"></div>
        </div>
        <div class="kitten-tail">
          <div class="kitten-tail-mid">
            <div class="kitten-tail-tip"></div>
          </div>
        </div>
        <div class="kitten-leg kitten-leg--fl"></div>
        <div class="kitten-leg kitten-leg--fr"></div>
        <div class="kitten-leg kitten-leg--bl"></div>
        <div class="kitten-leg kitten-leg--br"></div>
      </div>
    </div>
  </template>
  <template id="yarn-template">
    <div class="yarn" aria-hidden="true">
      <div class="yarn-ball"></div>
    </div>
  </template>
</div>

<script>
  const stage = document.getElementById('kittens-stage')!;
  const kittenTpl = document.getElementById('kitten-template') as HTMLTemplateElement;
  const yarnTpl = document.getElementById('yarn-template') as HTMLTemplateElement;

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reducedMotion) stage.style.display = 'none';

  /* ═══ Config ═══════════════════════════════════════════ */

  const FUR = [
    { fur: '#e8943a', dark: '#c67520', eye: '#4a8c3f' },
    { fur: '#3a3a3a', dark: '#1a1a1a', eye: '#d4a017' },
    { fur: '#9e9e9e', dark: '#6e6e6e', eye: '#5c8a4d' },
    { fur: '#f5e6d0', dark: '#d4c0a0', eye: '#5b88c9' },
    { fur: '#8b6347', dark: '#6d4c35', eye: '#4a8c3f' },
    { fur: '#d4a574', dark: '#b8864e', eye: '#7a6b5d' },
  ];

  const YARN_COLORS = ['#cc3333', '#3366bb', '#339944', '#cc7733', '#9944aa'];
  const PERSONALITIES = ['lazy', 'playful', 'curious', 'sassy'] as const;
  type Personality = typeof PERSONALITIES[number];
  type Behavior = 'walk' | 'sit' | 'playbow' | 'pounce' | 'groom' | 'nap' | 'zoomies' | 'stalk';

  const BWEIGHTS: Record<Personality, Partial<Record<Behavior, number>>> = {
    lazy:    { sit: 3, groom: 3, nap: 4, stalk: 1, zoomies: 0.5 },
    playful: { playbow: 3, pounce: 2, zoomies: 3, stalk: 1, groom: 1, sit: 0.5 },
    curious: { stalk: 4, sit: 2, pounce: 2, groom: 2 },
    sassy:   { sit: 2, groom: 3, stalk: 2, nap: 1, playbow: 1, pounce: 1 },
  };

  // Duration in frames (~60fps)
  const BDUR: Record<Behavior, [number, number]> = {
    walk:    [150, 360],
    sit:     [360, 900],
    playbow: [90, 150],
    pounce:  [60, 120],
    groom:   [480, 900],
    nap:     [900, 1800],
    zoomies: [120, 240],
    stalk:   [300, 600],
  };

  const TAIL_FOR_PERSONALITY: Record<Personality, string> = {
    playful: 'playful', curious: 'curious', sassy: 'sassy', lazy: 'content',
  };

  const MAX_KITTENS = 3;
  let activeKittens = 0;
  const STATIONARY: Behavior[] = ['sit', 'playbow', 'pounce', 'groom', 'nap'];

  /* ═══ State ════════════════════════════════════════════ */

  interface KState {
    el: HTMLElement;
    x: number; y: number;
    vx: number; vy: number;
    baseVx: number;
    savedVx: number;
    baseY: number;
    personality: Personality;
    behavior: Behavior;
    bTimer: number;
    walkTimer: number;
    normalWalk: number;
    origTail: string;
    noBehaviors: boolean;
  }

  interface YarnState {
    el: HTMLElement;
    x: number; y: number;
    vx: number;
  }

  const cats: KState[] = [];
  const yarns: YarnState[] = [];
  let mx = -9999, my = -9999;

  document.addEventListener('mousemove', (e) => { mx = e.pageX; my = e.pageY; });

  function rand(a: number, b: number) { return Math.random() * (b - a) + a; }
  function pick<T>(arr: readonly T[]): T { return arr[Math.floor(Math.random() * arr.length)]; }

  /* ═══ Physics constants ════════════════════════════════ */

  const AVOID_R = 140;
  const AVOID_F = 4.5;
  const DRAG = 0.92;
  const Y_SPRING = 0.018;

  /* ═══ Behavior system ══════════════════════════════════ */

  function pickBehavior(p: Personality): Behavior {
    const w = BWEIGHTS[p];
    const entries = Object.entries(w) as [Behavior, number][];
    const total = entries.reduce((s, [, v]) => s + v, 0);
    let r = Math.random() * total;
    for (const [b, v] of entries) { r -= v; if (r <= 0) return b; }
    return 'sit';
  }

  function enterBehavior(k: KState, b: Behavior) {
    k.behavior = b;
    const [lo, hi] = BDUR[b];
    k.bTimer = Math.floor(rand(lo, hi));
    k.el.dataset.behavior = b;

    switch (b) {
      case 'sit': case 'playbow': case 'pounce': case 'groom': case 'nap':
        k.savedVx = k.baseVx;
        k.baseVx = 0;
        break;
      case 'stalk':
        k.savedVx = k.baseVx;
        k.baseVx = k.savedVx * 0.25;
        break;
      case 'zoomies':
        k.savedVx = k.baseVx;
        k.baseVx = k.savedVx * (Math.random() > 0.5 ? 3.5 : -3.5);
        break;
    }

    if (b === 'playbow' || b === 'zoomies') k.el.dataset.tail = 'playful';
    else if (b === 'stalk') k.el.dataset.tail = 'curious';
    else if (b === 'nap' || b === 'groom' || b === 'sit') k.el.dataset.tail = 'content';
  }

  function exitBehavior(k: KState) {
    const prev = k.behavior;
    k.behavior = 'walk';
    k.walkTimer = Math.floor(rand(300, 600));
    delete k.el.dataset.behavior;
    k.el.dataset.tail = k.origTail;

    if (prev !== 'walk') k.baseVx = k.savedVx;

    // Exit bursts
    if (prev === 'playbow') { k.vx += Math.sign(k.baseVx || 1) * 15; k.vy -= 4; }
    else if (prev === 'pounce') { k.vx += Math.sign(k.baseVx || 1) * 22; k.vy -= 8; }
  }

  /* ═══ Tick ═════════════════════════════════════════════ */

  function tick() {
    for (let i = cats.length - 1; i >= 0; i--) {
      const k = cats[i];
      const dx = k.x - mx;
      const dy = k.y - my;
      const dist = Math.hypot(dx, dy);

      // Stalk: weak attraction toward cursor
      if (k.behavior === 'stalk' && dist < 300 && dist > 50) {
        k.vx -= (dx / dist) * 0.5;
        k.vy -= (dy / dist) * 0.15;
      }
      // Nap: wake up if cursor close
      else if (k.behavior === 'nap' && dist < AVOID_R * 0.7) {
        exitBehavior(k);
      }

      // Normal cursor avoidance (not during stalk)
      if (k.behavior !== 'stalk' && dist < AVOID_R && dist > 1) {
        const str = ((AVOID_R - dist) / AVOID_R) * AVOID_F;
        let fx = (dx / dist) * str;
        let fy = (dy / dist) * str;
        fy *= 0.35;
        if (Math.abs(fx) < 0.5) fx = Math.sign(fx || k.baseVx || 1) * 0.5;
        k.vx += fx;
        k.vy += fy;
      }

      // If cursor pushes kitten backwards, permanently flip direction
      // so it commits to walking away instead of oscillating
      if (k.behavior === 'walk' && Math.abs(k.vx) > 2) {
        const totalVxNow = k.baseVx + k.vx;
        if (Math.sign(totalVxNow) !== Math.sign(k.baseVx) && Math.sign(totalVxNow) !== 0) {
          k.baseVx = -k.baseVx;
          k.savedVx = -k.savedVx;
        }
      }

      // Break stationary behaviors if pushed hard
      if (STATIONARY.includes(k.behavior) && Math.hypot(k.vx, k.vy) > 4.5) {
        exitBehavior(k);
      }

      // Behavior timers
      if (!k.noBehaviors) {
        if (k.behavior === 'walk') {
          k.walkTimer--;
          if (k.walkTimer <= 0) enterBehavior(k, pickBehavior(k.personality));
        } else {
          k.bTimer--;
          if (k.bTimer <= 0) exitBehavior(k);
        }
        // Zoomies: random direction flips
        if (k.behavior === 'zoomies' && k.bTimer % 35 === 0 && Math.random() > 0.5) {
          k.baseVx = -k.baseVx;
          k.vy += rand(-4, 4);
        }
      }

      // Physics
      k.vx *= DRAG;
      k.vy *= DRAG;
      k.vy += (k.baseY - k.y) * Y_SPRING;

      const totalVx = k.baseVx + k.vx;
      k.x += totalVx;
      k.y += k.vy;

      // Y bounds
      const minY = 80, maxY = Math.max(document.documentElement.scrollHeight - 80, minY + 200);
      if (k.y < minY) { k.y = minY; k.vy = Math.abs(k.vy) * 0.3; }
      if (k.y > maxY) { k.y = maxY; k.vy = -Math.abs(k.vy) * 0.3; }

      // Flip
      const flip = totalVx >= 0 ? '' : 'scaleX(-1)';

      // Walk animation speed
      const spd = Math.hypot(totalVx, k.vy);
      const ref = Math.abs(k.savedVx || k.baseVx) || 1;
      const ratio = spd / ref;
      const wk = STATIONARY.includes(k.behavior)
        ? k.normalWalk
        : Math.max(0.06, k.normalWalk / Math.max(ratio, 0.5));
      k.el.style.setProperty('--kitten-walk-speed', `${wk}s`);

      // Panicked tail when fast (only override during walk)
      if (k.behavior === 'walk') {
        if (ratio > 3.5) k.el.dataset.tail = 'playful';
        else if (ratio <= 1.5 && k.el.dataset.tail !== k.origTail) k.el.dataset.tail = k.origTail;
      }

      k.el.style.transform = `translate(${k.x}px, ${k.y}px) ${flip}`;

      // Offscreen removal
      if (k.x < -250 || k.x > window.innerWidth + 250) {
        k.el.remove(); cats.splice(i, 1); activeKittens--;
      }
    }

    // Yarn balls
    for (let i = yarns.length - 1; i >= 0; i--) {
      const y = yarns[i];
      y.x += y.vx;
      y.el.style.transform = `translate(${y.x}px, ${y.y}px)`;
      if (y.x < -250 || y.x > window.innerWidth + 250) {
        y.el.remove(); yarns.splice(i, 1);
      }
    }

    requestAnimationFrame(tick);
  }

  /* ═══ Spawn ════════════════════════════════════════════ */

  function makeKitten(opts: {
    size?: [number, number];
    goRight?: boolean;
    yPos?: number;
    speed?: [number, number];
    personality?: Personality;
    noBehaviors?: boolean;
    force?: boolean;
  } = {}): KState | null {
    const force = opts.force ?? false;
    if (reducedMotion || (!force && activeKittens >= MAX_KITTENS)) return null;

    const el = (kittenTpl.content.cloneNode(true) as DocumentFragment).querySelector('.kitten') as HTMLElement;
    const pal = pick(FUR);
    el.style.setProperty('--kitten-fur', pal.fur);
    el.style.setProperty('--kitten-fur-dark', pal.dark);
    el.style.setProperty('--kitten-eye', pal.eye);

    const [sMin, sMax] = opts.size ?? [50, 90];
    el.style.setProperty('--kitten-size', `${rand(sMin, sMax)}px`);

    const personality = opts.personality ?? pick(PERSONALITIES);
    const tailMood = TAIL_FOR_PERSONALITY[personality];
    el.dataset.tail = tailMood;

    const goRight = opts.goRight ?? Math.random() > 0.5;
    const x = goRight ? -150 : window.innerWidth + 150;
    const y = opts.yPos ?? window.scrollY + rand(window.innerHeight * 0.4, window.innerHeight * 0.85);

    const [spMin, spMax] = opts.speed ?? [1.5, 4.5];
    const speed = rand(spMin, spMax);
    const baseVx = goRight ? speed : -speed;
    const normalWalk = Math.max(0.15, 0.35 * (3 / speed));
    el.style.setProperty('--kitten-walk-speed', `${normalWalk}s`);

    el.style.pointerEvents = 'auto';
    el.style.cursor = 'pointer';

    const state: KState = {
      el, x, y, vx: 0, vy: 0,
      baseVx, savedVx: baseVx, baseY: y,
      personality,
      behavior: 'walk', bTimer: 0,
      walkTimer: Math.floor(rand(200, 500)),
      normalWalk, origTail: tailMood,
      noBehaviors: opts.noBehaviors ?? false,
    };

    el.addEventListener('click', (e) => {
      e.stopPropagation();
      state.vx += Math.sign(state.x - e.pageX || 1) * 28;
      state.vy -= 6;
      if (state.behavior !== 'walk') exitBehavior(state);
    });

    activeKittens++;
    cats.push(state);
    stage.appendChild(el);
    return state;
  }

  function spawnKitten(force = false) {
    const r = Math.random();
    if (r < 0.05) spawnYarnChase();
    else if (r < 0.1) spawnMamaKittens();
    else makeKitten({ force });
  }

  function spawnYarnChase() {
    if (reducedMotion) return;
    const goRight = Math.random() > 0.5;
    const yPos = window.scrollY + rand(window.innerHeight * 0.4, window.innerHeight * 0.75);
    const speed = rand(3.5, 5);
    const vx = goRight ? speed : -speed;

    const yEl = (yarnTpl.content.cloneNode(true) as DocumentFragment).querySelector('.yarn') as HTMLElement;
    yEl.style.setProperty('--yarn-color', pick(YARN_COLORS));
    yEl.dataset.dir = goRight ? 'right' : 'left';
    yarns.push({ el: yEl, x: goRight ? -50 : window.innerWidth + 50, y: yPos, vx });
    stage.appendChild(yEl);

    const count = Math.floor(rand(4, 6));
    for (let j = 0; j < count; j++) {
      setTimeout(() => {
        makeKitten({
          size: [28, 45], goRight,
          yPos: yPos + rand(-40, 40),
          speed: [speed * 0.85, speed * 1.15],
          personality: 'playful', noBehaviors: true, force: true,
        });
      }, j * rand(400, 900));
    }
  }

  function spawnMamaKittens() {
    if (reducedMotion) return;
    const goRight = Math.random() > 0.5;
    const yPos = window.scrollY + rand(window.innerHeight * 0.4, window.innerHeight * 0.75);
    const speed = rand(1.5, 2.5);

    makeKitten({
      size: [90, 110], goRight, yPos,
      speed: [speed, speed],
      personality: 'sassy', noBehaviors: true, force: true,
    });

    const count = Math.floor(rand(2, 4));
    for (let j = 0; j < count; j++) {
      setTimeout(() => {
        makeKitten({
          size: [25, 38], goRight,
          yPos: yPos + rand(-30, 30),
          speed: [speed * 0.9, speed * 1.2],
          personality: pick(['playful', 'curious'] as const),
          noBehaviors: false, force: true,
        });
      }, (j + 1) * rand(600, 1200));
    }
  }

  /* ═══ Scheduling ═══════════════════════════════════════ */

  function scheduleKitten() {
    setTimeout(() => { spawnKitten(); scheduleKitten(); }, rand(10000, 20000));
  }

  document.addEventListener('spawn-kitten', () => spawnKitten(true));

  if (!reducedMotion) {
    requestAnimationFrame(tick);
    setTimeout(spawnKitten, 3000);
    scheduleKitten();
  }
</script>

<style is:global>
  body { position: relative; }

  .kittens-stage {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 10;
    overflow: hidden;
  }

  /* ══ Kitten root ═══════════════════════════════════════ */

  .kitten {
    position: absolute;
    top: 0; left: 0;
    width: var(--kitten-size, 70px);
    height: var(--kitten-size, 70px);
  }

  /* ══ Body ══════════════════════════════════════════════ */

  .kitten-body {
    position: relative;
    width: 100%; height: 100%;
    animation: kitten-bob var(--kitten-walk-speed, 0.35s) ease-in-out infinite alternate;
    transition: transform 0.3s ease;
  }

  .kitten-body::before {
    content: '';
    position: absolute;
    top: 32%; left: 14%;
    width: 56%; height: 30%;
    background: var(--kitten-fur, #e8943a);
    border-radius: 45% 52% 50% 42% / 60% 55% 45% 55%;
    transition: top 0.3s ease, left 0.3s ease, width 0.3s ease, height 0.3s ease, border-radius 0.3s ease;
  }

  .kitten-body::after {
    content: '';
    position: absolute;
    top: 28%; left: 50%;
    width: 18%; height: 30%;
    background: var(--kitten-fur, #e8943a);
    border-radius: 50%;
    z-index: 1;
    transition: top 0.3s ease, left 0.3s ease, width 0.3s ease, height 0.3s ease;
  }

  /* ══ Head ══════════════════════════════════════════════ */

  .kitten-head {
    position: absolute;
    top: 8%; left: 52%;
    width: 34%; height: 34%;
    background: var(--kitten-fur, #e8943a);
    border-radius: 50%;
    z-index: 2;
    transition: top 0.3s ease, left 0.3s ease;
  }

  .kitten-ear { position: absolute; }

  .kitten-ear--near {
    top: -22%; left: 8%;
    width: 30%; height: 50%;
    background: var(--kitten-fur-dark, #c67520);
    border-radius: 60% 40% 0 0 / 100% 100% 0 0;
    transform: rotate(-8deg);
    z-index: 1;
  }

  .kitten-ear--near::before {
    content: '';
    position: absolute;
    top: 18%; left: 22%;
    width: 56%; height: 52%;
    background: #d4878f;
    border-radius: 60% 40% 0 0 / 100% 100% 0 0;
    opacity: 0.45;
  }

  .kitten-ear--far {
    top: -18%; left: 28%;
    width: 22%; height: 38%;
    background: var(--kitten-fur-dark, #c67520);
    border-radius: 40% 60% 0 0 / 100% 100% 0 0;
    transform: rotate(8deg);
    opacity: 0.6;
  }

  /* ══ Eye ═══════════════════════════════════════════════ */

  .kitten-eye {
    position: absolute;
    top: 26%; right: 10%;
    width: 32%; height: 28%;
    background: var(--kitten-eye, #4a8c3f);
    border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
    animation: kitten-blink 4s infinite ease-in;
    z-index: 1;
    transition: transform 0.3s ease;
  }

  .kitten-eye::after {
    content: '';
    position: absolute;
    top: 18%; left: 35%;
    width: 22%; height: 56%;
    background: #111;
    border-radius: 50%;
  }

  .kitten-eye::before {
    content: '';
    position: absolute;
    top: 15%; right: 15%;
    width: 20%; height: 20%;
    background: rgba(255, 255, 255, 0.7);
    border-radius: 50%;
    z-index: 1;
  }

  .kitten-nose {
    position: absolute;
    top: 55%; right: -2%;
    width: 12%; height: 10%;
    background: #d4878f;
    border-radius: 50%;
    z-index: 1;
  }

  /* Tongue — on the head, hidden by default, shown during groom */
  .kitten-head::after {
    content: '';
    position: absolute;
    top: 60%; left: 85%;
    width: 0%; height: 16%;
    background: #e87a8a;
    border-radius: 0 50% 50% 0;
    opacity: 0;
    z-index: 3;
  }
  .kitten[data-behavior="groom"] .kitten-head::after {
    opacity: 1;
    animation: kitten-lick 0.8s ease-in-out infinite;
  }

  /* ══ Tail ══════════════════════════════════════════════ */

  .kitten-tail {
    position: absolute;
    top: 14%; left: 14%;
    width: 8%; height: 22%;
    background: var(--kitten-fur-dark, #c67520);
    border-radius: 50px;
    transform-origin: bottom center;
  }

  .kitten-tail-mid {
    position: absolute;
    top: -58%; left: 5%;
    width: 85%; height: 68%;
    background: var(--kitten-fur-dark, #c67520);
    border-radius: 50px;
    transform-origin: bottom center;
  }

  .kitten-tail-tip {
    position: absolute;
    top: -48%; left: 10%;
    width: 72%; height: 58%;
    background: var(--kitten-fur-dark, #c67520);
    border-radius: 50px;
    transform-origin: bottom center;
  }

  /* ══ Legs ══════════════════════════════════════════════ */

  .kitten-leg {
    position: absolute;
    bottom: 6%; width: 7%; height: 30%;
    background: var(--kitten-fur-dark, #c67520);
    border-radius: 3px 3px 4px 4px;
    transform-origin: top center;
    transition: transform 0.3s ease, opacity 0.3s ease, bottom 0.3s ease, height 0.3s ease, left 0.3s ease;
  }

  .kitten-leg::after {
    content: '';
    position: absolute;
    bottom: 0; left: -12%;
    width: 124%; height: 16%;
    background: var(--kitten-fur, #e8943a);
    border-radius: 50%;
  }

  .kitten-leg--fl {
    left: 56%;
    animation: kitten-step-a var(--kitten-walk-speed, 0.35s) ease-in-out infinite alternate;
  }
  .kitten-leg--fr {
    left: 62%;
    animation: kitten-step-b var(--kitten-walk-speed, 0.35s) ease-in-out infinite alternate;
    z-index: -1; opacity: 0.7;
  }
  .kitten-leg--bl {
    left: 22%;
    animation: kitten-step-b var(--kitten-walk-speed, 0.35s) ease-in-out infinite alternate;
  }
  .kitten-leg--br {
    left: 28%;
    animation: kitten-step-a var(--kitten-walk-speed, 0.35s) ease-in-out infinite alternate;
    z-index: -1; opacity: 0.7;
  }

  /* ══ Tail moods ════════════════════════════════════════ */

  .kitten[data-tail="playful"] .kitten-tail     { animation: tail-playful-base 0.5s ease-in-out infinite alternate; }
  .kitten[data-tail="playful"] .kitten-tail-mid { animation: tail-playful-mid 0.5s 0.06s ease-in-out infinite alternate; }
  .kitten[data-tail="playful"] .kitten-tail-tip { animation: tail-playful-tip 0.5s 0.12s ease-in-out infinite alternate; }

  .kitten[data-tail="curious"] .kitten-tail     { animation: tail-curious-base 1.2s ease-in-out infinite alternate; }
  .kitten[data-tail="curious"] .kitten-tail-mid { animation: tail-curious-mid 1.2s 0.1s ease-in-out infinite alternate; }
  .kitten[data-tail="curious"] .kitten-tail-tip { animation: tail-curious-tip 1.2s 0.2s ease-in-out infinite alternate; }

  .kitten[data-tail="content"] .kitten-tail     { animation: tail-content-base 0.8s ease-in-out infinite alternate; }
  .kitten[data-tail="content"] .kitten-tail-mid { animation: tail-content-mid 0.8s 0.08s ease-in-out infinite alternate; }
  .kitten[data-tail="content"] .kitten-tail-tip { animation: tail-content-tip 0.8s 0.16s ease-in-out infinite alternate; }

  .kitten[data-tail="sassy"] .kitten-tail     { animation: tail-sassy-base 0.6s ease-in-out infinite alternate; }
  .kitten[data-tail="sassy"] .kitten-tail-mid { animation: tail-sassy-mid 0.6s 0.07s ease-in-out infinite alternate; }
  .kitten[data-tail="sassy"] .kitten-tail-tip { animation: tail-sassy-tip 0.6s 0.14s ease-in-out infinite alternate; }

  /* ══ BEHAVIOR POSES ════════════════════════════════════ */

  /* ── Sit ─────────────────────────────────────────────── */

  .kitten[data-behavior="sit"] .kitten-body {
    animation: kitten-sit-bob 2s ease-in-out infinite alternate;
  }
  /* Torso: upright oval */
  .kitten[data-behavior="sit"] .kitten-body::before {
    top: 12%; left: 24%;
    width: 38%; height: 52%;
    border-radius: 50% 50% 44% 44%;
  }
  .kitten[data-behavior="sit"] .kitten-body::after {
    top: 10%; left: 42%;
    width: 18%; height: 28%;
  }
  /* Head: on top, toward the FRONT (right side — cat faces right) */
  .kitten[data-behavior="sit"] .kitten-head {
    top: -6%; left: 36%;
  }
  .kitten[data-behavior="sit"] .kitten-leg { animation: none !important; }
  /* Front legs: under the CHEST (front/right side), attached high on body */
  .kitten[data-behavior="sit"] .kitten-leg--fl { transform: rotate(0deg); left: 48%; bottom: 22%; height: 38%; }
  .kitten[data-behavior="sit"] .kitten-leg--fr { transform: rotate(0deg); left: 52%; bottom: 22%; height: 38%; }
  /* Hind legs: under the BUTT (back/left side), folded horizontal */
  .kitten[data-behavior="sit"] .kitten-leg--bl { transform: rotate(-75deg); left: 24%; bottom: 18%; height: 16%; }
  .kitten[data-behavior="sit"] .kitten-leg--br { transform: rotate(-75deg); left: 28%; bottom: 18%; height: 16%; }

  .kitten[data-behavior="sit"] .kitten-tail     { animation: tail-content-base 2s ease-in-out infinite alternate !important; }
  .kitten[data-behavior="sit"] .kitten-tail-mid { animation: tail-content-mid 2s 0.1s ease-in-out infinite alternate !important; }
  .kitten[data-behavior="sit"] .kitten-tail-tip { animation: tail-content-tip 2s 0.2s ease-in-out infinite alternate !important; }

  /* ── Nap (cat loaf) ──────────────────────────────────── */

  .kitten[data-behavior="nap"] .kitten-body {
    animation: kitten-breathe 3s ease-in-out infinite;
  }
  .kitten[data-behavior="nap"] .kitten-leg { animation: none !important; opacity: 0; }
  .kitten[data-behavior="nap"] .kitten-head { top: 14%; left: 48%; }
  .kitten[data-behavior="nap"] .kitten-eye {
    animation: none !important;
    transform: scaleY(0.1);
  }
  .kitten[data-behavior="nap"] .kitten-tail     { animation: none !important; transform: rotate(-35deg); }
  .kitten[data-behavior="nap"] .kitten-tail-mid { animation: none !important; transform: rotate(-25deg); }
  .kitten[data-behavior="nap"] .kitten-tail-tip { animation: none !important; transform: rotate(-15deg); }

  /* ── Play bow (front down, butt up) ──────────────────── */

  .kitten[data-behavior="playbow"] .kitten-body {
    animation-name: none;
    transform: rotate(-10deg);
    transform-origin: 25% 70%;
  }
  .kitten[data-behavior="playbow"] .kitten-leg { animation: none !important; }
  .kitten[data-behavior="playbow"] .kitten-leg--fl { transform: rotate(25deg); height: 35%; }
  .kitten[data-behavior="playbow"] .kitten-leg--fr { transform: rotate(20deg); height: 33%; }
  .kitten[data-behavior="playbow"] .kitten-leg--bl { transform: rotate(-5deg); }
  .kitten[data-behavior="playbow"] .kitten-leg--br { transform: rotate(-5deg); }

  .kitten[data-behavior="playbow"] .kitten-tail     { animation: tail-playful-base 0.3s ease-in-out infinite alternate !important; }
  .kitten[data-behavior="playbow"] .kitten-tail-mid { animation: tail-playful-mid 0.3s 0.04s ease-in-out infinite alternate !important; }
  .kitten[data-behavior="playbow"] .kitten-tail-tip { animation: tail-playful-tip 0.3s 0.08s ease-in-out infinite alternate !important; }

  /* ── Pounce prep (rising on hind legs) ───────────────── */

  .kitten[data-behavior="pounce"] .kitten-body {
    animation-name: none;
    transform: rotate(20deg);
    transform-origin: 25% 80%;
  }
  .kitten[data-behavior="pounce"] .kitten-leg { animation: none !important; }
  .kitten[data-behavior="pounce"] .kitten-leg--fl { transform: rotate(-35deg); bottom: 15%; }
  .kitten[data-behavior="pounce"] .kitten-leg--fr { transform: rotate(-25deg); bottom: 12%; }
  .kitten[data-behavior="pounce"] .kitten-leg--bl,
  .kitten[data-behavior="pounce"] .kitten-leg--br { transform: rotate(0deg); }
  .kitten[data-behavior="pounce"] .kitten-eye {
    animation: none !important; /* wide-eyed stare */
  }

  /* ── Groom (sitting + paw raised) ────────────────────── */

  .kitten[data-behavior="groom"] .kitten-body {
    animation: kitten-sit-bob 2s ease-in-out infinite alternate;
  }
  .kitten[data-behavior="groom"] .kitten-body::before {
    top: 12%; left: 24%;
    width: 38%; height: 52%;
    border-radius: 50% 50% 44% 44%;
  }
  .kitten[data-behavior="groom"] .kitten-body::after {
    top: 10%; left: 42%;
    width: 18%; height: 28%;
  }
  .kitten[data-behavior="groom"] .kitten-head {
    top: -6%; left: 36%;
  }
  .kitten[data-behavior="groom"] .kitten-leg { animation: none !important; }
  .kitten[data-behavior="groom"] .kitten-leg--fl { transform: rotate(-8deg); left: 48%; bottom: 22%; height: 38%; }
  .kitten[data-behavior="groom"] .kitten-leg--fr { transform: rotate(0deg); left: 52%; bottom: 22%; height: 38%; }
  .kitten[data-behavior="groom"] .kitten-leg--bl { transform: rotate(-75deg); left: 24%; bottom: 18%; height: 16%; }
  .kitten[data-behavior="groom"] .kitten-leg--br { transform: rotate(-75deg); left: 28%; bottom: 18%; height: 16%; }
  .kitten[data-behavior="groom"] .kitten-head {
    animation: kitten-groom-bob 0.6s ease-in-out infinite alternate;
  }

  /* ── Stalk (low crouch, creeping) ────────────────────── */

  .kitten[data-behavior="stalk"] .kitten-body {
    animation-name: none;
    transform: translateY(12%) scaleY(0.85);
  }
  .kitten[data-behavior="stalk"] .kitten-head { top: 14%; left: 56%; }
  .kitten[data-behavior="stalk"] .kitten-eye {
    animation: none !important; /* wide-eyed, alert */
  }
  .kitten[data-behavior="stalk"] .kitten-tail     { animation: none !important; transform: rotate(-25deg); }
  .kitten[data-behavior="stalk"] .kitten-tail-mid { animation: none !important; transform: rotate(-5deg); }
  .kitten[data-behavior="stalk"] .kitten-tail-tip { animation: none !important; transform: rotate(0deg); }

  /* ══ Yarn ball ═════════════════════════════════════════ */

  .yarn {
    position: absolute;
    top: 0; left: 0;
    pointer-events: none;
  }
  /* Trailing yarn strand — comes from bottom of ball, trails behind */
  .yarn::after {
    content: '';
    position: absolute;
    top: 16px;
    width: 30px; height: 3px;
    background: var(--yarn-color, #cc3333);
    border-radius: 2px;
    opacity: 0.7;
    animation: yarn-strand-wave 0.6s ease-in-out infinite alternate;
  }
  .yarn[data-dir="right"]::after {
    right: 18px;
    transform-origin: right center;
  }
  .yarn[data-dir="left"]::after {
    left: 18px;
    transform-origin: left center;
  }
  .yarn-ball {
    width: 20px; height: 20px;
    border-radius: 50%;
    position: relative;
    animation: yarn-spin 0.4s linear infinite;
    /* Striped gradient so rotation is visible */
    background: repeating-conic-gradient(
      var(--yarn-color, #cc3333) 0deg 40deg,
      color-mix(in srgb, var(--yarn-color, #cc3333), white 25%) 40deg 80deg
    );
  }
  /* Yarn cross-wrap lines */
  .yarn-ball::before,
  .yarn-ball::after {
    content: '';
    position: absolute;
    top: 15%; left: 15%;
    width: 70%; height: 70%;
    border: 1.5px solid rgba(255,255,255,0.4);
    border-radius: 50%;
  }
  .yarn-ball::before { transform: rotate(35deg); }
  .yarn-ball::after  { transform: rotate(-25deg) scale(0.8); }

  /* ══ Keyframes ═════════════════════════════════════════ */

  @keyframes kitten-step-a {
    0%   { transform: rotate(20deg); }
    100% { transform: rotate(-20deg); }
  }
  @keyframes kitten-step-b {
    0%   { transform: rotate(-20deg); }
    100% { transform: rotate(20deg); }
  }
  @keyframes kitten-bob {
    0%   { transform: translateY(0); }
    100% { transform: translateY(-2px); }
  }
  @keyframes kitten-blink {
    0%   { transform: scaleY(1); }
    90%  { transform: scaleY(1); }
    93%  { transform: scaleY(0.1); }
    96%  { transform: scaleY(1); }
    100% { transform: scaleY(1); }
  }
  @keyframes kitten-breathe {
    0%, 100% { transform: translateY(12%) scaleY(1); }
    50%      { transform: translateY(11%) scaleY(1.03); }
  }
  @keyframes kitten-groom-bob {
    0%   { transform: translateY(0) rotate(0deg); }
    40%  { transform: translateY(18%) rotate(-15deg); }
    60%  { transform: translateY(18%) rotate(-15deg); }
    100% { transform: translateY(0) rotate(0deg); }
  }
  @keyframes kitten-sit-bob {
    0%   { transform: translateY(2%); }
    100% { transform: translateY(0%); }
  }
  @keyframes kitten-lick {
    0%, 100% { width: 0%; }
    30%, 70% { width: 22%; }
  }
  @keyframes yarn-spin { to { transform: rotate(360deg); } }
  @keyframes yarn-strand-wave {
    0%   { transform: rotate(-2deg) scaleX(0.6) translateY(0px); }
    70%  { transform: rotate(2deg) scaleX(0.4) translateY(-6px); }
    100% { transform: rotate(-1deg) scaleX(1) translateY(2px); }
  }

  /* Tail keyframes */
  @keyframes tail-playful-base { 0% { transform: rotate(-8deg); }  100% { transform: rotate(12deg); } }
  @keyframes tail-playful-mid  { 0% { transform: rotate(-15deg); } 100% { transform: rotate(18deg); } }
  @keyframes tail-playful-tip  { 0% { transform: rotate(-30deg); } 100% { transform: rotate(25deg); } }

  @keyframes tail-curious-base { 0% { transform: rotate(-30deg); } 100% { transform: rotate(-18deg); } }
  @keyframes tail-curious-mid  { 0% { transform: rotate(5deg); }   100% { transform: rotate(18deg); } }
  @keyframes tail-curious-tip  { 0% { transform: rotate(-5deg); }  100% { transform: rotate(15deg); } }

  @keyframes tail-content-base { 0% { transform: rotate(-12deg); } 100% { transform: rotate(5deg); } }
  @keyframes tail-content-mid  { 0% { transform: rotate(-8deg); }  100% { transform: rotate(10deg); } }
  @keyframes tail-content-tip  { 0% { transform: rotate(-15deg); } 100% { transform: rotate(12deg); } }

  @keyframes tail-sassy-base { 0% { transform: rotate(-3deg); }  100% { transform: rotate(8deg); } }
  @keyframes tail-sassy-mid  { 0% { transform: rotate(12deg); } 100% { transform: rotate(25deg); } }
  @keyframes tail-sassy-tip  { 0% { transform: rotate(-12deg); } 100% { transform: rotate(8deg); } }
</style>
