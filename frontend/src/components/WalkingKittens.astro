---
---

<div class="kittens-stage" id="kittens-stage">
  <template id="kitten-template">
    <div class="kitten" aria-hidden="true">
      <div class="kitten-body">
        <div class="kitten-head">
          <!-- Side view (default) -->
          <div class="kitten-ear kitten-ear--far"></div>
          <div class="kitten-ear kitten-ear--near"></div>
          <div class="kitten-eye"></div>
          <div class="kitten-nose"></div>
          <!-- Front view (data-face="front") -->
          <div class="kitten-front">
            <div class="kitten-front-ear kitten-front-ear--l"></div>
            <div class="kitten-front-ear kitten-front-ear--r"></div>
            <div class="kitten-front-eye kitten-front-eye--l"><div class="kitten-front-pupil"></div></div>
            <div class="kitten-front-eye kitten-front-eye--r"><div class="kitten-front-pupil"></div></div>
            <div class="kitten-front-nose"></div>
          </div>
        </div>
        <div class="kitten-tail">
          <div class="kitten-tail-mid">
            <div class="kitten-tail-tip"></div>
          </div>
        </div>
        <div class="kitten-leg kitten-leg--fl"></div>
        <div class="kitten-leg kitten-leg--fr"></div>
        <div class="kitten-leg kitten-leg--bl"></div>
        <div class="kitten-leg kitten-leg--br"></div>
      </div>
      <div class="kitten-name"></div>
    </div>
  </template>
  <template id="yarn-template">
    <div class="yarn" aria-hidden="true">
      <div class="yarn-ball"></div>
    </div>
  </template>
</div>

<script>
  import { tamagotchi, type CareVariant, type TamagotchiCat } from '../lib/tamagotchi';

  const stage = document.getElementById('kittens-stage')!;
  const kittenTpl = document.getElementById('kitten-template') as HTMLTemplateElement;
  const yarnTpl = document.getElementById('yarn-template') as HTMLTemplateElement;
  const mainEl = document.getElementById('main')!;
  const pageContentEl = mainEl.querySelector('.page-content') as HTMLElement | null;

  // Main-relative coordinates (cats live inside main, scroll with content)
  const mainW = () => mainEl.clientWidth;
  const mainH = () => Math.max(pageContentEl?.offsetHeight || 0, mainEl.clientHeight);
  const mainScrollY = () => mainEl.scrollTop;
  const mainViewH = () => mainEl.clientHeight;

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reducedMotion) stage.style.display = 'none';

  /* ═══ Config ═══════════════════════════════════════════ */

  // Index: 0=Oranje, 1=Zwart, 2=Blauw/Grijs, 3=Lilac, 4=Chocolade, 5=Crème,
  //        6=Wit, 7=Rood/Ginger, 8=Cinnamon, 9=Cyaan/Blauwgrijs licht
  const FUR = [
    { fur: '#e8943a', dark: '#c67520', eye: '#4a8c3f' },  // 0: Oranje
    { fur: '#3a3a3a', dark: '#1a1a1a', eye: '#d4a017' },  // 1: Zwart
    { fur: '#8e9eaa', dark: '#6a7a88', eye: '#d4a017' },  // 2: Blauw (BSH blue)
    { fur: '#c4b0b8', dark: '#a08a94', eye: '#d4a017' },  // 3: Lilac
    { fur: '#6b4430', dark: '#4d2f1e', eye: '#4a8c3f' },  // 4: Chocolade
    { fur: '#f5e6d0', dark: '#d4c0a0', eye: '#5b88c9' },  // 5: Crème
    { fur: '#f0ece6', dark: '#d4cfc8', eye: '#5b88c9' },  // 6: Wit
    { fur: '#d4734a', dark: '#b85a30', eye: '#4a8c3f' },  // 7: Rood
    { fur: '#b87a50', dark: '#956038', eye: '#4a8c3f' },  // 8: Cinnamon
    { fur: '#a8b8c4', dark: '#8898a4', eye: '#5c8a4d' },  // 9: Blauwgrijs licht
  ];

  const YARN_COLORS = ['#cc3333', '#3366bb', '#339944', '#cc7733', '#9944aa'];
  const PERSONALITIES = ['lazy', 'playful', 'curious', 'sassy', 'shy', 'chaotic'] as const;
  type Personality = typeof PERSONALITIES[number];
  type Behavior = 'walk' | 'sit' | 'playbow' | 'pounce' | 'groom' | 'nap' | 'zoomies' | 'stalk' | 'knead' | 'headbonk' | 'loaf';
  type ItemKind = 'food' | 'yarn' | 'brush';

  const BWEIGHTS: Record<Personality, Partial<Record<Behavior, number>>> = {
    lazy:    { sit: 3, groom: 3, nap: 4, stalk: 1, zoomies: 0.5 },
    playful: { playbow: 3, pounce: 2, zoomies: 3, stalk: 1, groom: 1, sit: 0.5 },
    curious: { stalk: 4, sit: 2, pounce: 2, groom: 2 },
    sassy:   { sit: 2, groom: 3, stalk: 2, nap: 1, playbow: 1, pounce: 1 },
    shy:     { sit: 3, nap: 3, groom: 2, stalk: 3 },
    chaotic: { playbow: 2, pounce: 2, zoomies: 2, stalk: 2, sit: 2, groom: 1, nap: 1 },
  };

  // Duration in frames (~60fps)
  const BDUR: Record<Behavior, [number, number]> = {
    walk:    [150, 360],
    sit:     [360, 900],
    playbow: [90, 150],
    pounce:  [60, 120],
    groom:   [480, 900],
    nap:     [900, 1800],
    zoomies: [120, 240],
    stalk:   [300, 600],
    knead:    [180, 360],
    headbonk: [60, 120],
    loaf:     [600, 1500],
  };

  const TAIL_FOR_PERSONALITY: Record<Personality, string> = {
    playful: 'playful', curious: 'curious', sassy: 'sassy', lazy: 'content',
    shy: 'content', chaotic: 'playful',
  };

  let activeKittens = 0;
  const STATIONARY: Behavior[] = ['sit', 'playbow', 'pounce', 'groom', 'nap', 'knead', 'headbonk', 'loaf'];

  /* ═══ Activity system (higher-level than behaviors) ══ */

  // Activities last 30s–3min and constrain which behaviors a cat picks
  const ACTIVITY_DUR: Record<Activity, [number, number]> = {
    explore: [1800, 5400],   // 30s–90s: wander the page
    lounge:  [3600, 10800],  // 60s–180s: find a spot, settle
    alert:   [600, 2400],    // 10s–40s: sit and stare
    play:    [900, 3600],    // 15s–60s: playful energy
    social:  [1200, 3600],   // 20s–60s: seek other cats
    perch:   [1800, 5400],   // 30s–90s: sit at page edge and watch
    observe: [1200, 3600],  // 20s–60s: come watch the user
  };

  // Which behaviors each activity favors
  const ACTIVITY_WEIGHTS: Record<Activity, Partial<Record<Behavior, number>>> = {
    explore: { stalk: 4, walk: 3, sit: 1, nap: 0.5 },
    lounge:  { sit: 5, nap: 5, groom: 3 },
    alert:   { sit: 8, stalk: 2, nap: 1 },
    play:    { playbow: 4, pounce: 3, zoomies: 2, stalk: 1 },
    social:  { walk: 3, stalk: 2, groom: 2, sit: 1, nap: 0.5 },
    perch:   { sit: 6, stalk: 2, nap: 2 },
    observe: { sit: 6, stalk: 3, nap: 1 },
  };

  // Activity weights per personality (what activities they prefer)
  // Perch: sits at page edge. Observe: enters user's viewport and watches.
  type Activity = 'explore' | 'lounge' | 'alert' | 'play' | 'social' | 'perch' | 'observe';

  const PERSONALITY_ACTIVITIES: Record<Personality, Partial<Record<Activity, number>>> = {
    lazy:    { lounge: 5, alert: 3, explore: 1, social: 1, play: 0.5, perch: 2, observe: 1 },
    playful: { play: 4, explore: 3, social: 2, alert: 1, lounge: 1, perch: 0.5, observe: 0.5 },
    curious: { explore: 5, alert: 3, social: 2, play: 1, lounge: 1, perch: 1, observe: 2 },
    sassy:   { lounge: 3, alert: 4, explore: 2, social: 1, play: 1, perch: 3, observe: 1 },
    shy:     { lounge: 4, alert: 3, perch: 4, explore: 1, social: 0.5, play: 0.5, observe: 3 },
    chaotic: { play: 3, explore: 3, alert: 2, social: 2, lounge: 1, perch: 1, observe: 1 },
  };

  const ACTIVITY_THOUGHT: Record<Activity, string> = {
    explore: '🔍',
    lounge:  '💤',
    alert:   '👁️',
    play:    '⚡',
    social:  '💭',
    perch:   '🚪',
    observe: '👀',
  };

  function pickActivity(p: Personality): Activity {
    const w = PERSONALITY_ACTIVITIES[p];
    const entries = Object.entries(w) as [Activity, number][];
    const total = entries.reduce((s, [, v]) => s + v, 0);
    let r = Math.random() * total;
    for (const [a, v] of entries) { r -= v; if (r <= 0) return a; }
    return 'explore';
  }

  /* ═══ State ════════════════════════════════════════════ */

  interface KState {
    el: HTMLElement;
    x: number; y: number;
    vx: number; vy: number;
    baseVx: number;
    baseVy: number;
    savedVx: number;
    baseY: number;
    personality: Personality;
    behavior: Behavior;
    bTimer: number;
    walkTimer: number;
    normalWalk: number;
    origTail: string;
    // Activity (higher-level mood)
    activity: Activity;
    activityTimer: number;
    // Tamagotchi fields (undefined = ambient cat)
    tamagotchiId?: string;
    tamagotchiName?: string;
    shooed?: boolean;
    shooCount?: number;
    leaveSoonFrames?: number;
    scaredFrames?: number;
    scaredDir?: -1 | 1;
    startleCooldown?: number;
    askCooldown: number;
    // Mission: what is this cat trying to do?
    // null = tamagotchi resident (stays)
    // Stimuli responses: 'chase-food', 'chase-toy'
    // Ambient events: 'outsider', 'thief', 'bird-watch', 'bulldozer', 'observe'
    // Lifecycle: 'cross' (default ambient), 'leave' (heading for exit)
    mission: 'cross' | 'chase-food' | 'chase-toy' | 'outsider' | 'thief' | 'bird-watch' | 'bulldozer' | 'observe' | 'leave' | null;
    missionTarget?: { x: () => number; y: () => number; alive: () => boolean };
    missionFrames?: number;
    missionRoundsLeft?: number;
    // Legacy compat — keep toyPlay fields for now during migration
    toyPlayFrames?: number;
    toyPlayRounds?: number;
    toyPlayRecover?: number;
    toyPlayVariant?: CareVariant;
    // Behavior chains: queued sequential behaviors
    behaviorQueue?: Array<{ behavior: Behavior; duration?: number; popup?: string }>;
    // Idle detection
    idleFrames?: number;
    calmFrames?: number;
    // Short-lived interaction overlays layered on top of poses
    interaction?: 'eat' | 'head-bonk' | 'groomed';
    interactionFrames?: number;
    // Toy chase commit window — once a cat has committed, keep it closing the final gap
    toyCommitVariant?: CareVariant;
    toyCommitFrames?: number;
  }

  interface YarnState {
    el: HTMLElement;
    x: number; y: number;
    vx: number;
    vy: number;
    cruiseSpeed: number;
    boostSpeed: number;
    driftDirX: number;
    driftDirY: number;
    variant: CareVariant;
    targetCatId?: string;
    cooldown: number;
  }

  const cats: KState[] = [];
  const yarns: YarnState[] = [];
  let mx = -9999, my = -9999;
  let cursorSpeed = 0;
  let lastMouseX = -9999;
  let lastMouseY = -9999;
  let lastMouseAt = 0;
  let globalAskCooldown = 0;

  /* ═══ Tamagotchi integration ═════════════════════════════ */

  // Track which tamagotchi cats are currently on screen
  const onScreenTamagotchi = new Set<string>();

  // Stage → size range mapping
  const STAGE_SIZE: Record<string, [number, number]> = {
    kitten: [35, 50],
    adult:  [75, 95],
    elder:  [80, 90],
  };

  const STAGE_SPEED: Record<string, [number, number]> = {
    kitten: [2.1, 4.8],
    adult:  [1.3, 3.9],
    elder:  [0.7, 1.7],
  };

  document.addEventListener('mousemove', (e) => {
    const rect = mainEl.getBoundingClientRect();
    const now = performance.now();
    if (lastMouseAt > 0) {
      const dt = Math.max(16, now - lastMouseAt);
      const dx = e.clientX - lastMouseX;
      const dy = e.clientY - lastMouseY;
      cursorSpeed = Math.hypot(dx, dy) / (dt / 16.67);
    }
    lastMouseX = e.clientX;
    lastMouseY = e.clientY;
    lastMouseAt = now;
    mx = e.clientX - rect.left;
    my = e.clientY - rect.top + mainEl.scrollTop;
  });

  function rand(a: number, b: number) { return Math.random() * (b - a) + a; }
  function pick<T>(arr: readonly T[]): T { return arr[Math.floor(Math.random() * arr.length)]; }
  function clamp(n: number, lo: number, hi: number) { return Math.max(lo, Math.min(hi, n)); }
  function hashString(str: string) {
    let hash = 2166136261;
    for (let i = 0; i < str.length; i++) {
      hash ^= str.charCodeAt(i);
      hash = Math.imul(hash, 16777619);
    }
    return hash >>> 0;
  }

  function getCatFocusTarget(k: KState, cursorActive: boolean) {
    const baseX = cursorActive ? mx : mainW() * 0.5;
    const baseY = cursorActive ? my : (mainScrollY() + mainViewH() * 0.55);
    const seed = hashString(k.tamagotchiId || k.tamagotchiName || `${k.personality}:${k.baseY.toFixed(0)}`);
    const angle = (seed % 360) * (Math.PI / 180);
    const radiusX = cursorActive ? 42 + (seed % 34) : 70 + (seed % 56);
    const radiusY = cursorActive ? 20 + (seed % 18) : 34 + (seed % 30);
    const x = clamp(baseX + Math.cos(angle) * radiusX, 56, mainW() - 56);
    const y = clamp(baseY + Math.sin(angle) * radiusY, mainScrollY() + 88, mainScrollY() + mainViewH() - 88);
    return { x, y };
  }

  function isCatInViewport(k: KState, pad = 64) {
    const minY = mainScrollY() - pad;
    const maxY = mainScrollY() + mainViewH() + pad;
    return k.x > -pad && k.x < mainW() + pad && k.y > minY && k.y < maxY;
  }

  /* ═══ Physics constants ════════════════════════════════ */

  const AVOID_R = 140;
  const AVOID_F = 4.5;
  const DRAG = 0.92;
  const Y_SPRING = 0.018;

  /* ═══ Behavior system ══════════════════════════════════ */

  function pickBehavior(p: Personality): Behavior {
    const w = BWEIGHTS[p];
    const entries = Object.entries(w) as [Behavior, number][];
    const total = entries.reduce((s, [, v]) => s + v, 0);
    let r = Math.random() * total;
    for (const [b, v] of entries) { r -= v; if (r <= 0) return b; }
    return 'sit';
  }

  // Overwhelm detection: too many behavior changes = cat panics and runs
  let behaviorEntryLog: number[] = [];

  function enterBehavior(k: KState, b: Behavior) {
    // Track rapid entries
    const now = performance.now();
    behaviorEntryLog.push(now);
    behaviorEntryLog = behaviorEntryLog.filter(t => now - t < 1000);
    if (behaviorEntryLog.length > 10 || (k.behaviorQueue && k.behaviorQueue.length > 10)) {
      // Overwhelmed! Flush everything and run
      behaviorEntryLog = [];
      k.behaviorQueue = [];
      k.behavior = 'walk';
      delete k.el.dataset.behavior;
      k.el.dataset.tail = k.origTail;
      k.baseVx = (Math.random() > 0.5 ? 1 : -1) * rand(3, 5);
      k.savedVx = k.baseVx;
      k.vx = k.baseVx;
      k.vy -= rand(2, 4);
      showPopup(k.el, '🙀');
      return;
    }

    k.behavior = b;
    const [lo, hi] = BDUR[b];
    k.bTimer = Math.floor(rand(lo, hi));
    k.el.dataset.behavior = b;

    switch (b) {
      case 'sit': case 'groom': case 'nap': case 'knead': case 'loaf':
        k.savedVx = k.baseVx;
        k.baseVx = 0;
        k.baseVy = 0;
        k.vx = 0;
        k.vy = 0;
        break;
      case 'playbow': case 'pounce':
        k.savedVx = k.baseVx;
        k.baseVx = 0;
        k.baseVy = 0;
        k.vx *= 0.35;
        k.vy *= 0.35;
        break;
      case 'stalk':
        k.savedVx = k.baseVx;
        k.baseVx = k.savedVx * 0.25;
        break;
      case 'zoomies':
        k.savedVx = k.baseVx;
        k.baseVx = k.savedVx * (Math.random() > 0.5 ? 3.5 : -3.5);
        break;
    }

    // Circle + yawn before nap (tamagotchi cats only, not forced naps)
    if (b === 'nap' && k.tamagotchiId && k.bTimer < 9000) {
      showPopup(k.el, '🥱');
      // Brief circular movement before settling
      k.el.classList.add('kitten--circling');
      setTimeout(() => k.el.classList.remove('kitten--circling'), 800);
    }

    if (b === 'playbow' || b === 'zoomies') k.el.dataset.tail = 'playful';
    else if (b === 'stalk') k.el.dataset.tail = 'curious';
    else if (b === 'nap' || b === 'groom' || b === 'sit' || b === 'knead' || b === 'loaf') k.el.dataset.tail = 'content';
  }

  function exitBehavior(k: KState) {
    const prev = k.behavior;
    k.behavior = 'walk';
    delete k.el.dataset.behavior;
    k.el.dataset.tail = k.origTail;

    if (prev !== 'walk') k.baseVx = k.savedVx;

    // Behavior chain: if there's a queued next step, do that instead of walk
    if (k.behaviorQueue && k.behaviorQueue.length > 0) {
      const next = k.behaviorQueue.shift()!;
      enterBehavior(k, next.behavior);
      if (next.duration) k.bTimer = next.duration;
      if (next.popup) showPopup(k.el, next.popup);
      return;
    }

    // Lounging cats: very short walks between stationary behaviors (repositioning)
    if (k.activity === 'lounge') {
      k.walkTimer = Math.floor(rand(60, 180));
    } else {
      k.walkTimer = Math.floor(rand(300, 600));
    }

    // Wake chain after nap: stretch → yawn → sit → look around → walk
    if (prev === 'nap' && k.tamagotchiId) {
      k.behaviorQueue = [
        { behavior: 'sit', duration: Math.floor(rand(90, 180)), popup: '🥱' }, // yawn + look around
      ];
      enterBehavior(k, 'playbow'); // stretch
      k.bTimer = Math.floor(rand(60, 120));
      showPopup(k.el, '🥱');
      return;
    }

    // Exit bursts
    if (prev === 'playbow') { k.vx += Math.sign(k.baseVx || 1) * 15; k.vy -= 4; }
    else if (prev === 'pounce') { k.vx += Math.sign(k.baseVx || 1) * 22; k.vy -= 8; }
  }

  // Queue a settle chain: slow walk → sit → groom → nap
  /* ═══ Tick ═════════════════════════════════════════════ */

  function tick() {
    if (globalAskCooldown > 0) globalAskCooldown--;
    for (let i = cats.length - 1; i >= 0; i--) {
      const k = cats[i];
      if (k.startleCooldown && k.startleCooldown > 0) k.startleCooldown--;
      if (k.scaredFrames && k.scaredFrames > 0) k.scaredFrames--;
      if (k.interactionFrames && k.interactionFrames > 0) k.interactionFrames--;
      if ((k.interactionFrames || 0) <= 0) {
        k.interactionFrames = 0;
        k.interaction = undefined;
        delete k.el.dataset.interaction;
      } else if (k.interaction) {
        k.el.dataset.interaction = k.interaction;
      }
      if (k.toyCommitFrames && k.toyCommitFrames > 0) k.toyCommitFrames--;
      if ((k.toyCommitFrames || 0) <= 0) {
        k.toyCommitFrames = 0;
        k.toyCommitVariant = undefined;
      }
      if (k.toyPlayFrames && k.toyPlayFrames > 0) k.toyPlayFrames--;
      if (k.toyPlayRecover && k.toyPlayRecover > 0) k.toyPlayRecover--;
      if ((k.toyPlayFrames || 0) <= 0) {
        const wasToyPlaying = !!k.toyPlayVariant;
        k.toyPlayFrames = 0;
        k.toyPlayRounds = 0;
        k.toyPlayRecover = 0;
        k.toyPlayVariant = undefined;
        // Ambient cat done playing — transition to leave
        if (wasToyPlaying && !k.tamagotchiId && k.mission === 'chase-toy') {
          k.mission = 'leave';
          k.missionTarget = undefined;

          if (k.behavior !== 'walk') exitBehavior(k);
          // Sit briefly (catching breath), then leave
          enterBehavior(k, 'sit');
          k.bTimer = Math.floor(rand(60, 180));
          k.behaviorQueue = []; // clear any toy queue
          setTimeout(() => {
            if (k.mission === 'leave') {
              k.baseVx = k.x < mainW() / 2 ? -rand(2, 4) : rand(2, 4);
              k.savedVx = k.baseVx;
            }
          }, 2000);
        }
      }
      if (k.leaveSoonFrames && k.leaveSoonFrames > 0) {
        k.leaveSoonFrames--;
        if (k.leaveSoonFrames <= 0 && !k.shooed) {
          k.shooed = true;
          if (k.behavior !== 'walk') exitBehavior(k);
          const leaveDir = k.x < mainW() * 0.5 ? -1 : 1;
          k.baseVx = leaveDir * rand(4.5, 6.5);
          k.savedVx = k.baseVx;
          k.vx = leaveDir * rand(3.5, 5.5);
          showPopup(k.el, '👋');
        }
      }
      const isLeaving = !!k.shooed;
      const isScared = !!(k.scaredFrames && k.scaredFrames > 0);
      const isToyPlaying = (k.toyPlayFrames || 0) > 0;
      const dx = k.x - mx;
      const dy = k.y - my;
      const dist = Math.hypot(dx, dy);

      if (!isScared && !isLeaving && (k.shooCount || 0) > 0) {
        const isSettled =
          k.behavior === 'nap' ||
          k.behavior === 'sit' ||
          k.behavior === 'groom' ||
          (k.behavior === 'walk' && Math.hypot(k.baseVx + k.vx, k.baseVy + k.vy) < 0.75);
        if (isSettled) {
          k.calmFrames = (k.calmFrames || 0) + 1;
          if ((k.calmFrames || 0) >= 120) {
            k.shooCount = Math.max(0, (k.shooCount || 0) - 1);
            k.calmFrames = 0;
          }
        } else {
          k.calmFrames = 0;
        }
      } else {
        k.calmFrames = 0;
      }

      // Stalk: weak attraction toward cursor
      if (k.behavior === 'stalk' && dist < 300 && dist > 50) {
        k.vx -= (dx / dist) * 0.5;
        k.vy -= (dy / dist) * 0.15;
      }
      // Nap: wake up if cursor close (ambient only — tama cats sleep through it)
      else if (!k.tamagotchiId && k.behavior === 'nap' && dist < AVOID_R * 0.7) {
        exitBehavior(k);
      }

      // Cursor avoidance
      // Tamagotchi cats are tame: no avoidance when sitting/napping/grooming,
      // very weak avoidance when walking (they're approachable)
      // Ambient cats: full avoidance as before
      if (k.behavior !== 'stalk' && dist < AVOID_R && dist > 1) {
        let avoidForce = AVOID_F;
        if (k.tamagotchiId) {
          // Tame cats — stationary behaviors: no avoidance at all
          if (STATIONARY.includes(k.behavior)) {
            avoidForce = 0;
          } else {
            // Walking: very gentle avoidance so they're clickable
            avoidForce = AVOID_F * 0.15;
          }
        }
        if (avoidForce > 0) {
          const str = ((AVOID_R - dist) / AVOID_R) * avoidForce;
          let fx = (dx / dist) * str;
          let fy = (dy / dist) * str;
          fy *= 0.35;
          if (Math.abs(fx) < 0.5) fx = Math.sign(fx || k.baseVx || 1) * 0.5;
          k.vx += fx;
          k.vy += fy;
        }
      }

      // Soft personal space: cats can gather, but should not all stack on the exact same spot.
      if (!isScared && !isLeaving && !isToyPlaying) {
        for (const other of cats) {
          if (other === k) continue;
          const cdx = k.x - other.x;
          const cdy = k.y - other.y;
          const cdist = Math.hypot(cdx, cdy);
          if (cdist < 1 || cdist > 92) continue;

          const bonded =
            !!k.tamagotchiId &&
            !!other.tamagotchiId &&
            getBondAffinity(k.tamagotchiId, other.tamagotchiId) > 45;
          const inSocialMoment =
            k.interaction === 'head-bonk' ||
            other.interaction === 'head-bonk' ||
            k.interaction === 'groomed' ||
            other.interaction === 'groomed' ||
            k.behavior === 'groom' ||
            other.behavior === 'groom';
          if (inSocialMoment) continue;

          const preferredGap = bonded ? 44 : 72;
          if (cdist >= preferredGap) continue;

          const push = ((preferredGap - cdist) / preferredGap) * (bonded ? 0.12 : 0.3);
          k.vx += (cdx / cdist) * push;
          k.vy += (cdy / cdist) * push * 0.75;
        }
      }

      // If cursor pushes kitten backwards, permanently flip direction
      // so it commits to walking away instead of oscillating
      if (k.behavior === 'walk' && !isLeaving && !isScared && Math.abs(k.vx) > 2) {
        const totalVxNow = k.baseVx + k.vx;
        if (Math.sign(totalVxNow) !== Math.sign(k.baseVx) && Math.sign(totalVxNow) !== 0) {
          k.baseVx = -k.baseVx;
          k.savedVx = -k.savedVx;
        }
      }

      // Only spring out of pounce/playbow when momentum is high.
      // Sit/groom/nap should not silently turn into "sliding while posed".
      if ((k.behavior === 'playbow' || k.behavior === 'pounce') && Math.hypot(k.vx, k.vy) > 4.5) {
        exitBehavior(k);
      }

      if (k.askCooldown > 0) k.askCooldown--;

      // Force rest / ask behavior only when cat is not in a panic or leave state.
      if (k.tamagotchiId && !isScared && !isLeaving) {
        const cd = getTamagotchiData(k.tamagotchiId);
        if (cd) {
          const nearbyFood = foodItems.some((food) =>
            !food.eaten &&
            !food.gone &&
            (!food.targetCatId || food.targetCatId === k.tamagotchiId) &&
            Math.hypot(food.x - k.x, food.y - k.y) < 420
          );

          if (cd.energy < 15) {
            const hungryEnoughToWake = nearbyFood && shouldWakeForFood(k, cd);
            if (hungryEnoughToWake) {
              if (k.behavior === 'nap') {
                exitBehavior(k);
                enterBehavior(k, 'stalk');
                k.bTimer = Math.max(k.bTimer, 120);
                showPopup(k.el, '🍽️');
              }
              k.activity = 'alert';
              k.activityTimer = Math.max(240, k.activityTimer || 0);
            } else {
              // Critically tired — force nap, stay asleep, stop all movement
              if (k.behavior !== 'nap') {
                if (k.behavior !== 'walk') exitBehavior(k);
                enterBehavior(k, 'nap');
                k.bTimer = 9999;
                k.vx = 0; k.vy = 0;
                k.baseVx = 0; k.baseVy = 0;
              }
              k.activity = 'lounge';
              k.activityTimer = 9999;
            }
          } else if (cd.energy < 50 && k.activity !== 'lounge') {
            k.activity = 'lounge';
            k.activityTimer = Math.floor(rand(3600, 10800));
            if (k.behavior === 'walk') {
              enterBehavior(k, cd.energy < 30 ? 'nap' : 'sit');
            }
          } else if (cd.happiness < 35 && k.activity !== 'lounge') {
            k.activity = 'lounge';
            k.activityTimer = Math.floor(rand(3600, 10800));
          }

          const cursorActive = mx > -5000 && my > -5000;
          const focus = getCatFocusTarget(k, cursorActive);
          const focusX = focus.x;
          const focusY = focus.y;
          const inViewport = isCatInViewport(k, 36);
          const bondedNearby = cats.some((other) =>
            other !== k &&
            other.tamagotchiId &&
            k.tamagotchiId &&
            Math.hypot(other.x - k.x, other.y - k.y) < 220 &&
            getBondAffinity(k.tamagotchiId, other.tamagotchiId) > 25
          );

          if (cd.hunger < (k.personality === 'lazy' ? 22 : 35) && k.behavior !== 'nap' && !nearbyFood) {
            const demandDist = Math.hypot(focusX - k.x, focusY - k.y);
            if (k.behavior === 'sit' && demandDist > 120) {
              exitBehavior(k);
            }
            if (k.behavior === 'walk' || k.behavior === 'stalk' || k.behavior === 'sit') {
              const distToFocus = nudgeToward(k, focusX, focusY, 0.22, 0.08, 95);
              if (k.behavior === 'walk' && distToFocus < 110 && Math.abs(k.vx) < 1.2 && Math.random() < 0.03) {
                enterBehavior(k, 'sit');
                k.bTimer = Math.max(k.bTimer, 150);
              }
            }
            if (inViewport && demandDist < 155 && (cursorActive || Math.abs(focusY - k.y) < 220)) {
              const askIcon = k.personality === 'sassy' ? '😾' : '🍽️';
              tryEmitAsk(k, 'food', focusX, focusY, askIcon, 'wil eten', [420, 840]);
            }
          } else if (cd.happiness < 45 && !bondedNearby && k.behavior !== 'nap') {
            const attentionDist = Math.hypot(focusX - k.x, focusY - k.y);
            const wantsPlayAsk =
              (k.personality === 'playful' || k.personality === 'chaotic') &&
              cd.energy > 42 &&
              (k.activity === 'play' || cd.happiness < 32);
            if (k.behavior === 'sit' && attentionDist > 145) {
              exitBehavior(k);
            }
            if (k.behavior === 'walk' || k.behavior === 'sit') {
              const distToFocus = nudgeToward(k, focusX, focusY, 0.18, 0.06, 125);
              if (k.behavior === 'walk' && distToFocus < 138 && Math.abs(k.vx) < 1 && Math.random() < 0.025) {
                enterBehavior(k, 'sit');
                k.bTimer = Math.max(k.bTimer, 180);
              }
            }
            if (k.behavior === 'walk' && Math.abs(focusX - k.x) < 110 && Math.random() < 0.015) {
              enterBehavior(k, 'sit');
              k.bTimer = Math.max(k.bTimer, 180);
            }
            if (inViewport && attentionDist < 170) {
              const askIcon = wantsPlayAsk ? '🪶' : k.personality === 'sassy' ? '😼' : '🥺';
              const askKind = wantsPlayAsk ? 'play' : 'attention';
              const askLabel = wantsPlayAsk ? 'wil spelen' : 'wil aandacht';
              tryEmitAsk(k, askKind, focusX, focusY, askIcon, askLabel, wantsPlayAsk ? [440, 820] : [520, 960]);
            }
          } else if (k.personality === 'curious' && k.activity === 'explore' && k.behavior === 'walk' && cursorActive) {
            nudgeToward(k, focusX, focusY, 0.1, 0.03, 130);
          }
        }
      }

      // Activity timer (tick down, pick new activity when expired)
      if (!isScared && !isLeaving && k.activityTimer > 0) {
        k.activityTimer--;
        if (k.activityTimer <= 0) {
          const prev = k.activity;
          k.activity = pickActivity(k.personality);
          const [aLo, aHi] = ACTIVITY_DUR[k.activity];
          k.activityTimer = Math.floor(rand(aLo, aHi));
          // Thought bubble on activity change
          if (k.activity !== prev && k.tamagotchiId) {
            showPopup(k.el, ACTIVITY_THOUGHT[k.activity]);
          }
        }
      }

      // Activity-specific movement tweaks
      if (!isScared && !isLeaving && k.activity === 'explore' && k.behavior === 'walk') {
        // Exploring: roam the full page, change direction and altitude
        if (Math.random() < 0.005) {
          k.baseVx = -k.baseVx;
          k.savedVx = -k.savedVx;
        }
        // Exploring cats have stronger vertical movement
        if (Math.random() < 0.006) {
          k.baseVy = rand(-1.5, 1.5);
        }
        // Ensure cat is actually moving, not stuck
        if (Math.abs(k.baseVx + k.vx) < 0.3) {
          k.baseVx = (Math.random() > 0.5 ? 1 : -1) * rand(1.5, 3);
          k.savedVx = k.baseVx;
        }
      }
      // Stuck detection for all cats — if walking but barely moving, unstick
      if (!isScared && !isLeaving && k.behavior === 'walk') {
        const totalSpeed = Math.abs(k.baseVx + k.vx);
        if (totalSpeed < 0.3) {
          // Stuck — flip direction and push
          k.baseVx = -k.baseVx || (Math.random() > 0.5 ? 2 : -2);
          k.savedVx = k.baseVx;
          k.vx = k.baseVx * 0.5;
          if (k.tamagotchiId) k.vy += rand(-1, 1);
        }
      }
      if (!isScared && !isLeaving && k.activity === 'lounge' && k.behavior === 'walk') {
        // Lounging: walk very slowly for repositioning, then settle again quickly
        k.baseVx *= 0.97;
        k.walkTimer = Math.min(k.walkTimer, 120); // short repositioning walks
      }
      if (!isScared && !isLeaving && k.activity === 'alert' && k.behavior === 'sit') {
        // Alert sitting: face the cursor (stare)
        const adx = mx - k.x;
        if (Math.abs(adx) > 10) {
          k.el.dataset.facingRight = adx > 0 ? '1' : '';
        }
      }

      // ── Personality quirks (tamagotchi cats only) ──────────
      if (k.tamagotchiId && !isScared && !isLeaving && k.behavior === 'walk') {
        // Playful: random zoomies burst for no reason
        if (k.personality === 'playful' && Math.random() < 0.0005) {
          enterBehavior(k, 'zoomies');
          showPopup(k.el, '⚡');
        }

        // Curious: randomly stop, stare, and chirp ("sees a ghost" / chattering)
        if (k.personality === 'curious' && Math.random() < 0.0008) {
          enterBehavior(k, 'stalk');
          k.bTimer = Math.floor(rand(120, 300));
          showPopup(k.el, Math.random() < 0.5 ? '🗣 prrt!' : '👻');
          if (Math.random() < 0.3) emitTamaSound('meow', { catId: k.tamagotchiId });
        }

        // Chattering at fast cursor (curious + playful)
        if ((k.personality === 'curious' || k.personality === 'playful') && dist < 150 && cursorSpeed > 12 && Math.random() < 0.002) {
          showPopup(k.el, '🗣 prrt!');
          k.el.dataset.facingRight = dx < 0 ? '1' : '';
        }

        // Sassy: randomly stop walking and sit with attitude
        if (k.personality === 'sassy' && Math.random() < 0.0006) {
          enterBehavior(k, 'sit');
          k.el.dataset.tail = 'sassy';
        }
      }

      // Startled by fast cursor movement
      if (k.tamagotchiId && k.behavior === 'walk' && !isScared && (!k.startleCooldown || k.startleCooldown <= 0)) {
        if (dist < 80 && cursorSpeed > 18 && Math.abs(k.vx) < 1.5 && Math.hypot(k.baseVx, k.baseVy) < 2.5) {
          k.vy -= rand(3, 6);
          k.vx += (Math.random() > 0.5 ? 1 : -1) * rand(3, 6);
          k.behaviorQueue = []; // interrupt chain
          if (k.personality !== 'lazy') {
            showPopup(k.el, '❗');
            emitTamaSound('startled', { catId: k.tamagotchiId });
          }
          k.startleCooldown = 75;
        }
      }

      // Sassy stare-down: when another cat approaches, sassy cat stares
      if (k.tamagotchiId && k.personality === 'sassy' && k.behavior === 'sit') {
        for (const other of cats) {
          if (other === k || !other.tamagotchiId) continue;
          const d = Math.hypot(other.x - k.x, other.y - k.y);
          if (d < 100 && d > 30 && other.behavior === 'walk') {
            k.el.dataset.facingRight = (other.x - k.x) > 0 ? '1' : '';
            break;
          }
        }
      }

      // ── Shy personality: stay at edges, extra avoidance ────
      if (k.tamagotchiId && k.personality === 'shy' && !isScared && !isLeaving) {
        const trust = tamagotchi.getTrust();
        // Nervous body language at low trust
        // ears resolved in expression resolver below
        // At low trust: extra cursor avoidance
        if (trust < 30 && dist < 200 && dist > 1 && k.behavior !== 'stalk') {
          const shyForce = ((200 - dist) / 200) * 1.5;
          k.vx += (dx / dist) * shyForce;
        }
        // At high trust: velcro cat — follow cursor at distance
        if (trust > 60 && k.behavior === 'walk' && dist > 150 && dist < 500) {
          k.vx -= (dx / dist) * 0.3;
          k.vy -= (dy / dist) * 0.15;
          if (dist < 260 && Math.random() < 0.0015) {
            emitHint({ key: 'shy-approach', catId: k.tamagotchiId, catName: k.tamagotchiName, placement: 'cat' });
          }
        }
      }

      // ── Chaotic personality: fast activity switches, random behaviors ──
      if (k.tamagotchiId && k.personality === 'chaotic' && !isScared && !isLeaving) {
        // Switch activities way faster
        if (k.activityTimer > 0 && Math.random() < 0.002) {
          k.activityTimer = 0; // force activity switch
        }
        // Random mid-walk pounce at nothing
        if (k.behavior === 'walk' && Math.random() < 0.001) {
          enterBehavior(k, pick(['pounce', 'playbow', 'zoomies'] as const));
          showPopup(k.el, '❓');
        }
        // Interrupt own behavior chain mid-step
        if (k.behaviorQueue && k.behaviorQueue.length > 0 && Math.random() < 0.003) {
          k.behaviorQueue = []; // scrap the plan
          if (k.behavior !== 'walk') exitBehavior(k);
          showPopup(k.el, '❓');
        }
      }

      // ── Perch activity: stay near edges ─────────────────────
      // Observe: steer toward user's viewport
      if (k.tamagotchiId && k.activity === 'observe' && k.behavior === 'walk') {
        const viewY = mainScrollY() + mainViewH() * 0.5;
        if (Math.abs(k.y - viewY) > mainViewH() * 0.3) {
          steerToward(k, k.x, viewY, 0.04);
        }
      }

      if (k.tamagotchiId && k.activity === 'perch' && k.behavior === 'walk') {
        // Drift toward page edges + user's viewport Y
        const viewY = mainScrollY() + mainViewH() * 0.5;
        if (Math.abs(k.y - viewY) > mainViewH() * 0.4) {
          k.baseVy += Math.sign(viewY - k.y) * 0.03;
          k.baseVy = Math.max(-1, Math.min(1, k.baseVy));
        }
        const leftDist = k.x;
        const rightDist = mainW() - k.x;
        const nearestEdge = Math.min(leftDist, rightDist);
        if (nearestEdge > 60) {
          k.vx += leftDist < rightDist ? -0.3 : 0.3;
        } else {
          k.walkTimer = Math.min(k.walkTimer, 60);
        }
      }

      // ── Slow blink: trust reward ────────────────────────────
      if (k.tamagotchiId && k.behavior === 'sit' && !isScared) {
        const trust = tamagotchi.getTrust();
        const blinkChance = trust > 80 ? 0.002 : trust > 50 ? 0.0008 : 0;
        if (blinkChance > 0 && dist < 250 && Math.random() < blinkChance) {
          k.el.classList.add('kitten--slow-blink');
          setTimeout(() => k.el.classList.remove('kitten--slow-blink'), 1500);
          document.dispatchEvent(new CustomEvent('tama-hint', {
            detail: { key: 'slow-blink', catId: k.tamagotchiId, catName: k.tamagotchiName }
          }));
        }
      }

      // ── Stalk → pounce → flee (cursor hunting) ──────────────
      if (k.tamagotchiId && k.behavior === 'stalk' && !isScared && !isLeaving) {
        if ((k.personality === 'playful' || k.personality === 'curious' || k.personality === 'chaotic') && dist < 60 && dist > 10) {
          // Close enough — POUNCE at cursor then flee!
          enterBehavior(k, 'pounce');
          k.vx += -Math.sign(dx) * 15;
          k.vy -= 5;
          showPopup(k.el, '🐾');
          // After pounce, flee
          setTimeout(() => {
            if (k.behavior !== 'walk') exitBehavior(k);
            k.baseVx = Math.sign(dx) * rand(3, 5); // run AWAY from cursor
            k.savedVx = k.baseVx;
          }, 800);
        }
      }

      // tail irritated resolved in expression resolver — hint still triggered here
      if (k.tamagotchiId) {
        const pc2 = petCount.get(k.tamagotchiId) || 0;
        if (pc2 >= 3 && pc2 < 5 && k.behavior === 'sit') {
          document.dispatchEvent(new CustomEvent('tama-hint', {
            detail: { key: 'over-pet', catId: k.tamagotchiId, catName: k.tamagotchiName }
          }));
        }
      }

      // ── Trust-based behavior (only during social activities) ──
      if (k.tamagotchiId && !isScared) {
        const trust = tamagotchi.getTrust();
        // Only seek human attention during social activities — not when exploring, lounging, playing, or perching
        const wantsSocial = k.activity === 'observe' || k.activity === 'alert' || k.activity === 'social';

        // Greeting tail when approaching cursor (social only)
        if (trust > 60 && k.behavior === 'walk' && wantsSocial && dist > 100 && dist < 300) {
          if (Math.random() < 0.004) k.vx -= (dx / dist) * 0.4;
          k.el.dataset.tail = 'greeting';
        } else if (k.el.dataset.tail === 'greeting' && (dist > 300 || !wantsSocial)) {
          k.el.dataset.tail = k.origTail;
        }

        // Follow at distance — gentle, only when in the mood
        if (trust > 50 && k.behavior === 'walk' && wantsSocial && dist > 200 && dist < 400 && Math.random() < 0.002) {
          k.vx -= (dx / dist) * 0.25;
          k.vy -= (dy / dist) * 0.1;
        }
      }

      // Behavior timers
      if (!isScared && !isLeaving) {
        if (k.behavior === 'walk') {
          if (!isToyPlaying) {
            k.walkTimer--;
            if (k.walkTimer <= 0) {
              const nextB = pickActivityBehavior(k);
              enterBehavior(k, nextB);
              // Apply queue step's custom duration + popup if present
              if (k.behaviorQueue && k.behaviorQueue.length > 0 && k.behaviorQueue[0].behavior === nextB) {
                const step = k.behaviorQueue.shift()!;
                if (step.duration) k.bTimer = step.duration;
                if (step.popup) showPopup(k.el, step.popup);
              }
            }
          }
        } else {
          k.bTimer--;
          if (k.bTimer <= 0) exitBehavior(k);
        }
        // Zoomies: random direction flips
        if (k.behavior === 'zoomies' && k.bTimer % 35 === 0 && Math.random() > 0.5) {
          k.baseVx = -k.baseVx;
          k.vy += rand(-4, 4);
        }
      }

      // ── Mission system: drives ambient cat goals ─────────
      if (k.mission && k.missionTarget) {
        if (!k.missionTarget.alive()) {
          // Target gone — time to leave
          k.mission = 'leave';
          k.missionTarget = undefined;

          k.behaviorQueue = [];
          if (k.behavior !== 'walk') exitBehavior(k);
          // Head for nearest edge
          k.baseVx = k.x < mainW() / 2 ? -rand(2, 4) : rand(2, 4);
          k.savedVx = k.baseVx;
          k.baseY = k.y;
        } else if (k.mission === 'chase-food' || k.mission === 'chase-toy') {
          // Attraction toward target
          const tx = k.missionTarget.x();
          const ty = k.missionTarget.y();
          const ldx = tx - k.x;
          const ldy = ty - k.y;
          const ldist = Math.hypot(ldx, ldy);
          if (ldist > 20 && (k.behavior === 'walk' || k.behavior === 'stalk')) {
            k.vx += (ldx / ldist) * 0.6;
            k.vy += (ldy / ldist) * 0.6;
            k.baseVy = Math.max(-2.4, Math.min(2.4, (ldy / ldist) * 1.35));
            k.baseY = ty;
            if (Math.abs(ldx) > 5) k.el.dataset.facingRight = ldx > 0 ? '1' : '';
          }
        } else if (k.mission === 'observe') {
          const tx = k.missionTarget.x();
          const ty = k.missionTarget.y();
          const ldx = tx - k.x;
          const ldy = ty - k.y;
          const ldist = Math.hypot(ldx, ldy);
          const cursorTooClose = dist < 120;

          if ((k.missionFrames || 0) > 0) k.missionFrames = (k.missionFrames || 0) - 1;

          if (cursorTooClose) {
            k.mission = 'leave';
            k.missionTarget = undefined;
            k.missionFrames = 0;
            if (k.behavior !== 'walk') exitBehavior(k);
            const leaveDir = Math.sign(k.x - mx || (k.x < mainW() * 0.5 ? -1 : 1)) || 1;
            k.baseVx = leaveDir * rand(2.8, 4.6);
            k.savedVx = k.baseVx;
            k.baseVy = clamp((k.y - my) * 0.015, -1.6, 1.6);
          } else if ((k.missionFrames || 0) <= 0) {
            k.mission = 'cross';
            k.missionTarget = undefined;
            k.missionFrames = 0;
            if (k.behavior !== 'walk') exitBehavior(k);
            k.baseVx = k.x < mainW() * 0.5 ? rand(1.4, 2.6) : -rand(1.4, 2.6);
            k.savedVx = k.baseVx;
            k.baseVy = 0;
            k.baseY = k.y;
          } else if (ldist > 44) {
            if (k.behavior !== 'walk' && k.behavior !== 'stalk') exitBehavior(k);
            if (k.behavior === 'walk' || k.behavior === 'stalk') {
              steerToward(k, tx, ty, 0.08);
              k.baseVy = clamp((ldy / Math.max(1, ldist)) * 1.1, -1.3, 1.3);
              k.baseY = ty;
            }
            if (Math.abs(ldx) > 14) k.el.dataset.facingRight = ldx > 0 ? '1' : '';
          } else {
            if (k.behavior === 'walk' || k.behavior === 'stalk') {
              const settleBehavior: Behavior = Math.random() < 0.58 ? 'loaf' : 'sit';
              enterBehavior(k, settleBehavior);
              k.bTimer = settleBehavior === 'loaf'
                ? Math.floor(rand(320, 680))
                : Math.floor(rand(220, 460));
            }
            if (mx > -5000 && Math.abs(mx - k.x) > 18) {
              k.el.dataset.facingRight = (mx - k.x) > 0 ? '1' : '';
            }
          }
        }
      }
      // Leave mission: just walk toward edge (already set baseVx)
      // Cross mission: default ambient behavior, no special logic needed

      // Physics
      if (isScared && k.scaredDir) {
        if (k.behavior !== 'walk') exitBehavior(k);
        k.baseVx = k.scaredDir * Math.max(4.2, Math.abs(k.baseVx || k.savedVx || 4.2));
        k.savedVx = k.baseVx;
      }

      k.vx *= DRAG;
      k.vy *= DRAG;
      if ((k.behavior === 'sit' || k.behavior === 'groom' || k.behavior === 'nap') && !isScared) {
        k.vx *= 0.18;
        k.vy *= 0.18;
        if (Math.abs(k.vx) < 0.08) k.vx = 0;
        if (Math.abs(k.vy) < 0.08) k.vy = 0;
      }
      if (k.tamagotchiId) {
        // Tamagotchi cats: change vertical direction periodically
        if (!isLeaving && !isScared && k.behavior === 'walk' && Math.random() < 0.003) {
          k.baseVy = rand(-1, 1);
        }
        // Bounce off Y bounds by flipping baseVy
        if (!isLeaving) {
          const minY = 80, maxYBound = mainH() - 80;
          if (k.y < minY + 20) k.baseVy = Math.abs(k.baseVy) || 0.5;
          else if (k.y > maxYBound - 20) k.baseVy = -Math.abs(k.baseVy) || -0.5;
        }
      } else if (k.mission === 'chase-food' || k.mission === 'chase-toy') {
        // Chasing cats: no Y spring, mission attraction handles Y
      } else {
        k.vy += (k.baseY - k.y) * Y_SPRING;
      }

      // Clamp velocity
      const MAX_V = 15;
      k.vx = Math.max(-MAX_V, Math.min(MAX_V, k.vx));
      k.vy = Math.max(-MAX_V, Math.min(MAX_V, k.vy));

      // Stationary behaviors: hard-zero all velocity (forces can't move a sitting/napping cat)
      const isStationary = STATIONARY.includes(k.behavior);
      if (isStationary) {
        k.vx = 0; k.vy = 0;
        k.baseVx = 0; k.baseVy = 0;
      }

      const totalVx = k.baseVx + k.vx;
      const totalVy = ((k.tamagotchiId || k.mission === 'chase-food' || k.mission === 'chase-toy' || k.mission === 'leave') ? k.baseVy : 0) + k.vy;
      const actualSpeed = Math.hypot(totalVx, totalVy);
      k.x += totalVx;
      k.y += totalVy;

      // data-moving: drives leg animation via CSS
      k.el.dataset.moving = actualSpeed > 0.5 ? '1' : '';

      // Auto-sit: cat walking with no velocity should stop and sit
      if (k.behavior === 'walk' && actualSpeed < 0.3 && !isScared && !isLeaving) {
        k.idleFrames = (k.idleFrames || 0) + 1;
        if (k.idleFrames > 30) {
          enterBehavior(k, 'sit');
          k.bTimer = Math.floor(rand(120, 300));
          k.idleFrames = 0;
        }
      } else {
        k.idleFrames = 0;
      }

      // Y bounds
      const minY = 80, maxY = Math.max(mainH() - 80, minY + 200);
      if (!isLeaving) {
        if (k.y < minY) {
          k.y = minY;
          if (isScared) {
            k.baseVy = rand(0.8, 1.8);
            k.vy = Math.max(1.5, Math.abs(k.vy)) + rand(0.6, 1.6);
            if (Math.random() < 0.55 && k.scaredDir) k.scaredDir = (k.scaredDir * -1) as -1 | 1;
          } else {
            k.vy = Math.abs(k.vy) * 0.3;
          }
        }
        if (k.y > maxY) {
          k.y = maxY;
          if (isScared) {
            k.baseVy = -rand(0.8, 1.8);
            k.vy = -Math.max(1.5, Math.abs(k.vy)) - rand(0.6, 1.6);
            if (Math.random() < 0.55 && k.scaredDir) k.scaredDir = (k.scaredDir * -1) as -1 | 1;
          } else {
            k.vy = -Math.abs(k.vy) * 0.3;
          }
        }
      }

      // Flip — deadzone to prevent rapid flickering
      const flipThreshold = 0.3;
      if (Math.abs(totalVx) > flipThreshold) {
        k.el.dataset.facingRight = totalVx >= 0 ? '1' : '';
      }
      const flip = k.el.dataset.face === 'front' ? '' : (k.el.dataset.facingRight === '1' ? '' : 'scaleX(-1)');

      // Walk animation speed
      const spd = Math.hypot(totalVx, k.vy);
      const ref = Math.abs(k.savedVx || k.baseVx) || 1;
      const ratio = spd / ref;
      const wk = STATIONARY.includes(k.behavior)
        ? k.normalWalk
        : Math.max(0.06, k.normalWalk / Math.max(ratio, 0.5));
      k.el.style.setProperty('--kitten-walk-speed', `${wk}s`);

      // Base tail mood from movement/personality; stronger emotional overrides are applied separately below.
      if (k.behavior === 'walk') {
        if (ratio > 3.5) k.el.dataset.tail = 'playful';
        else if (ratio <= 1.5 && k.el.dataset.tail !== k.origTail) k.el.dataset.tail = k.origTail;
      }

      const tailOverride = getTailOverride(k, isScared);
      if (tailOverride) k.el.dataset.tailOverride = tailOverride;
      else delete k.el.dataset.tailOverride;
      const liveIntent = getLiveIntent(k, isScared, isLeaving);
      if (liveIntent) k.el.dataset.liveIntent = liveIntent;
      else delete k.el.dataset.liveIntent;
      // scared state resolved in expression resolver below

      k.el.style.transform = `translate(${k.x}px, ${k.y}px) ${flip}`;

      // Offscreen handling
      if (k.tamagotchiId && !isLeaving) {
        // Tamagotchi cats stay within the visible page
        const margin = 20;
        // Jump over cursor if it's blocking the escape route
        const cursorNearEdge = Math.hypot(k.x - mx, k.y - my) < 200;
        const jumpForce = cursorNearEdge ? rand(8, 14) : rand(2, 5);
        if (k.x < margin) {
          k.x = margin + 10;
          if (isScared) {
            k.scaredDir = 1;
            k.baseVx = rand(3.6, 5.8);
            k.savedVx = k.baseVx;
            k.vx = rand(2.8, 4.8);
            k.baseVy = rand(-1.8, 1.8);
            k.vy -= rand(4, 8);
          } else {
            k.baseVx = Math.abs(k.baseVx) || 3.5;
            k.savedVx = Math.abs(k.savedVx) || k.baseVx;
            k.vx = Math.max(3.5, Math.abs(k.vx));
            k.vy -= jumpForce;
          }
        }
        else if (k.x > mainW() - margin) {
          k.x = mainW() - margin - 10;
          if (isScared) {
            k.scaredDir = -1;
            k.baseVx = -rand(3.6, 5.8);
            k.savedVx = k.baseVx;
            k.vx = -rand(2.8, 4.8);
            k.baseVy = rand(-1.8, 1.8);
            k.vy -= rand(4, 8);
          } else {
            k.baseVx = -Math.abs(k.baseVx) || -3.5;
            k.savedVx = -Math.abs(k.savedVx) || k.baseVx;
            k.vx = -Math.max(3.5, Math.abs(k.vx));
            k.vy -= jumpForce;
          }
        }
      } else if (k.x < -250 || k.x > mainW() + 250 || k.y < mainScrollY() - 250 || k.y > mainScrollY() + mainViewH() + 250) {
        // Ambient cats or shooed tamagotchi cats despawn
        const wasTama = !!k.tamagotchiId;
        if (k.tamagotchiId) onScreenTamagotchi.delete(k.tamagotchiId);
        k.el.remove(); cats.splice(i, 1); activeKittens--;
        if (wasTama) document.dispatchEvent(new CustomEvent('tama-cats-changed'));
      }
    }

    // Toys
    for (let i = yarns.length - 1; i >= 0; i--) {
      const y = yarns[i];
      if (y.cooldown > 0) y.cooldown--;
      if (y.variant === 'yarn') {
        const speed = Math.hypot(y.vx, y.vy);
        if (speed > 0.05) {
          y.driftDirX = y.vx / speed;
          y.driftDirY = y.vy / speed;
        }

        const targetSpeed = Math.max(1.4, y.boostSpeed, y.cruiseSpeed);
        const nextSpeed =
          speed < targetSpeed
            ? speed + (targetSpeed - speed) * 0.22
            : speed - (speed - targetSpeed) * 0.05;

        y.vx = y.driftDirX * nextSpeed;
        y.vy = y.driftDirY * nextSpeed;
        y.boostSpeed = Math.max(y.cruiseSpeed, y.boostSpeed * 0.992);
        y.el.dataset.dir = y.vx >= 0 ? 'right' : 'left';
      } else {
        y.vx *= 0.965;
        y.vy = (y.vy * 0.88) + Math.sin(Date.now() / 120 + i) * 0.04 + 0.03;
      }

      y.x += y.vx;
      y.y += y.vy;

      for (const k of cats) {
        const isAmbientToyCat = !k.tamagotchiId && k.toyPlayVariant === y.variant && (k.toyPlayFrames || 0) > 0;
        if ((!k.tamagotchiId && !isAmbientToyCat) || k.behavior === 'nap') continue;
        if (y.targetCatId && k.tamagotchiId !== y.targetCatId) continue;
        const keepPlaying = shouldContinueToyPlay(k, y.variant);
        const shouldChase = k.tamagotchiId ? shouldChaseToy(k, y.variant) : isAmbientToyCat;
        if (!keepPlaying && !shouldChase) continue;
        if (!keepPlaying) {
          if (k.tamagotchiId) startToyPlay(k, y.variant);
          else startAmbientToyPlay(k, y.variant);
        }

        const chaseDx = y.x - k.x;
        const chaseDy = y.y - k.y;
        const chaseDist = Math.hypot(chaseDx, chaseDy);
        if (chaseDist < 18 || chaseDist > 460) continue;

        const contactRadius = y.variant === 'feather' ? 50 : 46;
        const prepRadius = y.variant === 'feather' ? 60 : 66;
        const arrivalRadius = y.variant === 'feather' ? 96 : 108;
        const slowRadius = y.variant === 'feather' ? 190 : 220;
        const isCommitted = k.toyCommitVariant === y.variant && (k.toyCommitFrames || 0) > 0;
        if (chaseDist < arrivalRadius) {
          const closePullX = isCommitted ? (y.variant === 'feather' ? 1.5 : 1.2) : (y.variant === 'feather' ? 0.9 : 0.72);
          const closePullY = isCommitted ? (y.variant === 'feather' ? 1.25 : 0.95) : (y.variant === 'feather' ? 0.72 : 0.55);
          if (k.behavior === 'walk' || k.behavior === 'stalk' || isCommitted) {
            k.vx += (chaseDx / chaseDist) * closePullX;
            k.vy += (chaseDy / chaseDist) * closePullY;
          } else {
            k.vx *= 0.82;
            k.vy *= 0.8;
          }
          if ((k.behavior === 'walk' || k.behavior === 'stalk') && chaseDist < prepRadius && y.cooldown <= 4 && (k.toyPlayRecover || 0) <= 0) {
            queueToyAction(k, y.variant, chaseDist);
            k.toyPlayRecover = Math.floor(rand(16, 30));
          }
          if (isCommitted && chaseDist > slowRadius + 40) {
            k.toyCommitFrames = 0;
            k.toyCommitVariant = undefined;
          }
          if (Math.abs(chaseDx) > 12) {
            k.el.dataset.facingRight = chaseDx > 0 ? '1' : '';
          }
          continue;
        }

        const chaseT = Math.min(1, Math.max(0.2, (chaseDist - arrivalRadius) / Math.max(1, slowRadius - arrivalRadius)));
        const pullX = y.variant === 'feather' ? 1.25 : 0.85;
        const pullY = y.variant === 'feather' ? 0.95 : 0.4;
        k.vx += (chaseDx / chaseDist) * pullX * chaseT;
        k.vy += (chaseDy / chaseDist) * pullY * chaseT;

        if (k.behavior === 'walk' && chaseDist < (y.variant === 'feather' ? 150 : 180) && (k.toyPlayRecover || 0) <= 0) {
          enterBehavior(k, 'stalk');
        } else if ((k.behavior === 'playbow' || k.behavior === 'pounce') && chaseDist > 95) {
          exitBehavior(k);
          enterBehavior(k, 'stalk');
        }

        if (Math.abs(chaseDx) > 8) {
          k.el.dataset.facingRight = chaseDx > 0 ? '1' : '';
        }
      }

      for (const k of cats) {
        const isAmbientToyCat = !k.tamagotchiId && k.toyPlayVariant === y.variant && (k.toyPlayFrames || 0) > 0;
        if ((!k.tamagotchiId && !isAmbientToyCat) || k.behavior === 'nap') continue;
        if (y.targetCatId && k.tamagotchiId !== y.targetCatId) continue;
        const dist = Math.hypot(k.x - y.x, k.y - y.y);
        const contactRadius = y.variant === 'feather' ? 50 : 46;
        if (dist > contactRadius || y.cooldown > 0) continue;

        if (y.variant === 'yarn') {
          y.vx += Math.sign(y.x - k.x || 1) * rand(2.5, 4.8);
          y.vy += rand(-1.2, 1.2);
          const swatSpeed = Math.hypot(y.vx, y.vy);
          if (swatSpeed > 0.05) {
            y.driftDirX = y.vx / swatSpeed;
            y.driftDirY = y.vy / swatSpeed;
          }
          y.cruiseSpeed = Math.max(y.cruiseSpeed, Math.min(10.5, swatSpeed));
          y.boostSpeed = Math.max(y.boostSpeed, Math.min(13.5, swatSpeed * 1.18));
          if (k.behavior === 'walk') enterBehavior(k, Math.random() < 0.65 ? 'pounce' : 'playbow');
          showPopup(k.el, '🐾');
        } else {
          y.vx += Math.sign(y.x - k.x || 1) * rand(3.8, 6.4);
          y.vy -= rand(3.2, 5.6);
          if (k.behavior === 'walk') enterBehavior(k, 'pounce');
          showPopup(k.el, '🪶');
        }

        if (k.tamagotchiId || isAmbientToyCat) {
          k.toyCommitFrames = 0;
          k.toyCommitVariant = undefined;
          const roundsLeft = Math.max(0, (k.toyPlayRounds || 1) - 1);
          k.toyPlayRounds = roundsLeft;
          if (roundsLeft > 0 && Math.random() < (y.variant === 'feather' ? 0.82 : 0.68)) {
            k.toyPlayFrames = Math.max(k.toyPlayFrames || 0, Math.floor(rand(110, 180)));
            k.toyPlayRecover = Math.floor(rand(18, 34));
            if (k.behavior !== 'walk') exitBehavior(k);
          } else {
            k.toyPlayFrames = Math.floor(rand(20, 60));
            k.toyPlayRounds = 0;
            k.toyPlayRecover = Math.floor(rand(28, 50));
            if (Math.random() < 0.5 && k.behavior === 'walk') {
              enterBehavior(k, 'sit');
              k.bTimer = Math.max(k.bTimer, 90);
            }
            if (!k.tamagotchiId) {
              // Done playing — leave
              k.mission = 'leave';
              k.missionTarget = undefined;
    
              k.baseY = k.y;
              k.baseVy = 0;
              k.baseVx = k.x < mainW() / 2 ? -rand(2, 4) : rand(2, 4);
              k.savedVx = k.baseVx;
            }
          }
        }
        y.cooldown = 12;

        if (Math.abs(y.x - k.x) > 8) {
          k.el.dataset.facingRight = (y.x - k.x) > 0 ? '1' : '';
        }
        break;
      }

      y.el.style.transform = `translate(${y.x}px, ${y.y}px)`;
      const offscreenMargin = y.variant === 'feather' ? 72 : 250;
      const minYBound = y.variant === 'feather' ? mainScrollY() - offscreenMargin : -offscreenMargin;
      const maxYBound = y.variant === 'feather'
        ? mainScrollY() + mainViewH() + offscreenMargin
        : mainH() + offscreenMargin;
      if (y.x < -offscreenMargin || y.x > mainW() + offscreenMargin || y.y < minYBound || y.y > maxYBound) {
        y.el.remove(); yarns.splice(i, 1);
      }
    }

    // ── Resolve expressions: tail, ears, eyes from state (per frame) ──
    for (const k of cats) {
      const isScared = !!(k.scaredFrames && k.scaredFrames > 0);
      const pc = petCount.get(k.tamagotchiId) || 0;
      const trust = tamagotchi.getTrust();

      // Tail: behavior sets base tail, but scared/irritated/greeting override
      if (isScared) {
        k.el.dataset.tail = 'scared';
      } else if (pc >= 3 && pc < 5 && k.behavior === 'sit') {
        k.el.dataset.tail = 'irritated';
      }
      // greeting tail is set in the trust-based section above — don't override it here

      // Ears: resolved from state
      if (isScared) {
        k.el.dataset.ears = 'flat';
      } else if (k.personality === 'shy' && trust < 30) {
        k.el.dataset.ears = 'nervous';
      } else if (k.behavior === 'stalk' || k.el.dataset.tail === 'greeting') {
        k.el.dataset.ears = 'forward';
      } else {
        delete k.el.dataset.ears;
      }

      // Face: front-facing when sitting/loafing in watchful activities, or kneading
      const isEngaging = (
        (k.activity === 'observe' || k.activity === 'alert' || k.activity === 'perch') &&
        (k.behavior === 'sit' || k.behavior === 'loaf')
      ) || k.behavior === 'knead' || k.behavior === 'headbonk';
      if (isEngaging && !isScared) {
        k.el.dataset.face = 'front';
      } else {
        delete k.el.dataset.face;
      }
    }

    // Keep kittens-stage covering full scroll height
    stage.style.height = `${mainH()}px`;

    requestAnimationFrame(tick);
  }

  /* ═══ Spawn ════════════════════════════════════════════ */

  function makeKitten(opts: {
    size?: [number, number];
    goRight?: boolean;
    yPos?: number;
    speed?: [number, number];
    personality?: Personality;
    force?: boolean;
    furIndex?: number;
    tamagotchi?: TamagotchiCat;
  } = {}): KState | null {
    const force = opts.force ?? false;
    const isTama = !!opts.tamagotchi;
    if (reducedMotion) return null;

    // Don't spawn duplicate tamagotchi cats
    if (isTama && onScreenTamagotchi.has(opts.tamagotchi!.id)) return null;

    const el = (kittenTpl.content.cloneNode(true) as DocumentFragment).querySelector('.kitten') as HTMLElement;

    // Fur color: use specific index for tamagotchi/named cats, or random
    const palIndex = opts.tamagotchi?.furIndex ?? opts.furIndex;
    const pal = palIndex != null ? FUR[palIndex % FUR.length] : pick(FUR);
    el.style.setProperty('--kitten-fur', pal.fur);
    el.style.setProperty('--kitten-fur-dark', pal.dark);
    el.style.setProperty('--kitten-eye', pal.eye);

    // Size: based on stage for tamagotchi cats
    const sizeRange = isTama ? (STAGE_SIZE[opts.tamagotchi!.stage] ?? [50, 90]) : (opts.size ?? [50, 90]);
    const [sMin, sMax] = sizeRange;
    el.style.setProperty('--kitten-size', `${rand(sMin, sMax)}px`);

    const personality = opts.tamagotchi?.personality as Personality ?? opts.personality ?? pick(PERSONALITIES);
    const tailMood = TAIL_FOR_PERSONALITY[personality];
    el.dataset.tail = tailMood;

    const goRight = opts.goRight ?? Math.random() > 0.5;
    const x = goRight ? -150 : mainW() + 150;
    const y = opts.yPos ?? mainScrollY() + rand(mainViewH() * 0.4, mainViewH() * 0.85);

    // Speed: based on stage for tamagotchi cats
    const speedRange = isTama ? (STAGE_SPEED[opts.tamagotchi!.stage] ?? [1.3, 3.9]) : (opts.speed ?? [1.25, 3.9]);
    const [spMin, spMax] = speedRange;
    const speed = rand(spMin, spMax);
    const baseVx = goRight ? speed : -speed;
    const normalWalk = Math.max(0.15, 0.35 * (3 / speed));
    el.style.setProperty('--kitten-walk-speed', `${normalWalk}s`);

    el.style.pointerEvents = 'auto';
    el.style.cursor = 'pointer';

    // Name label for tamagotchi cats (and named ambient/sold cats)
    const catName = opts.tamagotchi?.name;
    if (catName) {
      const nameEl = el.querySelector('.kitten-name') as HTMLElement;
      if (nameEl) {
        nameEl.textContent = catName;
        nameEl.style.display = 'block';
      }
      if (isTama) {
        el.classList.add('kitten--tamagotchi');
        el.dataset.tamagotchiId = opts.tamagotchi!.id;
      }
    }

    const initActivity = pickActivity(personality);
    const [aLo, aHi] = ACTIVITY_DUR[initActivity];
    const initBaseVy = isTama ? rand(-0.5, 0.5) : 0;
    const state: KState = {
      el, x, y, vx: 0, vy: 0,
      baseVx, baseVy: initBaseVy, savedVx: baseVx, baseY: y,
      personality,
      behavior: 'walk', bTimer: 0,
      walkTimer: Math.floor(rand(200, 500)),
      normalWalk, origTail: tailMood,
      
      activity: initActivity,
      activityTimer: Math.floor(rand(aLo, aHi)),
      tamagotchiId: isTama ? opts.tamagotchi!.id : undefined,
      tamagotchiName: catName,
      askCooldown: Math.floor(rand(300, 720)),
      mission: isTama ? null : 'cross', // ambient cats cross, tamagotchi cats stay
    };

    if (isTama) {
      // Tamagotchi cat: clicking = petting or shooing
      el.addEventListener('click', (e) => {
        e.stopPropagation();
        handleTamagotchiClick(state, e);
      });
      onScreenTamagotchi.add(opts.tamagotchi!.id);
    } else {
      // Ambient cat: click to jump (original behavior)
      el.addEventListener('click', (e) => {
        e.stopPropagation();
        state.vx += Math.sign(state.x - e.pageX || 1) * 28;
        state.vy -= 6;
        if (state.behavior !== 'walk') exitBehavior(state);
      });
    }

    activeKittens++;
    cats.push(state);
    el.classList.add('kitten--entering');
    stage.appendChild(el);
    requestAnimationFrame(() => el.classList.remove('kitten--entering'));
    if (isTama) document.dispatchEvent(new CustomEvent('tama-cats-changed'));
    return state;
  }

  function spawnAmbientKitten(force = false) {
    const r = Math.random();
    if (r < 0.05) spawnYarnChase();
    else if (r < 0.1) spawnMamaKittens();
    else {
      // Sold kittens can appear as named ambient cats
      const sold = tamagotchi.getAmbientCats();
      if (sold.length > 0 && Math.random() < 0.3) {
        const cat = pick(sold);
        makeKitten({ force, furIndex: cat.furIndex, personality: cat.personality as Personality, tamagotchi: undefined });
      } else {
        makeKitten({ force });
      }
    }
  }

  function spawnTamagotchiOrAmbient(force = false) {
    // Try to spawn a tamagotchi cat not already on screen
    const available = tamagotchi.getTamagotchiCats().filter(c => !onScreenTamagotchi.has(c.id));
    if (available.length > 0) {
      // Trust affects who appears first — high trust cats "want" to see you
      const trust = tamagotchi.getTrust();
      let cat: typeof available[0];
      if (trust > 30 && available.length > 1) {
        // Sort by personality eagerness at this trust level
        // Shy cats only appear at high trust, playful cats always eager
        const eager = available.filter(c => {
          if (c.personality === 'shy') return trust > 50;
          return true;
        });
        cat = eager.length > 0 ? pick(eager) : pick(available);
      } else {
        cat = pick(available);
      }
      makeKitten({ tamagotchi: cat, force: true });
    } else {
      spawnAmbientKitten(force);
    }
  }

  function spawnYarnChase() {
    if (reducedMotion) return;
    const goRight = Math.random() > 0.5;
    const yPos = mainScrollY() + rand(mainViewH() * 0.4, mainViewH() * 0.75);
    const speed = rand(3.5, 5);
    const vx = goRight ? speed : -speed;
    const launchSpeed = Math.abs(vx) || 1;

    const yEl = (yarnTpl.content.cloneNode(true) as DocumentFragment).querySelector('.yarn') as HTMLElement;
    yEl.style.setProperty('--yarn-color', pick(YARN_COLORS));
    yEl.dataset.dir = goRight ? 'right' : 'left';
    yarns.push({
      el: yEl,
      x: goRight ? -50 : mainW() + 50,
      y: yPos,
      vx,
      vy: 0,
      cruiseSpeed: launchSpeed,
      boostSpeed: launchSpeed,
      driftDirX: vx / launchSpeed,
      driftDirY: 0,
      variant: 'yarn',
      cooldown: 0,
    });
    stage.appendChild(yEl);

    const count = Math.floor(rand(4, 6));
    for (let j = 0; j < count; j++) {
      setTimeout(() => {
        makeKitten({
          size: [28, 45], goRight,
          yPos: yPos + rand(-40, 40),
          speed: [speed * 0.85, speed * 1.15],
          personality: 'playful', force: true,
        });
      }, j * rand(400, 900));
    }
  }

  function spawnMamaKittens() {
    if (reducedMotion) return;
    const goRight = Math.random() > 0.5;
    const yPos = mainScrollY() + rand(mainViewH() * 0.4, mainViewH() * 0.75);
    const speed = rand(1.5, 2.5);

    makeKitten({
      size: [90, 110], goRight, yPos,
      speed: [speed, speed],
      personality: 'sassy', force: true,
    });

    const count = Math.floor(rand(2, 4));
    for (let j = 0; j < count; j++) {
      setTimeout(() => {
        makeKitten({
          size: [25, 38], goRight,
          yPos: yPos + rand(-30, 30),
          speed: [speed * 0.9, speed * 1.2],
          personality: pick(['playful', 'curious'] as const),
          force: true,
        });
      }, (j + 1) * rand(600, 1200));
    }
  }

  /* ═══ Tamagotchi interactions ══════════════════════════ */

  // Receptive states for petting
  const RECEPTIVE: Behavior[] = ['walk', 'sit', 'groom'];
  const SHOO_THRESHOLD = 4; // clicks needed to shoo a cat away

  function showPopup(el: HTMLElement, icon: string) {
    const popup = document.createElement('div');
    popup.className = 'tama-care-popup';
    popup.textContent = icon;
    el.appendChild(popup);
    popup.addEventListener('animationend', () => popup.remove());
  }

  function emitAskIndicator(
    k: KState,
    kind: 'food' | 'attention' | 'play',
    focusX: number,
    focusY: number,
    icon: string,
    label: string
  ) {
    if (!k.tamagotchiId) return;
    document.dispatchEvent(new CustomEvent('tama-ask-indicator', {
      detail: {
        catId: k.tamagotchiId,
        catName: k.tamagotchiName,
        kind,
        icon,
        label,
        x: focusX,
        y: focusY,
      }
    }));
  }

  function tryEmitAsk(
    k: KState,
    kind: 'food' | 'attention' | 'play',
    focusX: number,
    focusY: number,
    icon: string,
    label: string,
    cooldownRange: [number, number]
  ) {
    if (!k.tamagotchiId || k.askCooldown > 0 || globalAskCooldown > 0 || !isCatInViewport(k, 32)) return false;
    showPopup(k.el, icon);
    emitAskIndicator(k, kind, focusX, focusY, icon, label);
    emitTamaSound(
      kind === 'food'
        ? 'ask-food'
        : kind === 'play'
          ? 'play-demand'
          : 'ask-attention',
      { catId: k.tamagotchiId, personality: k.personality }
    );
    k.askCooldown = Math.floor(rand(cooldownRange[0], cooldownRange[1]));
    globalAskCooldown = Math.floor(rand(120, 210));
    return true;
  }

  function emitHint(detail: Record<string, unknown>) {
    document.dispatchEvent(new CustomEvent('tama-hint', { detail }));
  }

  function getFoodThreshold(k: KState, variant: CareVariant) {
    let hungerThreshold = 70;
    if (k.personality === 'lazy') hungerThreshold = 40;
    if (k.personality === 'curious') hungerThreshold = 85;
    if (k.personality === 'shy') hungerThreshold = 50;
    if (k.personality === 'chaotic') hungerThreshold = 80;
    if (variant === 'treat') {
      hungerThreshold += 15;
      if (k.personality === 'playful') hungerThreshold += 10;
    }
    if (variant === 'fish' && k.personality === 'lazy') hungerThreshold += 15;
    if (variant === 'pellets' && k.personality === 'sassy') hungerThreshold -= 10;
    return hungerThreshold;
  }

  function shouldWakeForFood(k: KState, catData: TamagotchiCat, variant?: CareVariant) {
    const threshold = variant ? getFoodThreshold(k, variant) : (k.personality === 'lazy' ? 18 : 28);
    return catData.hunger < threshold;
  }

  function getPreferredFoodVariant(k: KState): CareVariant {
    if (k.personality === 'playful' || k.personality === 'chaotic') return 'treat';
    if (k.personality === 'lazy' || k.personality === 'shy') return 'fish';
    if (k.personality === 'sassy') return 'fish';
    return 'pellets';
  }

  function getPreferredToyVariant(k: KState): CareVariant {
    if (k.personality === 'playful' || k.personality === 'chaotic' || k.personality === 'sassy') return 'feather';
    return 'yarn';
  }

  function getVariantLabel(variant: CareVariant) {
    switch (variant) {
      case 'fish': return 'vis';
      case 'pellets': return 'brokjes';
      case 'treat': return 'treat';
      case 'yarn': return 'wol';
      case 'feather': return 'veertje';
      case 'brush': return 'borstel';
      default: return variant;
    }
  }

  function emitTamaSound(kind: string, detail: Record<string, unknown> = {}) {
    document.dispatchEvent(new CustomEvent('tama-sound', { detail: { kind, ...detail } }));
  }

  function findCatById(catId?: string): KState | null {
    if (!catId) return null;
    return cats.find((cat) => cat.tamagotchiId === catId) || null;
  }

  function getTamagotchiData(catId?: string): TamagotchiCat | undefined {
    if (!catId) return undefined;
    return tamagotchi.getState()?.cats.find((cat) => cat.id === catId);
  }

  function shouldChaseToy(k: KState, variant: CareVariant): boolean {
    if (!k.tamagotchiId || k.behavior === 'nap') return false;
    const catData = getTamagotchiData(k.tamagotchiId);
    if (!catData) return false;

    if (k.personality === 'playful') return catData.energy > (variant === 'feather' ? 10 : 15);
    if (k.personality === 'curious') return catData.energy > (variant === 'feather' ? 18 : 25);
    if (k.personality === 'chaotic') return catData.energy > (variant === 'feather' ? 8 : 14);
    if (k.personality === 'sassy') return catData.energy > 50 && Math.random() < (variant === 'feather' ? 0.45 : 0.3);
    if (k.personality === 'shy') {
      // Shy cats only chase when alone and feeling safe
      const otherTamaOnScreen = cats.filter(c => c.tamagotchiId && c !== k).length;
      return otherTamaOnScreen === 0 && catData.energy > 30 && Math.random() < 0.4;
    }
    if (k.personality === 'lazy') return false; // lazy cats never chase
    return false;
  }

  function startToyPlay(k: KState, variant: CareVariant) {
    const baseRounds =
      k.personality === 'playful' || k.personality === 'chaotic' ? rand(2, 4) :
      k.personality === 'curious' ? rand(1, 3) :
      k.personality === 'sassy' ? rand(1, 2) :
      rand(1, 2);

    k.toyPlayVariant = variant;
    k.toyPlayFrames = Math.floor(variant === 'feather' ? rand(220, 360) : rand(170, 300));
    k.toyPlayRounds = Math.max(1, Math.round(baseRounds));
    k.toyPlayRecover = 0;
  }

  function startAmbientToyPlay(k: KState, variant: CareVariant) {
    k.toyPlayVariant = variant;
    k.toyPlayFrames = Math.floor(variant === 'feather' ? rand(180, 300) : rand(150, 260));
    k.toyPlayRounds = Math.floor(variant === 'feather' ? rand(1, 3) : rand(1, 2));
    k.toyPlayRecover = 0;
    if (!k.mission || k.mission === 'cross') {
      k.mission = 'chase-toy';
    }
  }

  function queueToyAction(k: KState, variant: CareVariant, chaseDist: number) {
    // Full play chain: prep → POUNCE → recover → (decide next round or done)
    const isFeather = variant === 'feather';
    const closeEnoughForPlaybow = chaseDist < (isFeather ? 48 : 54);
    const prepBehavior: Behavior = closeEnoughForPlaybow
      ? (isFeather ? (Math.random() < 0.35 ? 'stalk' : 'playbow') : 'playbow')
      : 'stalk';
    k.toyCommitVariant = variant;
    k.toyCommitFrames = Math.floor(isFeather ? rand(40, 56) : rand(34, 48));

    k.behaviorQueue = [
      { behavior: 'pounce', duration: Math.floor(rand(40, 70)), popup: isFeather ? '🪶' : '🐾' },
      { behavior: 'sit', duration: Math.floor(rand(30, 60)) }, // brief recover
    ];

    // Enter prep behavior (wiggle butt / playbow)
    enterBehavior(k, prepBehavior);
    k.bTimer = Math.floor(prepBehavior === 'stalk' ? rand(14, 26) : rand(24, 40));

    // After the pounce, knock the toy
    setTimeout(() => {
      // Find the yarn this cat was playing with and give it a bump
      for (const y of yarns) {
        if (y.variant !== variant) continue;
        const d = Math.hypot(y.x - k.x, y.y - k.y);
        if (d < 120) {
          // Knock the toy in a random direction
          y.vx += (Math.random() - 0.5) * 6;
          y.vy += rand(-3, -1);
          y.boostSpeed = Math.max(y.boostSpeed, 3);
          break;
        }
      }
    }, Math.floor(rand(400, 800)));
  }

  function shouldContinueToyPlay(k: KState, variant: CareVariant): boolean {
    return k.toyPlayVariant === variant && (k.toyPlayFrames || 0) > 0 && (k.toyPlayRounds || 0) > 0;
  }

  function startScaredRun(k: KState, dir: number, frames = 150, speed = 4.2) {
    const scaredDir = (dir >= 0 ? 1 : -1) as -1 | 1;
    k.scaredFrames = Math.max(k.scaredFrames || 0, frames);
    k.scaredDir = scaredDir;
    if (k.behavior !== 'walk') exitBehavior(k);
    k.baseVx = scaredDir * Math.max(speed, Math.abs(k.baseVx || k.savedVx || speed));
    k.savedVx = k.baseVx;
    k.vx = scaredDir * Math.max(Math.abs(k.vx), speed * 0.7);
    k.vy *= 0.2;
  }

  function setInteraction(k: KState, interaction: KState['interaction'], frames: number) {
    if (!interaction) return;
    k.interaction = interaction;
    k.interactionFrames = Math.max(k.interactionFrames || 0, frames);
    k.el.dataset.interaction = interaction;
  }

  function getTailOverride(k: KState, isScared: boolean): string {
    if (isScared) return 'scared';
    if ((k.toyPlayFrames || 0) > 0) return 'playful';
    const catData = getTamagotchiData(k.tamagotchiId);
    const petsReceived = k.tamagotchiId ? (petCount.get(k.tamagotchiId) || 0) : 0;
    if ((k.shooCount || 0) > 0 || petsReceived >= 3) return 'irritated';
    if (catData) {
      if (catData.hunger < 35 || catData.happiness < 45) return 'alert';
      if (catData.energy > 75 && k.personality === 'playful') return 'playful';
    }
    if (k.personality === 'sassy' && (k.behavior === 'sit' || k.behavior === 'walk') && Math.abs(k.baseVx + k.vx) < 1.6) {
      return 'sassy';
    }
    return '';
  }

  function getLiveIntent(k: KState, isScared: boolean, isLeaving: boolean): string {
    if (isLeaving || k.shooed) return 'Wil weg';
    if (isScared) return (k.shooCount || 0) > 0 ? 'Geirriteerd' : 'Geschrokken';
    if (k.interaction === 'eat') return 'Aan het eten';
    if (k.behavior === 'nap') return 'Slaapt';
    if ((k.shooCount || 0) > 0) return 'Geirriteerd';
    if ((k.toyPlayFrames || 0) > 0 || k.behavior === 'playbow' || k.behavior === 'pounce') return 'Aan het spelen';
    if (k.behavior === 'groom') return 'Poetst zich';
    if (k.behavior === 'stalk') return 'Aan het observeren';
    return '';
  }

  function nudgeToward(k: KState, targetX: number, targetY: number, forceX: number, forceY: number, keepDistance = 0) {
    const dx = targetX - k.x;
    const dy = targetY - k.y;
    const dist = Math.hypot(dx, dy);
    if (dist < 1) return dist;

    if (keepDistance > 0 && dist < keepDistance) {
      k.vx *= 0.82;
      k.vy *= 0.82;
      return dist;
    } else {
      k.vx += (dx / dist) * forceX;
      k.vy += (dy / dist) * forceY;
    }

    if (Math.abs(dx) > 22) {
      k.el.dataset.facingRight = dx > 0 ? '1' : '';
    }
    return dist;
  }

  let petCount = new Map<string, number>(); // track consecutive pets per cat
  const PET_ANNOY_THRESHOLD = 5; // too many pets in a row

  function handleTamagotchiClick(k: KState, e: MouseEvent) {
    if (!k.tamagotchiId) return;
    k.behaviorQueue = []; // interrupt any chain

    const rect = mainEl.getBoundingClientRect();
    const clickX = e.clientX - rect.left;
    const pushDir = Math.sign(k.x - clickX || 1);

    // Check if cat is receptive to petting
    const isReceptive = RECEPTIVE.includes(k.behavior);
    const isSassy = k.personality === 'sassy';
    const sassyRejects = isSassy && Math.random() < 0.4;
    const petsReceived = petCount.get(k.tamagotchiId!) || 0;
    const overPetted = petsReceived >= PET_ANNOY_THRESHOLD;
    const escalatingShoo = (k.scaredFrames || 0) > 0 || (k.shooCount || 0) > 0;

    if (k.behavior === 'nap') {
      // Waking up a napping cat — annoyed!
      exitBehavior(k);
      startScaredRun(k, pushDir, 220, 5.5);
      k.shooCount = (k.shooCount || 0) + 2;
      bumpTrust(k.tamagotchiId!, -2);
      petCount.set(k.tamagotchiId!, 0);
      showPopup(k.el, '😾');
      emitTamaSound('pet-reject', { catId: k.tamagotchiId });
      emitHint({ key: 'wake-sleeping-cat', catId: k.tamagotchiId, catName: k.tamagotchiName, placement: 'cat' });
    } else if (isReceptive && !sassyRejects && !overPetted && !escalatingShoo) {
      // Belly trap! Playful cat at high trust shows belly then attacks
      if (k.personality === 'playful' && tamagotchi.getTrust() > 60 && k.behavior === 'sit' && Math.random() < 0.25) {
        showPopup(k.el, '🫴'); // shows belly
        setTimeout(() => {
          if (k.tamagotchiId && k.behavior === 'sit') {
            enterBehavior(k, 'pounce');
            k.vx += pushDir * -10; // attack the hand!
            k.vy -= 3;
            showPopup(k.el, '🐾');
            emitTamaSound('pounce');
          }
        }, 600);
        return; // skip normal pet logic
      }

      // Successful pet — cat stays and enjoys it!
      k.shooCount = Math.max(0, (k.shooCount || 0) - 1);
      bumpTrust(k.tamagotchiId!, 1);
      petCount.set(k.tamagotchiId!, petsReceived + 1);
      if (k.behavior !== 'sit') {
        if (k.behavior !== 'walk') exitBehavior(k);
        enterBehavior(k, 'sit');
      }
      // Extend sit duration so cat stays content
      k.bTimer = Math.max(k.bTimer, 300);
      k.el.dataset.tail = 'content';
      // Close eyes (squint) — override blink animation
      k.el.classList.add('kitten--purring');
      setTimeout(() => k.el.classList.remove('kitten--purring'), 2000);
      // Making biscuits after 3+ pets — interrupt with knead behavior
      if (petsReceived >= 3) {
        k.el.classList.remove('kitten--purring'); // knead has its own eye squint
        k.behaviorQueue = [{ behavior: 'sit', duration: Math.floor(rand(180, 360)) }];
        enterBehavior(k, 'knead');
        k.bTimer = Math.floor(rand(240, 480)); // knead for a good while
        if (petsReceived === 3) {
          showPopup(k.el, '🫶');
          document.dispatchEvent(new CustomEvent('tama-hint', {
            detail: { key: 'kneading', catId: k.tamagotchiId, catName: k.tamagotchiName }
          }));
        } else {
          showPopup(k.el, '💕');
        }
      } else {
        showPopup(k.el, '💕');
      }
      emitTamaSound(petsReceived >= 3 ? 'pet-long' : 'pet', { catId: k.tamagotchiId });

      const onScreen = cats.filter(c => c.tamagotchiId).map(c => c.tamagotchiId!);
      tamagotchi.sendCare(k.tamagotchiId, 'pet', onScreen);
    } else if (overPetted) {
      // Over-petted — cat is done, walks away annoyed
      petCount.set(k.tamagotchiId!, 0);
      bumpTrust(k.tamagotchiId!, -1);
      startScaredRun(k, pushDir, 200, 4.8);
      k.shooCount = (k.shooCount || 0) + 1;
      showPopup(k.el, '😾');
      emitHint({ key: 'annoyed-cat', catId: k.tamagotchiId, catName: k.tamagotchiName, placement: 'cat' });
    } else if (k.personality === 'chaotic' && Math.random() < 0.5) {
      // Chaotic cat: 50/50 purr or hiss, you never know
      if (Math.random() < 0.5) {
        // Surprise purr!
        k.shooCount = 0;
        enterBehavior(k, 'sit');
        k.el.classList.add('kitten--purring');
        setTimeout(() => k.el.classList.remove('kitten--purring'), 1500);
        showPopup(k.el, '💕');
        tamagotchi.sendCare(k.tamagotchiId!, 'pet', cats.filter(c => c.tamagotchiId).map(c => c.tamagotchiId!));
      } else {
        // Surprise hiss!
        k.vx += pushDir * 8;
        k.vy -= 3;
        k.shooCount = (k.shooCount || 0) + 1;
        showPopup(k.el, '🙀');
      }
    } else if (sassyRejects) {
      // Sassy cat rejects petting — turn back and walk away with attitude
      bumpTrust(k.tamagotchiId!, -1);
      k.shooCount = (k.shooCount || 0) + 1;
      showPopup(k.el, '😤');
      emitTamaSound('pet-reject', { catId: k.tamagotchiId });
      document.dispatchEvent(new CustomEvent('tama-hint', { detail: { key: 'sassy-reject', catId: k.tamagotchiId, catName: k.tamagotchiName } }));
      // Deliberately face AWAY from cursor
      k.el.dataset.facingRight = pushDir > 0 ? '1' : '';
      if (k.behavior !== 'walk') exitBehavior(k);
      // Walk away slowly with attitude (not scared run)
      k.baseVx = pushDir * rand(1.5, 2.5);
      k.savedVx = k.baseVx;
      k.el.dataset.tail = 'sassy';
    } else {
      // Too busy (zoomies/stalk/pounce/playbow) — push them
      bumpTrust(k.tamagotchiId!, -1);
      startScaredRun(k, pushDir, 170, 4.6);
      k.shooCount = (k.shooCount || 0) + 1;
      showPopup(k.el, '💨');
      emitHint({ key: 'annoyed-cat', catId: k.tamagotchiId, catName: k.tamagotchiName, placement: 'cat' });
    }

    // Shoo detection: enough consecutive pushes = cat gets shooed
    if ((k.shooCount || 0) >= SHOO_THRESHOLD) {
      k.shooed = true;
      k.el.classList.add('kitten--shooed');
      bumpTrust(k.tamagotchiId!, -3);
      if (k.behavior !== 'walk') exitBehavior(k);
      k.baseVx = pushDir * 6;
      k.savedVx = k.baseVx;
      k.vx = pushDir * 5;
      showPopup(k.el, '👋');
      emitTamaSound('shoo', { catId: k.tamagotchiId });
      petCount.delete(k.tamagotchiId!);
      saveTamagotchiSession();
    } else if ((k.shooCount || 0) >= SHOO_THRESHOLD - 1) {
      showPopup(k.el, '😿');
      emitHint({ key: 'shoo-warning', catId: k.tamagotchiId, catName: k.tamagotchiName, placement: 'cat' });
    }
  }

  // Care reaction: trigger behavior change on a tamagotchi cat (from remote care)
  const CARE_BEHAVIORS: Record<string, Behavior> = {
    feed: 'sit',       // happy sit after eating
    pet: 'sit',        // content sit while being petted
    play: 'zoomies',   // excited zoomies after play
    groom: 'groom',    // grooming behavior
  };

  document.addEventListener('tamagotchi-care-react', ((e: CustomEvent) => {
    const { catId, action, variant, sourceType } = e.detail;
    const cat = cats.find(k => k.tamagotchiId === catId);
    if (!cat) return;

    if (sourceType === 'visitor') {
      if (action === 'pet') bumpTrust(catId, 1);
      else if (action === 'feed' || action === 'play' || action === 'groom') bumpTrust(catId, 2);
    }

    let behavior = CARE_BEHAVIORS[action];
    if (action === 'play' && variant === 'feather') behavior = 'pounce';
    if (action === 'feed' && variant === 'treat') behavior = 'playbow';
    if (action === 'pet' && cat.behavior === 'knead') behavior = undefined;
    if (behavior) {
      if (cat.behavior !== 'walk') exitBehavior(cat);
      enterBehavior(cat, behavior);
      cat.vy -= 4;
    }
  }) as EventListener);

  /* ═══ Item drops (food, yarn, brush) ═════════════════ */

  interface FoodItem {
    el: HTMLElement;
    x: number; y: number;
    vx: number; vy: number;
    variant: CareVariant;
    targetCatId?: string;
    bitesRemaining: number;
    cooldown: number;
    eaten: boolean;
    gone: boolean; // removed from DOM
    rejectedHinted?: boolean;
  }
  const foodItems: FoodItem[] = [];

  document.addEventListener('tama-drop-item', ((e: CustomEvent) => {
    const { item, variant, x: px, y: py, vx, vy, targetCatId } = e.detail as {
      item: ItemKind;
      variant?: CareVariant;
      x: number;
      y: number;
      vx?: number;
      vy?: number;
      targetCatId?: string;
    };
    // Convert page coordinates to main-relative
    const rect = mainEl.getBoundingClientRect();
    const x = px - rect.left;
    const y = py - rect.top + mainEl.scrollTop;
    if (item === 'food') dropFood(x, y, vx || 0, vy || 0, variant || 'fish', targetCatId);
    else if (item === 'yarn') dropYarn(x, y, vx || 0, vy || 0, variant || 'yarn', targetCatId);
    else if (item === 'brush') dropBrush(x, y, targetCatId);
  }) as EventListener);

  function dropFood(x: number, y: number, dragVx: number, dragVy: number, variant: CareVariant = 'fish', targetCatId?: string) {
    // Pellets scatter into 3-4 separate food items
    if (variant === 'pellets') {
      const count = Math.floor(rand(3, 5));
      for (let i = 0; i < count; i++) {
        const px = x + rand(-25, 25);
        const py = y + rand(-15, 15);
        const pvx = dragVx * 0.72 + rand(-3.2, 3.2);
        const pvy = dragVy * 0.72 + rand(-2.2, 2.2);
        dropSingleFood(px, py, pvx, pvy, 'pellets', targetCatId);
      }
      return;
    }
    dropSingleFood(x, y, dragVx, dragVy, variant, targetCatId);
  }

  function dropSingleFood(x: number, y: number, dragVx: number, dragVy: number, variant: CareVariant = 'fish', targetCatId?: string) {
    const el = document.createElement('div');
    el.className = 'tama-food-item';
    if (variant === 'pellets') {
      el.classList.add('tama-food-item--pellets');
      el.innerHTML = `<span class="tama-pellet tama-pellet--a"></span>`; // single pellet
    } else {
      el.textContent = variant === 'treat' ? '🍤' : '🐟';
    }
    el.style.left = `${x}px`;
    el.style.top = `${y}px`;
    stage.appendChild(el);

    const throwFactor = variant === 'pellets' ? 1.12 : variant === 'treat' ? 0.98 : 0.72;
    const maxThrowSpeed = variant === 'pellets' ? 24 : variant === 'treat' ? 20 : 14;
    const fvx = Math.max(-maxThrowSpeed, Math.min(maxThrowSpeed, dragVx * throwFactor));
    const fvy = Math.max(-maxThrowSpeed, Math.min(maxThrowSpeed, dragVy * throwFactor));
    const bitesRemaining = 1; // each food item = 1 bite (pellets scatter into multiple)
    const food: FoodItem = { el, x, y, vx: fvx, vy: fvy, variant, targetCatId, bitesRemaining, cooldown: 0, eaten: false, gone: false };
    foodItems.push(food);

    // After 15 seconds, food disappears if uneaten
    setTimeout(() => {
      if (!food.eaten) {
        food.gone = true;
        food.el.remove();
        const idx = foodItems.indexOf(food);
        if (idx >= 0) foodItems.splice(idx, 1);
      }
    }, 15000);

    // 40% chance to lure in an ambient cat to eat it
    if (Math.random() < 0.4) {
      setTimeout(() => {
        if (food.gone) return;
        const goRight = x > mainW() / 2 ? false : true;
        const lured = makeKitten({
          goRight, yPos: food.y + rand(-20, 20),
          speed: [1, 2], force: true,
        });
        if (lured) {
          lured.mission = 'chase-food';
          lured.missionTarget = { x: () => food.x, y: () => food.y, alive: () => !food.gone };
          enterBehavior(lured, 'stalk');
        }
      }, rand(2000, 5000));
    }
  }

  function dropYarn(x: number, y: number, dragVx: number, dragVy: number, variant: CareVariant = 'yarn', targetCatId?: string) {
    // Direction and speed from drag gesture
    const hasDrag = Math.abs(dragVx) > 0.5 || Math.abs(dragVy) > 0.5;
    const fallbackRight = Math.random() > 0.5;
    const vx = hasDrag ? Math.max(-7.4, Math.min(7.4, dragVx * 0.4)) : (fallbackRight ? rand(1.8, 3.5) : -rand(1.8, 3.5));
    const vy = hasDrag ? Math.max(-6.2, Math.min(6.2, dragVy * 0.4)) : 0;
    const launchVx = Math.abs(vx) < 0.2 && Math.abs(vy) > 0.6 ? 0 : vx;
    const goRight = launchVx >= 0;
    const yEl = (yarnTpl.content.cloneNode(true) as DocumentFragment).querySelector('.yarn') as HTMLElement;
    yEl.dataset.variant = variant;
    if (variant === 'feather') {
      yEl.innerHTML = '<div class="tama-feather">🪶</div>';
    }
    yEl.style.setProperty('--yarn-color', pick(YARN_COLORS));
    yEl.dataset.dir = goRight ? 'right' : 'left';
    const launchSpeed = Math.hypot(launchVx, vy) || 1;
    const driftDirX = launchVx / launchSpeed;
    const driftDirY = vy / launchSpeed;
    const cruiseSpeed = Math.max(1.15, launchSpeed);
    yarns.push({
      el: yEl,
      x,
      y,
      vx: launchVx,
      vy,
      cruiseSpeed,
      boostSpeed: cruiseSpeed,
      driftDirX,
      driftDirY,
      variant,
      targetCatId,
      cooldown: 0,
    });
    stage.appendChild(yEl);

    // Tamagotchi cats with enough energy chase the yarn
    const targetCat = findCatById(targetCatId);
    const targetCatWillChase = targetCat ? shouldChaseToy(targetCat, variant) : false;
    if (targetCat && targetCat.tamagotchiId && !targetCatWillChase) {
      const preferredToy = getPreferredToyVariant(targetCat);
      const tooLazyToPlay = targetCat.personality === 'lazy';
      const dislikesThisToy = preferredToy !== variant &&
        (targetCat.personality === 'sassy' || targetCat.personality === 'shy');
      if (tooLazyToPlay || dislikesThisToy) {
        showPopup(targetCat.el, targetCat.personality === 'sassy' ? '😼' : '😒');
        emitHint({
          key: 'ignore-play',
          catId: targetCat.tamagotchiId,
          catName: targetCat.tamagotchiName,
          preferredVariantLabel: tooLazyToPlay ? '' : getVariantLabel(preferredToy),
          placement: 'cat',
        });
      }
    }
    for (const k of cats) {
      if (!k.tamagotchiId) continue;
      if (targetCat && k !== targetCat) continue;
      const shouldChase = targetCat && k === targetCat ? targetCatWillChase : shouldChaseToy(k, variant);
      if (shouldChase) {
        startToyPlay(k, variant);
        if (k.behavior !== 'walk') exitBehavior(k);
        // Point toward the yarn at a gentle chase speed (don't stack with zoomies multiplier)
        const chaseSpeed = Math.min(3, Math.abs(k.savedVx || k.baseVx) * 1.2);
        k.baseVx = launchVx >= 0 ? chaseSpeed : -chaseSpeed;
        k.savedVx = k.baseVx;
        enterBehavior(k, variant === 'feather' ? 'pounce' : 'stalk');
        showPopup(k.el, variant === 'feather' ? '🪶' : '❗');

        // Send play action
        const onScreen = cats.filter(c => c.tamagotchiId).map(c => c.tamagotchiId!);
        tamagotchi.sendCare(k.tamagotchiId, 'play', onScreen, variant);
      }
    }

    // 30% chance to lure in an ambient cat to chase the yarn
    const yarnRef = yarns[yarns.length - 1];
    if (Math.random() < 0.3 && yarnRef) {
      setTimeout(() => {
        if (!yarns.includes(yarnRef)) return;
        const yarnSpeed = Math.max(1.5, Math.abs(yarnRef.vx));
        const lured = makeKitten({
          goRight: yarnRef.vx >= 0, yPos: y + rand(-30, 30),
          speed: [yarnSpeed * 0.9, yarnSpeed * 1.05],
          personality: 'playful', force: true,
        });
        if (lured) {
          lured.mission = 'chase-toy';
          lured.missionTarget = { x: () => yarnRef.x, y: () => yarnRef.y, alive: () => yarns.includes(yarnRef) };
          lured.missionRoundsLeft = Math.floor(rand(1, 3));
          lured.toyPlayVariant = variant;
          startToyPlay(lured, variant);
        }
      }, rand(500, 2000));
    }
  }

  function dropBrush(x: number, y: number, targetCatId?: string) {
    // Find closest tamagotchi cat within range (any cleanliness — some cats like being brushed)
    let closest: KState | null = null;
    let closestDist = 150;

    for (const k of cats) {
      if (!k.tamagotchiId) continue;
      if (targetCatId && k.tamagotchiId !== targetCatId) continue;
      const dist = Math.hypot(k.x - x, k.y - y);
      if (dist < closestDist) {
        closest = k;
        closestDist = dist;
      }
    }

    if (!closest || !closest.tamagotchiId) {
      // No cat nearby
      const poof = document.createElement('div');
      poof.className = 'tama-care-popup';
      poof.textContent = '🪮';
      poof.style.position = 'absolute';
      poof.style.left = `${x}px`;
      poof.style.top = `${y}px`;
      stage.appendChild(poof);
      poof.addEventListener('animationend', () => poof.remove());
      return;
    }

    const p = closest.personality;
    const catData = tamagotchi.getState()?.cats.find(c => c.id === closest!.tamagotchiId);
    const onScreen = cats.filter(c => c.tamagotchiId).map(c => c.tamagotchiId!);
    closest.behaviorQueue = []; // interrupt any chain

    // Sleeping cats ignore
    if (closest.behavior === 'nap') {
      showPopup(closest.el, '💤');
      emitHint({ key: 'wake-sleeping-cat', catId: closest.tamagotchiId, catName: closest.tamagotchiName, placement: 'cat' });
      return;
    }

    // Sassy cats: 50% chance to reject
    if (p === 'sassy' && Math.random() < 0.5) {
      closest.vx += Math.sign(closest.x - x || 1) * 15;
      closest.vy -= 3;
      if (closest.behavior !== 'walk') exitBehavior(closest);
      showPopup(closest.el, '😤');
      emitHint({ key: 'sassy-reject', catId: closest.tamagotchiId, catName: closest.tamagotchiName, placement: 'cat' });
      return;
    }

    // Playful cats: 30% chance to attack the brush (still counts as groom)
    if (p === 'playful' && Math.random() < 0.3) {
      if (closest.behavior !== 'walk') exitBehavior(closest);
      enterBehavior(closest, 'pounce');
      closest.vx += Math.sign(x - closest.x) * 10;
      showPopup(closest.el, '🐾');
      tamagotchi.sendCare(closest.tamagotchiId, 'groom', onScreen, 'brush');
      return;
    }

    // Lazy and curious cats LOVE being brushed — it's like petting for them
    const lovesBrush = p === 'lazy' || p === 'curious';

    if (p === 'curious') {
      // Inspect first, then enjoy
      if (closest.behavior !== 'walk') exitBehavior(closest);
      enterBehavior(closest, 'stalk');
      showPopup(closest.el, '👀');
      const cat = closest; // capture for timeout
      setTimeout(() => {
        if (cat.tamagotchiId) {
          if (cat.behavior !== 'walk') exitBehavior(cat);
          enterBehavior(cat, 'groom');
          cat.bTimer = Math.max(cat.bTimer, 400);
          showPopup(cat.el, lovesBrush ? '💕' : '✨');
          emitTamaSound('groom', { catId: cat.tamagotchiId });
          cat.el.classList.add('kitten--purring');
          setTimeout(() => cat.el.classList.remove('kitten--purring'), 2000);
        }
      }, 800);
    } else {
      // Lazy cats settle right in, others just groom
      if (closest.behavior !== 'walk') exitBehavior(closest);
      enterBehavior(closest, 'groom');
      closest.bTimer = Math.max(closest.bTimer, 400);
      if (lovesBrush) {
        showPopup(closest.el, '💕');
        emitTamaSound('groom', { catId: closest.tamagotchiId });
        closest.el.classList.add('kitten--purring');
        setTimeout(() => closest!.el.classList.remove('kitten--purring'), 2000);
      } else {
        showPopup(closest.el, '✨');
        emitTamaSound('groom', { catId: closest.tamagotchiId });
      }
    }

    // Send groom action — and also pet if the cat loves it
    tamagotchi.sendCare(closest.tamagotchiId, 'groom', onScreen, 'brush');
    if (lovesBrush) {
      tamagotchi.sendCare(closest.tamagotchiId, 'pet', onScreen);
    }
  }

  /* ═══ Food attraction (in tick loop) ═════════════════ */

  function tickFoodAttraction() {
    for (const food of foodItems) {
      if (food.eaten) continue;
      if (food.cooldown > 0) food.cooldown--;

      // Food inertia — slides and decelerates
      if (Math.abs(food.vx) > 0.05 || Math.abs(food.vy) > 0.05) {
        food.x += food.vx;
        food.y += food.vy;
        const drag = food.variant === 'pellets' ? 0.72 : food.variant === 'treat' ? 0.84 : 0.95;
        food.vx *= drag;
        food.vy *= drag;
        food.el.style.left = `${food.x}px`;
        food.el.style.top = `${food.y}px`;
      }

      // Find hungriest nearby tamagotchi cat
      let hungriest: KState | null = null;
      let lowestHunger = 70;

      if (food.targetCatId && !food.rejectedHinted) {
        const targetCat = findCatById(food.targetCatId);
        const targetData = getTamagotchiData(food.targetCatId);
        if (targetCat && targetData) {
          const baseThreshold = getFoodThreshold(targetCat, 'fish');
          const variantThreshold = getFoodThreshold(targetCat, food.variant);
          const hungryEnoughForFood = targetData.hunger < baseThreshold;
          const rejectsThisVariant = hungryEnoughForFood && targetData.hunger >= variantThreshold;
          if (rejectsThisVariant) {
            food.rejectedHinted = true;
            const preferredFood = getPreferredFoodVariant(targetCat);
            showPopup(targetCat.el, targetCat.personality === 'sassy' ? '😒' : '🙅');
            emitHint({
              key: 'ignore-food',
              catId: targetCat.tamagotchiId,
              catName: targetCat.tamagotchiName,
              preferredVariantLabel: getVariantLabel(preferredFood),
              placement: 'cat',
            });
          }
        }
      }

      // ONE unified loop: find any cat that wants this food
      // Tamagotchi cats: hunger-based threshold + personality preference
      // Ambient cats with chase-food mission: always want it (that's their job)
      // All other cats: might swat or stare if nearby
      for (const k of cats) {
        const isMissionCat = k.mission === 'chase-food' || k.mission === 'thief';
        const isTama = !!k.tamagotchiId;

        // Skip cats that shouldn't care about this food
        if (!isTama && !isMissionCat) continue;
        if (food.targetCatId && k.tamagotchiId && k.tamagotchiId !== food.targetCatId) continue;

        const dist = Math.hypot(k.x - food.x, k.y - food.y);
        if (dist >= 400) continue;

        if (isMissionCat) {
          // Mission cats ALWAYS want the food — that's why they're here
          hungriest = k;
          lowestHunger = 0;
          break; // mission cats get priority
        }

        // Tamagotchi cats: check hunger threshold
        const catData = tamagotchi.getState()?.cats.find(c => c.id === k.tamagotchiId);
        if (!catData) continue;

        if (k.behavior === 'nap') {
          if (!shouldWakeForFood(k, catData, food.variant)) continue;
          exitBehavior(k);
          enterBehavior(k, 'stalk');
          k.bTimer = Math.max(k.bTimer, 120);
          showPopup(k.el, '👀');
        }

        const hungerThreshold = getFoodThreshold(k, food.variant);
        if (catData.hunger < hungerThreshold && catData.hunger < lowestHunger) {
          hungriest = k;
          lowestHunger = catData.hunger;
        } else if (dist < 80 && dist > 20 && Math.random() < 0.003) {
          // Not hungry enough to eat but nearby — personality reaction
          if (k.personality === 'playful') {
            food.vx += (Math.random() > 0.5 ? 3 : -3);
            food.vy += rand(-2, 2);
            showPopup(k.el, '🐾');
            enterBehavior(k, 'pounce');
            k.bTimer = 60;
          } else if (k.behavior === 'walk') {
            enterBehavior(k, 'sit');
            k.bTimer = Math.floor(rand(120, 300));
            k.el.dataset.facingRight = (food.x - k.x) > 0 ? '1' : '';
            showPopup(k.el, '😒');
          }
        }
      }

      // ALL interested cats path toward the food (not just the hungriest)
      for (const k of cats) {
        const isMissionCat = k.mission === 'chase-food' || k.mission === 'thief';
        const isTama = !!k.tamagotchiId;
        if (!isTama && !isMissionCat) continue;

        // Check if this cat wants the food
        let wantsFood = isMissionCat;
        if (isTama && !wantsFood) {
          const catData = tamagotchi.getState()?.cats.find(c => c.id === k.tamagotchiId);
          if (catData) {
            if (k.behavior === 'nap' && shouldWakeForFood(k, catData, food.variant)) {
              exitBehavior(k);
              enterBehavior(k, 'stalk');
              k.bTimer = Math.max(k.bTimer, 120);
            }
            const threshold = getFoodThreshold(k, food.variant);
            wantsFood = catData.hunger < threshold;
          }
        }
        if (!wantsFood) continue;

        const fdx = food.x - k.x;
        const fdy = food.y - k.y;
        const fdist = Math.hypot(fdx, fdy);
        if (fdist > 400 || fdist < 1) continue;

        // Attract toward food (everyone who wants it)
        if (fdist > 30 && (k.behavior === 'walk' || k.behavior === 'stalk')) {
          k.vx += (fdx / fdist) * 0.8;
          k.vy += (fdy / fdist) * 0.4;
        }
      }

      // First cat to arrive eats
      if (hungriest) {
        const dx = food.x - hungriest.x;
        const dy = food.y - hungriest.y;
        const dist = Math.hypot(dx, dy);

        const eatRadius = food.variant === 'pellets' ? 42 : 30;
        if (dist < eatRadius && food.cooldown <= 0) {
          // Eating chain: stalk (sniff) → sit (chew) → sit (lick lips)
          hungriest.behaviorQueue = [
            { behavior: 'sit', duration: Math.floor(rand(60, 120)), popup: food.variant === 'pellets' ? '•' : '😋' },
            { behavior: 'sit', duration: Math.floor(rand(40, 80)) }, // lick lips
          ];
          if (hungriest.behavior !== 'walk') exitBehavior(hungriest);
          enterBehavior(hungriest, 'stalk'); // sniff the food
          hungriest.bTimer = Math.floor(rand(30, 60));
          hungriest.el.dataset.facingRight = dx > 0 ? '1' : '';
          const feedSound =
            food.variant === 'fish'
              ? 'feed-fish'
              : food.variant === 'pellets'
                ? 'feed-crunch'
                : food.variant === 'treat'
                  ? 'feed-treat'
                : 'feed-fish';
          emitTamaSound(feedSound, { catId: hungriest.tamagotchiId, variant: food.variant });
          hungriest.missionTarget = undefined;
          // Ambient cat done eating — time to leave
          if (hungriest.mission === 'chase-food') {
            hungriest.mission = 'leave';
            hungriest.behaviorQueue = [
              { behavior: 'sit', duration: Math.floor(rand(60, 180)) }, // sit and lick lips
            ];
            setTimeout(() => {
              if (hungriest.mission === 'leave') {
                hungriest.baseVx = hungriest.x < mainW() / 2 ? -rand(2, 4) : rand(2, 4);
                hungriest.savedVx = hungriest.baseVx;
              }
            }, 2000);
          }

          // Send feed action (tamagotchi cats only)
          if (hungriest.tamagotchiId) {
            const onScreen = cats.filter(c => c.tamagotchiId).map(c => c.tamagotchiId!);
            tamagotchi.sendCare(hungriest.tamagotchiId, 'feed', onScreen, food.variant);
          }

          food.bitesRemaining -= 1;
          if (food.variant === 'pellets') {
            const pellets = Array.from(food.el.querySelectorAll('.tama-pellet'));
            const pellet = pellets[food.bitesRemaining];
            pellet?.remove();
            food.vx += rand(-0.6, 0.6);
            food.vy += rand(-0.3, 0.3);
          }
          food.cooldown = food.variant === 'pellets' ? 20 : 10;

          if (food.bitesRemaining <= 0) {
            food.eaten = true;
            food.gone = true;
            food.el.classList.add('eaten');
            setTimeout(() => {
              food.el.remove();
              const idx = foodItems.indexOf(food);
              if (idx >= 0) foodItems.splice(idx, 1);
            }, 300);
          }
        } else if (hungriest.tamagotchiId) {
          // Tamagotchi cats: attract toward food
          const foodPull = food.variant === 'pellets' ? 1.05 : 0.8;
          hungriest.vx += (dx / dist) * foodPull;
          hungriest.vy += (dy / dist) * 0.3;
        } else {
          // Mission pursuit handles attraction, just face the food
          hungriest.vx += (dx / dist) * 0.95;
          hungriest.vy += (dy / dist) * 0.95;
        }
      }
    }
  }

  /* ═══ Stats → behavior weights ═══════════════════════ */

  function pickActivityBehavior(k: KState): Behavior {
    // Feed the queue for ALL cats (tamagotchi and ambient)
    if (!k.behaviorQueue || k.behaviorQueue.length === 0) {
      if (k.tamagotchiId) {
        feedActivityQueue(k);
      } else {
        feedAmbientQueue(k);
      }
    }

    // Peek at next step (the tick loop will shift it after enterBehavior)
    if (k.behaviorQueue && k.behaviorQueue.length > 0) {
      return k.behaviorQueue[0].behavior;
    }

    // Fallback
    return pickBehavior(k.personality);
  }

  // Ambient cats get short personality-driven chains based on their mission
  function feedAmbientQueue(k: KState) {
    const R = (lo: number, hi: number) => Math.floor(rand(lo, hi));
    const p = k.personality;
    const q: ChainStep[] = [];

    switch (k.mission) {
      case 'cross':
        // Crossing the page — personality determines if they stop to do anything
        if (p === 'curious' && Math.random() < 0.4) {
          q.push({ behavior: 'stalk', duration: R(60, 120) }); // investigate something
          q.push({ behavior: 'sit', duration: R(40, 90) });     // look around
        } else if (p === 'lazy' && Math.random() < 0.3) {
          q.push({ behavior: 'sit', duration: R(90, 180) });    // stop for a rest
        } else if (p === 'sassy' && Math.random() < 0.25) {
          q.push({ behavior: 'sit', duration: R(60, 120) });    // stop and judge
          q.push({ behavior: 'groom', duration: R(60, 120) });  // groom with attitude
        } else if (p === 'playful' && Math.random() < 0.3) {
          q.push({ behavior: 'playbow', duration: R(40, 70) }); // playful moment
          q.push({ behavior: 'pounce', duration: R(30, 50) });  // pounce at nothing
        }
        // else: just keep walking (empty queue = pickBehavior fallback)
        break;

      case 'chase-food':
      case 'thief':
        // On food mission — stalk toward food, sit briefly on arrival
        q.push({ behavior: 'stalk', duration: R(60, 120) });
        break;

      case 'chase-toy':
        // Chasing toy — handled by toyPlay system, just stalk
        q.push({ behavior: 'stalk', duration: R(60, 120) });
        break;

      case 'leave':
        // Leaving — just walk, no stopping
        break;

      case 'outsider':
        // Outsider event cat — look around nervously
        q.push({ behavior: 'stalk', duration: R(60, 120) });
        q.push({ behavior: 'sit', duration: R(40, 90) });
        break;

      case 'bulldozer':
        // Bulldozer kitten — playful burst mid-crossing
        if (Math.random() < 0.5) {
          q.push({ behavior: 'zoomies', duration: R(40, 80) });
        }
        break;

      case 'observe':
        q.push({ behavior: 'stalk', duration: R(60, 120) });
        q.push({ behavior: 'sit', duration: R(180, 360) });
        if (p === 'curious' || p === 'shy') {
          q.push({ behavior: 'groom', duration: R(60, 120) });
        }
        break;
    }

    k.behaviorQueue = q;
  }

  type ChainStep = { behavior: Behavior; duration?: number; popup?: string };

  /* ═══ Page anchors: real DOM targets for cat navigation ═══ */

  interface PageAnchor {
    x: number; y: number;  // main-relative center position
    w: number; h: number;
    label: string;         // for debugging
  }

  function getPageAnchors(): PageAnchor[] {
    const anchors: PageAnchor[] = [];
    const content = mainEl.querySelector('.page-content');
    if (!content) return anchors;

    // Find interesting sections: hero, card grids, headings, etc.
    const selectors = [
      'section', '.hero', '.card', '.cat-card', '.kitten-card',
      '.container > h2', '.container > h1',
      'footer',
    ];

    for (const sel of selectors) {
      content.querySelectorAll(sel).forEach((el) => {
        const rect = (el as HTMLElement).getBoundingClientRect();
        const mainRect = mainEl.getBoundingClientRect();
        if (rect.width < 20 || rect.height < 20) return;
        anchors.push({
          x: rect.left - mainRect.left + rect.width / 2,
          y: rect.top - mainRect.top + mainEl.scrollTop + rect.height * 0.8, // bottom area of section
          w: rect.width,
          h: rect.height,
          label: (el as HTMLElement).tagName.toLowerCase(),
        });
      });
    }

    return anchors;
  }

  // Get a random anchor near the viewport (or any if none visible)
  function getVisibleAnchor(): PageAnchor | null {
    const anchors = getPageAnchors();
    if (anchors.length === 0) return null;

    const viewTop = mainScrollY();
    const viewBot = viewTop + mainViewH();
    const visible = anchors.filter(a => a.y > viewTop - 200 && a.y < viewBot + 200);
    return visible.length > 0 ? pick(visible) : pick(anchors);
  }

  // Navigate a cat toward a page anchor
  function steerToward(k: KState, targetX: number, targetY: number, strength = 0.04) {
    const dx = targetX - k.x;
    const dy = targetY - k.y;
    if (Math.abs(dx) > 10) {
      k.baseVx += Math.sign(dx) * strength * Math.min(30, Math.abs(dx));
      k.baseVx = Math.max(-3, Math.min(3, k.baseVx));
      k.savedVx = k.baseVx;
    }
    if (Math.abs(dy) > 10) {
      k.baseVy += Math.sign(dy) * strength * Math.min(20, Math.abs(dy)) * 0.5;
      k.baseVy = Math.max(-1.5, Math.min(1.5, k.baseVy));
    }
  }

  // The core: activity + personality + mood → randomized chain of intentional actions
  function feedActivityQueue(k: KState) {
    const R = (lo: number, hi: number) => Math.floor(rand(lo, hi));
    const p = k.personality;
    const catData = tamagotchi.getState()?.cats.find(c => c.id === k.tamagotchiId);
    const energy = catData?.energy ?? 75;
    const happiness = catData?.happiness ?? 75;
    const q: ChainStep[] = [];

    switch (k.activity) {
      case 'explore': {
        // Target a real page section to investigate
        const anchor = getVisibleAnchor();
        if (anchor) {
          steerToward(k, anchor.x + rand(-50, 50), anchor.y);
        } else {
          k.baseVx = (Math.random() > 0.5 ? 1 : -1) * rand(1.5, 3);
          k.savedVx = k.baseVx;
          k.baseVy = rand(-0.8, 0.8);
        }

        // Walk to section → investigate → look around → personality extras
        q.push({ behavior: 'stalk', duration: R(300, 600) });
        q.push({ behavior: 'sit', duration: R(300, 600) });

        if (p === 'curious') {
          q.push({ behavior: 'stalk', duration: R(180, 360) });
          q.push({ behavior: 'sit', duration: R(300, 600), popup: '🔍' });
          if (Math.random() < 0.3) q.push({ behavior: 'groom', duration: R(300, 600) });
        } else if (p === 'chaotic') {
          q.push(pick([
            { behavior: 'pounce' as Behavior, duration: R(40, 70), popup: '❓' },
            { behavior: 'zoomies' as Behavior, duration: R(60, 100) },
            { behavior: 'playbow' as Behavior, duration: R(40, 80) },
          ]));
        } else if (p === 'shy') {
          q.push({ behavior: 'sit', duration: R(120, 240) });
        }
        break;
      }

      case 'lounge': {
        // Settle in — chain varies by personality
        // Kneading happens when: high trust, settling in, feeling safe
        const trust = tamagotchi.getTrust();
        const shouldKnead = trust > 40 && happiness > 50 && Math.random() < 0.35;

        if (p === 'lazy') {
          // Lazy: sit → maybe knead → nap long
          q.push({ behavior: 'sit', duration: R(60, 120) });
          if (shouldKnead) q.push({ behavior: 'knead', duration: R(360, 720), popup: '🫶' });
          q.push({ behavior: 'nap', duration: R(900, 2400), popup: '💤' });
        } else if (p === 'sassy') {
          // Sassy: groom → sit → maybe nap
          q.push({ behavior: 'groom', duration: R(300, 600) });
          q.push({ behavior: 'sit', duration: R(180, 360) });
          if (energy < 60) q.push({ behavior: 'nap', duration: R(600, 1200), popup: '💤' });
        } else {
          // Default: sit → groom → maybe knead → nap
          q.push({ behavior: 'sit', duration: R(120, 300) });
          q.push({ behavior: 'groom', duration: R(180, 420) });
          if (shouldKnead) q.push({ behavior: 'knead', duration: R(360, 720), popup: '🫶' });
          q.push({ behavior: 'nap', duration: R(600, 1800), popup: '💤' });
        }
        break;
      }

      case 'alert': {
        // Watch something — long settled stare
        const watchPose: Behavior = Math.random() < 0.5 ? 'loaf' : 'sit';
        q.push({ behavior: watchPose, duration: R(600, 1200) }); // 10-20s stare
        if (p === 'curious') {
          q.push({ behavior: 'stalk', duration: R(180, 360) });
          q.push({ behavior: 'loaf', duration: R(600, 1200) });
        } else if (p === 'sassy' || p === 'lazy') {
          q.push({ behavior: 'loaf', duration: R(900, 1800) }); // 15-30s loaf
        } else {
          q.push({ behavior: 'stalk', duration: R(120, 240) });
          q.push({ behavior: watchPose, duration: R(600, 900) });
        }
        break;
      }

      case 'play': {
        // Solo hunt — personality affects style
        if (p === 'playful') {
          // Full hunt sequence: stalk → wiggle → POUNCE → zoomies → catch breath
          q.push({ behavior: 'stalk', duration: R(300, 600) });
          q.push({ behavior: 'playbow', duration: R(40, 80) });
          q.push({ behavior: 'pounce', duration: R(40, 70), popup: '🐾' });
          q.push({ behavior: 'zoomies', duration: R(60, 120) });
          q.push({ behavior: 'sit', duration: R(60, 120) });
        } else if (p === 'chaotic') {
          // Unpredictable sequence
          const moves: ChainStep[] = [
            { behavior: 'pounce', duration: R(30, 60), popup: '❓' },
            { behavior: 'zoomies', duration: R(60, 120) },
            { behavior: 'playbow', duration: R(40, 80) },
            { behavior: 'stalk', duration: R(60, 120) },
          ];
          // Shuffle and pick 2-4
          for (let i = moves.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [moves[i], moves[j]] = [moves[j], moves[i]];
          }
          q.push(...moves.slice(0, Math.floor(rand(2, 4))));
        } else {
          // Standard: stalk → playbow → pounce
          q.push({ behavior: 'stalk', duration: R(120, 240) });
          q.push({ behavior: 'playbow', duration: R(60, 120) });
          q.push({ behavior: 'pounce', duration: R(40, 80), popup: '🐾' });
        }
        break;
      }

      case 'social': {
        q.push({ behavior: 'stalk', duration: R(180, 360) }); // approach
        q.push({ behavior: 'sit', duration: R(600, 1200) });   // sit nearby — settle in
        if (Math.random() < 0.6) {
          q.push({ behavior: 'groom', duration: R(360, 720) }); // long social groom
        }
        q.push({ behavior: 'loaf', duration: R(600, 1200) });  // chill together
        if (p === 'lazy' && Math.random() < 0.4) {
          q.push({ behavior: 'nap', duration: R(900, 1800) }); // nap next to friend
        }
        break;
      }

      case 'perch': {
        // First ensure we're at an edge
        if (Math.min(k.x, mainW() - k.x) > 80) {
          break; // still walking to edge, perch drift handles direction
        }
        q.push({ behavior: 'sit', duration: R(360, 720) });
        if (Math.random() < 0.5) q.push({ behavior: 'groom', duration: R(120, 240) });
        q.push({ behavior: 'sit', duration: R(240, 480) });
        if (energy < 50) {
          q.push({ behavior: 'nap', duration: R(300, 600) });
          q.push({ behavior: 'sit', duration: R(180, 360) });
        }
        break;
      }

      case 'observe': {
        // Come to where the user is scrolled and watch them
        const viewY = mainScrollY() + mainViewH() * rand(0.3, 0.7);
        const viewX = rand(mainW() * 0.15, mainW() * 0.85);
        steerToward(k, viewX, viewY, 0.06);

        q.push({ behavior: 'loaf', duration: R(600, 1200) }); // lie down and watch — 10-20s
        if (tamagotchi.getTrust() > 50 && Math.random() < 0.4) {
          q.push({ behavior: 'loaf', duration: R(300, 600) }); // slow blink
        }
        q.push({ behavior: 'groom', duration: R(300, 600) });
        // High trust: knead near the user (feeling very safe)
        if (tamagotchi.getTrust() > 60 && happiness > 60 && Math.random() < 0.3) {
          q.push({ behavior: 'knead', duration: R(360, 720), popup: '🫶' });
        }
        q.push({ behavior: 'loaf', duration: R(600, 1200) }); // watch more
        if (p === 'shy' && Math.random() < 0.5) {
          q.push({ behavior: 'stalk', duration: R(60, 120) });
          q.push({ behavior: 'loaf', duration: R(120, 240) });
        }
        break;
      }
    }

    k.behaviorQueue = q;
  }

  /* ═══ Stats → visual appearance ══════════════════════ */

  function updateTamagotchiVisuals() {
    const state = tamagotchi.getState();
    if (!state) return;

    for (const k of cats) {
      if (!k.tamagotchiId) continue;
      const catData = state.cats.find(c => c.id === k.tamagotchiId);
      if (!catData) continue;

      // Low hunger: slow movement
      if (catData.hunger < 30) {
        k.el.style.setProperty('--kitten-walk-speed', `${k.normalWalk * 1.8}s`);
      }

      // Low cleanliness: desaturated fur
      if (catData.cleanliness < 30) {
        k.el.style.filter = 'saturate(0.5) drop-shadow(0 0 4px rgba(255, 200, 100, 0.3))';
      } else if (catData.cleanliness < 60) {
        k.el.style.filter = 'saturate(0.75) drop-shadow(0 0 4px rgba(255, 200, 100, 0.3))';
      } else {
        k.el.style.filter = 'drop-shadow(0 0 4px rgba(255, 200, 100, 0.3))';
      }

      // Low happiness: droopy ears
      const ears = k.el.querySelectorAll('.kitten-ear');
      if (catData.happiness < 30) {
        ears.forEach(ear => (ear as HTMLElement).style.transform += ' rotate(15deg)');
      }
    }
  }

  /* ═══ Social bonds + family behavior ══════════════════ */

  const SOCIAL_GROOM_INTERVAL = 600; // frames (~10s at 60fps)
  let socialTimer = 0;

  function getRelation(catA: string, catB: string): string | null {
    const state = tamagotchi.getState();
    if (!state) return null;
    const rel = state.family.find(
      f => (f.catId === catA && f.relatedCatId === catB) ||
           (f.catId === catB && f.relatedCatId === catA)
    );
    return rel?.relation || null;
  }

  function getBondAffinity(catA: string, catB: string): number {
    const state = tamagotchi.getState();
    if (!state) return 0;
    const [a, b] = catA < catB ? [catA, catB] : [catB, catA];
    const bond = state.bonds.find(bo => bo.catAId === a && bo.catBId === b);
    // Family relations count as high affinity
    const familyBonus = getRelation(catA, catB) ? 80 : 0;
    return Math.min(100, (bond?.affinity || 0) + familyBonus);
  }

  function tickSocialBehavior() {
    socialTimer++;

    const tamaCats = cats.filter(k => k.tamagotchiId);
    if (tamaCats.length < 2) return;

    for (let i = 0; i < tamaCats.length; i++) {
      const a = tamaCats[i];
      if (!a.tamagotchiId) continue;

      for (let j = i + 1; j < tamaCats.length; j++) {
        const b = tamaCats[j];
        if (!b.tamagotchiId) continue;

        const dx = b.x - a.x;
        const dy = b.y - a.y;
        const dist = Math.hypot(dx, dy);
        const affinity = getBondAffinity(a.tamagotchiId, b.tamagotchiId);
        const relation = getRelation(a.tamagotchiId, b.tamagotchiId);

        if (affinity < 10) continue; // no meaningful bond

        // ── Attraction: only during social activity, not always ──
        const aWantsSocial = a.activity === 'social' || a.activity === 'lounge';
        const bWantsSocial = b.activity === 'social' || b.activity === 'lounge';
        if (dist > 150 && dist < 500 && affinity > 30 && (aWantsSocial || bWantsSocial)) {
          const strength = 0.08 * (affinity / 100);
          if (a.behavior === 'walk' && aWantsSocial) {
            a.vx += (dx / dist) * strength;
          }
          if (b.behavior === 'walk' && bWantsSocial) {
            b.vx -= (dx / dist) * strength;
          }
        }
        // When close AND both social, settle down together
        if (dist < 120 && dist > 20 && affinity > 30 && (aWantsSocial || bWantsSocial)) {
          if (a.behavior === 'walk' && Math.random() < 0.008) {
            enterBehavior(a, 'sit');
          }
          if (b.behavior === 'walk' && Math.random() < 0.008) {
            enterBehavior(b, 'sit');
          }
        }

        // ── Parent-child: kittens follow moeder more strongly ──
        if (relation === 'mother') {
          // Figure out who is the kitten and who is the mother
          const state = tamagotchi.getState();
          const aData = state?.cats.find(c => c.id === a.tamagotchiId);
          const bData = state?.cats.find(c => c.id === b.tamagotchiId);

          let kitten: KState | null = null;
          let mother: KState | null = null;
          if (aData?.stage === 'kitten' && bData?.stage === 'adult') { kitten = a; mother = b; }
          else if (bData?.stage === 'kitten' && aData?.stage === 'adult') { kitten = b; mother = a; }

          if (kitten && mother && dist > 80 && dist < 600) {
            const kdx = mother.x - kitten.x;
            const kdy = mother.y - kitten.y;
            const kdist = Math.hypot(kdx, kdy);
            // Kittens follow mom with a stronger force
            if (kitten.behavior === 'walk' || kitten.behavior === 'stalk') {
              kitten.vx += (kdx / kdist) * 0.4;
              kitten.vy += (kdy / kdist) * 0.15;
            }
          }
        }

        // ── Sibling play: playbow → lunge → target dodges/plays back ──
        if (relation === 'sibling' && dist < 120 && dist > 30) {
          if (Math.random() < 0.003 && affinity > 40) {
            const player = Math.random() > 0.5 ? a : b;
            const target = player === a ? b : a;
            if (player.behavior === 'walk') {
              const pdx = target.x - player.x;
              const pdy = target.y - player.y;
              const pdist = Math.hypot(pdx, pdy) || 1;
              player.el.dataset.facingRight = pdx > 0 ? '1' : '';
              player.behaviorQueue = [{ behavior: 'pounce', duration: Math.floor(rand(40, 70)), popup: '🐾' }];
              enterBehavior(player, 'playbow');
              player.bTimer = Math.floor(rand(40, 80));
              // Lunge toward sibling
              player.vx += (pdx / pdist) * 5;
              player.vy += (pdy / pdist) * 2;
              // Target dodges + maybe plays back
              target.vx -= (pdx / pdist) * 3;
              target.vy -= 1.5;
              if (target.behavior === 'walk' && Math.random() < 0.4) {
                setTimeout(() => {
                  if (target.behavior === 'walk') {
                    enterBehavior(target, 'pounce');
                    target.vx += (pdx / pdist) * 4;
                    showPopup(target.el, '🐾');
                  }
                }, rand(400, 800));
              }
            }
          }
        }

        // ── Head bonk: bonded cats briefly touch heads ──
        if (dist < 50 && dist > 15 && affinity > 60 && Math.random() < 0.001) {
          if ((a.behavior === 'walk' || a.behavior === 'sit') && (b.behavior === 'walk' || b.behavior === 'sit')) {
            // Head bonk as behavior: headbonk → sit (resume)
            const bonkDir = Math.sign(dx) || 1;
            a.el.dataset.facingRight = dx > 0 ? '1' : '';
            b.el.dataset.facingRight = dx > 0 ? '' : '1';
            // Queue: headbonk (lean + touch) → sit (settle back)
            a.behaviorQueue = [{ behavior: 'sit', duration: Math.floor(rand(120, 240)) }];
            b.behaviorQueue = [{ behavior: 'sit', duration: Math.floor(rand(120, 240)) }];
            enterBehavior(a, 'headbonk');
            enterBehavior(b, 'headbonk');
            a.bTimer = Math.floor(rand(60, 100));
            b.bTimer = Math.floor(rand(60, 100));
            // CSS animation handles the lean — cats stay in place
            a.el.dataset.tail = 'greeting';
            b.el.dataset.tail = 'greeting';
            showPopup(a.el, '💕');
            showPopup(b.el, '💕');
            document.dispatchEvent(new CustomEvent('tama-hint', {
              detail: {
                key: 'head-bonk',
                catId: a.tamagotchiId,
                catName: a.tamagotchiName,
                otherCatId: b.tamagotchiId,
                otherCatName: b.tamagotchiName,
              }
            }));
          }
        }

        // ── Social grooming: bonded cats groom each other ──
        if (dist < 80 && affinity > 50 && socialTimer % SOCIAL_GROOM_INTERVAL === 0) {
          const state = tamagotchi.getState();
          const aData = state?.cats.find(c => c.id === a.tamagotchiId);
          const bData = state?.cats.find(c => c.id === b.tamagotchiId);

          // Find the dirtier cat
          let groomer: KState | null = null;
          let groomee: KState | null = null;
          let groomeeId: string | null = null;

          if (aData && bData) {
            if (bData.cleanliness < 60 && a.behavior === 'walk') {
              groomer = a; groomee = b; groomeeId = b.tamagotchiId!;
            } else if (aData.cleanliness < 60 && b.behavior === 'walk') {
              groomer = b; groomee = a; groomeeId = a.tamagotchiId!;
            }
          }

          if (groomer && groomee && groomeeId) {
            // Groomer: approach → groom (facing groomee)
            const groomDx = groomee.x - groomer.x;
            groomer.el.dataset.facingRight = groomDx > 0 ? '1' : '';
            groomee.el.dataset.facingRight = groomDx > 0 ? '' : '1';
            // Queue: stalk (approach) → groom (lean in and lick)
            groomer.behaviorQueue = [
              { behavior: 'groom', duration: Math.floor(rand(300, 600)) },
            ];
            enterBehavior(groomer, 'stalk');
            groomer.bTimer = Math.floor(rand(40, 80));
            groomer.vx = Math.sign(groomDx) * 2; // move toward groomee
            // Groomee: sit contentedly
            if (groomee.behavior !== 'sit') {
              if (groomee.behavior !== 'walk') exitBehavior(groomee);
              enterBehavior(groomee, 'sit');
            }
            groomee.bTimer = Math.max(groomee.bTimer, 400);
            groomee.el.classList.add('kitten--purring');
            setTimeout(() => groomee!.el.classList.remove('kitten--purring'), 3000);
            setInteraction(groomee, 'groomed', 90);
            showPopup(groomer.el, '✨');
            showPopup(groomee.el, '💕');
            document.dispatchEvent(new CustomEvent('tama-hint', { detail: {
              key: 'social-groom',
              catId: groomer.tamagotchiId, catName: groomer.tamagotchiName,
              otherCatId: groomee.tamagotchiId, otherCatName: groomee.tamagotchiName,
            } }));

            // Send groom action for the dirty cat
            const onScreen = tamaCats.map(c => c.tamagotchiId!);
            tamagotchi.sendCare(groomeeId, 'groom', onScreen, undefined, {
              sourceType: 'cat',
              sourceCatId: groomer.tamagotchiId,
              sourceCatName: groomer.tamagotchiName,
            });
          }
        }

        // ── Nap pile: bonded cats nap near each other ──
        if (dist < 150 && affinity > 40) {
          // If one is napping, the other gravitates toward them for a nap too
          if (a.behavior === 'nap' && b.behavior === 'walk' && Math.random() < 0.002) {
            b.baseY = a.y; enterBehavior(b, 'nap'); showPopup(b.el, '💤');
            document.dispatchEvent(new CustomEvent('tama-hint', { detail: { key: 'nap-pile' } }));
          } else if (b.behavior === 'nap' && a.behavior === 'walk' && Math.random() < 0.002) {
            a.baseY = b.y; enterBehavior(a, 'nap'); showPopup(a.el, '💤');
            document.dispatchEvent(new CustomEvent('tama-hint', { detail: { key: 'nap-pile' } }));
          }
        }
      }
    }
  }

  /* ═══ SessionStorage persistence ═════════════════════ */

  const SESSION_KEY = 'tamagotchi_onscreen';
  // Per-cat session mood: short-term disposition this visit (-3 annoyed → +12 happy)
  // Separate from server trust (long-term relationship across visits)
  const MOOD_KEY = 'tamagotchi_mood';
  const MOOD_RESTORE_THRESHOLD = 2;

  function getMoodMap(): Record<string, number> {
    try {
      return JSON.parse(sessionStorage.getItem(MOOD_KEY) || '{}') as Record<string, number>;
    } catch {
      return {};
    }
  }

  function getCatMood(catId: string): number {
    return getMoodMap()[catId] || 0;
  }

  function setCatMood(catId: string, value: number): void {
    const moods = getMoodMap();
    moods[catId] = Math.max(-3, Math.min(12, value));
    sessionStorage.setItem(MOOD_KEY, JSON.stringify(moods));
  }

  // bumpTrust updates BOTH: session mood + server trust
  function bumpTrust(catId: string, delta: number): void {
    setCatMood(catId, getCatMood(catId) + delta);
  }

  function saveTamagotchiSession() {
    const ids = cats
      .filter((k) => k.tamagotchiId && !k.shooed && getCatMood(k.tamagotchiId!) >= MOOD_RESTORE_THRESHOLD)
      .map((k) => k.tamagotchiId!);
    sessionStorage.setItem(SESSION_KEY, JSON.stringify(ids));
  }

  function restoreTamagotchiSession() {
    const stored = sessionStorage.getItem(SESSION_KEY);
    if (!stored) return;

    try {
      const ids = JSON.parse(stored) as string[];

      // Wait for state to be available, then spawn
      function tryRestore() {
        const tamaCats = tamagotchi.getTamagotchiCats();
        if (tamaCats.length === 0) {
          // State not loaded yet, retry shortly
          setTimeout(tryRestore, 500);
          return;
        }
        ids.forEach((id, i) => {
          const cat = tamaCats.find(c => c.id === id);
          if (cat && !onScreenTamagotchi.has(id) && getCatMood(id) >= MOOD_RESTORE_THRESHOLD) {
            setTimeout(() => {
              makeKitten({ tamagotchi: cat, force: true });
              saveTamagotchiSession();
            }, i * rand(800, 1500));
          }
        });
      }
      tryRestore();
    } catch { /* ignore bad data */ }
  }

  // Save session when tamagotchi cats change
  function onTamagotchiChange() {
    saveTamagotchiSession();
  }

  // Save before navigating away
  window.addEventListener('beforeunload', saveTamagotchiSession);

  /* ═══ Scheduling ═══════════════════════════════════════ */

  let spawnPaused = false;
  // Unified ambient scheduler: regular crossing cats + ambient events in one loop
  function scheduleAmbient() {
    setTimeout(() => {
      if (!spawnPaused) {
        const hasTamaCats = cats.some(k => k.tamagotchiId && !k.shooed);
        // ~20% chance of an event (only when tamagotchi cats are present + cooldown passed)
        if (hasTamaCats && Math.random() < 0.2 && Date.now() - lastEventTime > 30000) {
          triggerAmbientEvent();
        } else {
          spawnAmbientKitten();
        }
      }
      scheduleAmbient();
    }, rand(10000, 20000));
  }

  // Tab visibility — pause spawning when hidden, scatter cats on return
  let hiddenAt = 0;
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      spawnPaused = true;
      hiddenAt = Date.now();
    } else {
      spawnPaused = false;
      const idleMs = Date.now() - hiddenAt;
      if (idleMs > 30000) {
        // 15 min ≈ 5 cats, 2 hours ≈ 20 cats
        const idleMin = idleMs / 60000;
        const count = Math.min(20, Math.round(idleMin / 3));
        for (let i = 0; i < count; i++) {
          const cat = makeKitten({ force: true });
          if (cat) {
            // Place at random position on the visible page
            cat.x = rand(50, mainW() - 50);
            cat.y = mainScrollY() + rand(50, mainViewH() - 50);
            cat.baseVx = 0;
            cat.savedVx = 0;
            // Start in a settled pose — they were chilling
            const settled = pick(['sit', 'nap', 'groom'] as const);
            enterBehavior(cat, settled);
            cat.el.style.transform = `translate(${cat.x}px, ${cat.y}px)`;

            // After a staggered delay — they notice you're back and scatter
            setTimeout(() => {
              if (!cat.el.parentNode) return;
              exitBehavior(cat);
              showPopup(cat.el, '❗');
              cat.baseY = cat.y; // reset spring anchor so they don't bounce back
              const goLeft = cat.x < mainW() / 2;
              cat.baseVx = goLeft ? rand(-4, -6) : rand(4, 6);
              cat.savedVx = cat.baseVx;
              cat.vy -= rand(1, 3);
            }, rand(300, 1500 + i * 400));
          }
        }
      }
    }
  });

  // Dismiss all tamagotchi cats (from sidebar close)
  document.addEventListener('tama-dismiss-all', () => {
    for (const k of cats) {
      if (k.tamagotchiId) {
        k.shooed = true;
        k.el.classList.add('kitten--shooed');
        k.baseVx = (Math.random() > 0.5 ? 1 : -1) * 6;
        k.savedVx = k.baseVx;
        if (k.behavior !== 'walk') exitBehavior(k);
      }
    }
    saveTamagotchiSession();
  });

  // Button click: tamagotchi first, then ambient
  document.addEventListener('spawn-kitten', () => {
    spawnTamagotchiOrAmbient(true);
    saveTamagotchiSession();
  });

  /* ═══ Ambient events ══════════════════════════════════ */

  type AmbientEventType = 'outsider' | 'thief' | 'bird' | 'bulldozer' | 'hiss' | 'observer';
  let lastEventTime = 0;


  function triggerAmbientEvent() {
    if (Date.now() - lastEventTime < 30000) return; // min 30s between events
    lastEventTime = Date.now();

    const events: AmbientEventType[] = ['outsider', 'thief', 'bird', 'bulldozer', 'hiss', 'observer'];
    const event = pick(events);

    switch (event) {
      case 'outsider': return eventOutsider();
      case 'thief': return eventThief();
      case 'bird': return eventBirdWatch();
      case 'bulldozer': return eventBulldozer();
      case 'hiss': return eventHissStandoff();
      case 'observer': return eventObserver();
    }
  }

  // De kat die niemand mag — rude outsider gets chased off by tamagotchi cats
  function eventOutsider() {
    const goRight = Math.random() > 0.5;
    const yPos = mainScrollY() + rand(mainViewH() * 0.3, mainViewH() * 0.7);
    const outsider = makeKitten({
      goRight, yPos,
      speed: [1.5, 2.5], personality: 'sassy', force: true,
    });
    if (!outsider) return;
    outsider.mission = 'outsider';
    outsider.baseVx *= 0.5; // walks in slowly, looking around

    // After a pause, tamagotchi cats react
    setTimeout(() => {
      if (!outsider.el.parentNode) return;
      for (const k of cats) {
        if (!k.tamagotchiId || k.behavior === 'nap') continue;
        const d = Math.hypot(k.x - outsider.x, k.y - outsider.y);
        if (d > 400) continue;

        if (k.personality === 'sassy') {
          // Sassy cats confront: stare, approach, then pounce at outsider
          const chaseDx = outsider.x - k.x;
          const chaseDy = outsider.y - k.y;
          const chaseDist = Math.hypot(chaseDx, chaseDy) || 1;
          k.el.dataset.facingRight = chaseDx > 0 ? '1' : '';
          showPopup(k.el, '😾');
          k.behaviorQueue = [{ behavior: 'pounce', duration: 60, popup: '🐾' }];
          enterBehavior(k, 'stalk');
          k.bTimer = 120;
          // Physically move toward the outsider
          k.vx += (chaseDx / chaseDist) * 4;
          k.vy += (chaseDy / chaseDist) * 2;
          emitTamaSound('pet-reject');
        } else if (k.personality === 'shy') {
          // Shy cats back away
          k.vx += Math.sign(k.x - outsider.x) * 4;
          showPopup(k.el, '😨');
        } else if (k.personality === 'playful') {
          // Playful cats join the chase for fun
          showPopup(k.el, '❗');
          k.vx += Math.sign(outsider.x - k.x) * 3;
        } else {
          // Lazy/curious: just stare and judge
          k.el.dataset.facingRight = (outsider.x - k.x) > 0 ? '1' : '';
          showPopup(k.el, '😒');
        }
      }

      // Outsider gets spooked and runs away
      setTimeout(() => {
        if (!outsider.el.parentNode) return;
        outsider.mission = 'leave';
        outsider.baseVx = goRight ? -rand(4, 6) : rand(4, 6); // run back where it came from
        outsider.savedVx = outsider.baseVx;
        outsider.vy -= 3;
        showPopup(outsider.el, '🙀');
        emitTamaSound('startled');
      }, rand(1500, 3000));
    }, rand(2000, 4000));
  }

  // Brutaal voerdiefje — thief cat sneaks in and steals food
  function eventThief() {
    // Only trigger if there's food on the ground
    const targetFood = foodItems.find(f => !f.gone);
    if (!targetFood) return;

    const goRight = targetFood.x > mainW() / 2 ? false : true;
    const thief = makeKitten({
      goRight, yPos: targetFood.y + rand(-30, 30),
      speed: [2, 3.5], personality: 'chaotic', force: true,
    });
    if (!thief) return;
    thief.mission = 'thief';
    thief.missionTarget = { x: () => targetFood.x, y: () => targetFood.y, alive: () => !targetFood.gone };
    enterBehavior(thief, 'stalk');

    // Tamagotchi cats notice and react
    setTimeout(() => {
      for (const k of cats) {
        if (!k.tamagotchiId || k.behavior === 'nap') continue;
        const d = Math.hypot(k.x - thief.x, k.y - thief.y);
        if (d < 250) {
          k.el.dataset.facingRight = (thief.x - k.x) > 0 ? '1' : '';
          showPopup(k.el, '👀');
        }
      }
    }, 1500);
  }

  // Raamvogel — all cats stare at an invisible bird, chatter, tail twitch
  function eventBirdWatch() {
    // Pick a random offscreen point (top edge)
    const birdX = rand(mainW() * 0.2, mainW() * 0.8);
    const birdY = mainScrollY() - 50; // above viewport

    let reactCount = 0;
    for (const k of cats) {
      if (!k.tamagotchiId || k.behavior === 'nap') continue;
      if (reactCount >= 4) break; // max 4 cats react
      if (Math.random() < 0.4) continue; // not everyone notices

      k.behaviorQueue = [];
      if (k.behavior !== 'walk') exitBehavior(k);
      enterBehavior(k, 'stalk');
      k.bTimer = Math.floor(rand(300, 600));
      // Face the bird
      k.el.dataset.facingRight = (birdX - k.x) > 0 ? '1' : '';

      // Stagger reactions
      const delay = reactCount * rand(300, 800);
      setTimeout(() => {
        if (k.behavior !== 'stalk') return;
        if (k.personality === 'curious' || k.personality === 'chaotic') {
          showPopup(k.el, '🐦');
          emitTamaSound('meow');
        } else {
          showPopup(k.el, '👀');
        }
      }, delay);

      // Some cats pounce at nothing
      if ((k.personality === 'playful' || k.personality === 'chaotic') && Math.random() < 0.5) {
        setTimeout(() => {
          if (k.behavior === 'stalk') {
            enterBehavior(k, 'pounce');
            k.vy -= 4;
            showPopup(k.el, '🐾');
          }
        }, delay + rand(1500, 3000));
      }

      reactCount++;
    }
  }

  // Bulldozer kitten — tiny fearless kitten barges through lounging cats
  function eventBulldozer() {
    const goRight = Math.random() > 0.5;
    const yPos = mainScrollY() + rand(mainViewH() * 0.3, mainViewH() * 0.7);
    const bulldozer = makeKitten({
      goRight, yPos,
      size: [25, 35], speed: [4, 6], personality: 'playful', force: true,
    });
    if (!bulldozer) return;
    bulldozer.mission = 'bulldozer';

    // Nearby tamagotchi cats react as the kitten passes
    const checkInterval = setInterval(() => {
      if (!bulldozer.el.parentNode) { clearInterval(checkInterval); return; }
      for (const k of cats) {
        if (k === bulldozer || !k.tamagotchiId) continue;
        const d = Math.hypot(k.x - bulldozer.x, k.y - bulldozer.y);
        if (d < 80 && d > 20) {
          if (k.behavior === 'nap') {
            exitBehavior(k);
            showPopup(k.el, '😾');
          } else if (k.behavior === 'sit') {
            showPopup(k.el, '😒');
            k.el.dataset.facingRight = (bulldozer.x - k.x) > 0 ? '1' : '';
          }
        }
      }
    }, 200);

    // Bulldozer leaves after crossing
    setTimeout(() => clearInterval(checkInterval), 15000);
  }

  // Dramatische hiss — two ambient cats have a territorial standoff
  function eventHissStandoff() {
    const y = mainScrollY() + rand(mainViewH() * 0.3, mainViewH() * 0.7);
    const catA = makeKitten({ goRight: true, yPos: y, speed: [1.5, 2], personality: 'sassy', force: true });
    const catB = makeKitten({ goRight: false, yPos: y + rand(-20, 20), speed: [1.5, 2], personality: 'sassy', force: true });
    if (!catA || !catB) return;

    // They walk toward each other, then stop
    setTimeout(() => {
      if (!catA.el.parentNode || !catB.el.parentNode) return;
      // Face each other
      catA.el.dataset.facingRight = '1';
      catB.el.dataset.facingRight = '';
      // Side-step circling: both drift vertically in opposite directions
      catA.baseVy = rand(0.5, 1.2);
      catB.baseVy = -rand(0.5, 1.2);
      catA.baseVx = 0; catB.baseVx = 0;
      enterBehavior(catA, 'stalk'); // low crouch, not sit
      enterBehavior(catB, 'stalk');
      catA.bTimer = 180;
      catB.bTimer = 180;
      // Tail puff + ears back
      catA.el.dataset.tail = 'scared'; catA.el.dataset.ears = 'flat';
      catB.el.dataset.tail = 'scared'; catB.el.dataset.ears = 'flat';
      showPopup(catA.el, '😾');
      showPopup(catB.el, '😾');
      emitTamaSound('pet-reject');

      // One backs off
      setTimeout(() => {
        const loser = Math.random() > 0.5 ? catA : catB;
        const winner = loser === catA ? catB : catA;
        delete loser.el.dataset.ears;
        delete winner.el.dataset.ears;
        loser.mission = 'leave';
        if (loser.behavior !== 'walk') exitBehavior(loser);
        loser.baseVx = loser === catA ? -rand(3, 5) : rand(3, 5);
        loser.savedVx = loser.baseVx;
        loser.vy -= 2;
        showPopup(loser.el, '😿');
        showPopup(winner.el, '😤');

        // Winner walks off after gloating
        setTimeout(() => {
          winner.mission = 'leave';
          if (winner.behavior !== 'walk') exitBehavior(winner);
          winner.baseVx = winner === catA ? rand(2, 4) : -rand(2, 4);
          winner.savedVx = winner.baseVx;
          winner.el.dataset.tail = 'sassy';
        }, rand(2000, 4000));
      }, rand(2000, 4000));
    }, rand(3000, 5000));
  }

  function eventObserver() {
    const anchorX = rand(mainW() * 0.18, mainW() * 0.82);
    const anchorY = mainScrollY() + rand(mainViewH() * 0.28, mainViewH() * 0.72);
    const goRight = anchorX < mainW() * 0.5;
    const observer = makeKitten({
      goRight,
      yPos: anchorY + rand(-30, 30),
      speed: [1.2, 2.1],
      personality: pick(['curious', 'shy', 'sassy'] as const),
      force: true,
    });
    if (!observer) return;

    observer.mission = 'observe';
    observer.activity = 'observe';
    observer.activityTimer = Math.floor(rand(600, 1200));
    observer.missionFrames = Math.floor(rand(900, 1800));
    observer.missionTarget = {
      x: () => anchorX,
      y: () => anchorY,
      alive: () => true,
    };
  }

  if (!reducedMotion) {
    let restTimer = 0;
    requestAnimationFrame(function gameTick() {
      tickFoodAttraction();
      tickSocialBehavior();
      if (Math.random() < 0.016) updateTamagotchiVisuals();

      // Send "rest" for napping tamagotchi cats every ~10 seconds
      restTimer++;
      if (restTimer >= 600) {
        restTimer = 0;
        for (const k of cats) {
          if (k.tamagotchiId && k.behavior === 'nap') {
            const onScreen = cats.filter(c => c.tamagotchiId).map(c => c.tamagotchiId!);
            tamagotchi.sendCare(k.tamagotchiId, 'rest' as any, onScreen);
          }
        }
      }

      // Exploring cats: follow the user's viewport / cursor area
      for (const k of cats) {
        if (!k.tamagotchiId || k.activity !== 'explore') continue;
        if (k.behavior !== 'walk' && k.behavior !== 'stalk') continue;

        // Drift toward the visible area (where the user is scrolled to)
        const viewCenter = mainScrollY() + mainViewH() * 0.5;
        const distToView = viewCenter - k.y;
        if (Math.abs(distToView) > mainViewH() * 0.6) {
          // Cat is off-screen — pull toward viewport
          k.baseVy += Math.sign(distToView) * 0.02;
          k.baseVy = Math.max(-1.5, Math.min(1.5, k.baseVy));
        }

        // Occasionally drift toward cursor
        if (Math.random() < 0.002 && Math.abs(my - k.y) > 100) {
          k.baseVy += Math.sign(my - k.y) * 0.3;
          k.baseVy = Math.max(-1.5, Math.min(1.5, k.baseVy));
        }
      }

      requestAnimationFrame(gameTick);
    });

    requestAnimationFrame(tick);

    // Init tamagotchi client, then start spawning
    tamagotchi.init().then(() => {
      // Restore previously on-screen cats
      restoreTamagotchiSession();
      // High-trust auto-spawn: trusted cats come greet you on page load
      const trust = tamagotchi.getTrust();
      if (trust > 40) {
        const count = trust > 80 ? 2 : 1;
        const available = tamagotchi.getTamagotchiCats().filter(c => !onScreenTamagotchi.has(c.id));
        for (let i = 0; i < Math.min(count, available.length); i++) {
          setTimeout(() => {
            const cat = available[i];
            if (cat && !onScreenTamagotchi.has(cat.id)) makeKitten({ tamagotchi: cat, force: true });
          }, rand(2000, 5000 + i * 2000));
        }
      }
      setTimeout(spawnAmbientKitten, 3000);
      scheduleAmbient();
    }).catch(() => {
      // Game server unavailable — fall back to pure ambient
      setTimeout(spawnAmbientKitten, 3000);
      scheduleAmbient();
    });
  }
</script>

