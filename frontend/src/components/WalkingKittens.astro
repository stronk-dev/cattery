  }
  .kitten[data-behavior="nap"] .kitten-leg { animation: none !important; opacity: 0; }
  .kitten[data-behavior="nap"] .kitten-head { top: 14%; left: 48%; }
  .kitten[data-behavior="nap"] .kitten-eye {
    animation: none !important;
    transform: scaleY(0.1);
  }
  .kitten[data-behavior="nap"] .kitten-tail     { animation: none !important; transform: rotate(-35deg); }
  .kitten[data-behavior="nap"] .kitten-tail-mid { animation: none !important; transform: rotate(-25deg); }
  .kitten[data-behavior="nap"] .kitten-tail-tip { animation: none !important; transform: rotate(-15deg); }

  /* ── Play bow (front down, butt up) ──────────────────── */

  .kitten[data-behavior="playbow"] .kitten-body {
    animation-name: none;
    transform: rotate(-10deg);
    transform-origin: 25% 70%;
  }
  .kitten[data-behavior="playbow"] .kitten-leg { animation: none !important; }
  .kitten[data-behavior="playbow"] .kitten-leg--fl { transform: rotate(25deg); height: 35%; }
  .kitten[data-behavior="playbow"] .kitten-leg--fr { transform: rotate(20deg); height: 33%; }
  .kitten[data-behavior="playbow"] .kitten-leg--bl { transform: rotate(-5deg); }
  .kitten[data-behavior="playbow"] .kitten-leg--br { transform: rotate(-5deg); }

  .kitten[data-behavior="playbow"] .kitten-tail     { animation: tail-playful-base 0.3s ease-in-out infinite alternate !important; }
  .kitten[data-behavior="playbow"] .kitten-tail-mid { animation: tail-playful-mid 0.3s 0.04s ease-in-out infinite alternate !important; }
  .kitten[data-behavior="playbow"] .kitten-tail-tip { animation: tail-playful-tip 0.3s 0.08s ease-in-out infinite alternate !important; }

  /* ── Pounce prep (rising on hind legs) ───────────────── */

  .kitten[data-behavior="pounce"] .kitten-body {
    animation-name: none;
    transform: rotate(20deg);
    transform-origin: 25% 80%;
  }
  .kitten[data-behavior="pounce"] .kitten-leg { animation: none !important; }
  .kitten[data-behavior="pounce"] .kitten-leg--fl { transform: rotate(-35deg); bottom: 15%; }
  .kitten[data-behavior="pounce"] .kitten-leg--fr { transform: rotate(-25deg); bottom: 12%; }
  .kitten[data-behavior="pounce"] .kitten-leg--bl,
  .kitten[data-behavior="pounce"] .kitten-leg--br { transform: rotate(0deg); }
  .kitten[data-behavior="pounce"] .kitten-eye {
    animation: none !important; /* wide-eyed stare */
  }

  /* ── Groom (sitting + paw raised) ────────────────────── */

  .kitten[data-behavior="groom"] .kitten-body {
    animation: kitten-sit-bob 2s ease-in-out infinite alternate;
  }
  .kitten[data-behavior="groom"] .kitten-body::before {
    top: 12%; left: 24%;
    width: 38%; height: 52%;
    border-radius: 50% 50% 44% 44%;
  }
  .kitten[data-behavior="groom"] .kitten-body::after {
    top: 10%; left: 42%;
    width: 18%; height: 28%;
  }
  .kitten[data-behavior="groom"] .kitten-head {
    top: -6%; left: 36%;
  }
  .kitten[data-behavior="groom"] .kitten-leg { animation: none !important; }
  .kitten[data-behavior="groom"] .kitten-leg--fl { transform: rotate(-8deg); left: 48%; bottom: 22%; height: 38%; }
  .kitten[data-behavior="groom"] .kitten-leg--fr { transform: rotate(0deg); left: 52%; bottom: 22%; height: 38%; }
  .kitten[data-behavior="groom"] .kitten-leg--bl { transform: rotate(-75deg); left: 24%; bottom: 18%; height: 16%; }
  .kitten[data-behavior="groom"] .kitten-leg--br { transform: rotate(-75deg); left: 28%; bottom: 18%; height: 16%; }
  .kitten[data-behavior="groom"] .kitten-head {
    animation: kitten-groom-bob 0.6s ease-in-out infinite alternate;
  }

  /* ── Stalk (low crouch, creeping) ────────────────────── */

  .kitten[data-behavior="stalk"] .kitten-body {
    animation-name: none;
    transform: translateY(12%) scaleY(0.85);
  }
  .kitten[data-behavior="stalk"] .kitten-head { top: 14%; left: 56%; }
  .kitten[data-behavior="stalk"] .kitten-eye {
    animation: none !important; /* wide-eyed, alert */
  }
  .kitten[data-behavior="stalk"] .kitten-tail     { animation: none !important; transform: rotate(-25deg); }
  .kitten[data-behavior="stalk"] .kitten-tail-mid { animation: none !important; transform: rotate(-5deg); }
  .kitten[data-behavior="stalk"] .kitten-tail-tip { animation: none !important; transform: rotate(0deg); }

  /* ══ Yarn ball ═════════════════════════════════════════ */

  .yarn {
    position: absolute;
    top: 0; left: 0;
    pointer-events: none;
  }
  .yarn[data-variant="feather"]::after {
    content: none;
  }
  /* Trailing yarn strand — comes from bottom of ball, trails behind */
  .yarn::after {
    content: '';
    position: absolute;
    top: 16px;
    width: 30px; height: 3px;
    background: var(--yarn-color, #cc3333);
    border-radius: 2px;
    opacity: 0.7;
    animation: yarn-strand-wave 0.6s ease-in-out infinite alternate;
  }
  .yarn[data-dir="right"]::after {
    right: 18px;
    transform-origin: right center;
  }
  .yarn[data-dir="left"]::after {
    left: 18px;
    transform-origin: left center;
  }
  .yarn-ball {
    width: 20px; height: 20px;
    border-radius: 50%;
    position: relative;
    animation: yarn-spin 0.4s linear infinite;
    /* Striped gradient so rotation is visible */
    background: repeating-conic-gradient(
      var(--yarn-color, #cc3333) 0deg 40deg,
      color-mix(in srgb, var(--yarn-color, #cc3333), white 25%) 40deg 80deg
    );
  }
  /* Yarn cross-wrap lines */
  .yarn-ball::before,
  .yarn-ball::after {
    content: '';
    position: absolute;
    top: 15%; left: 15%;
    width: 70%; height: 70%;
    border: 1.5px solid rgba(255,255,255,0.4);
    border-radius: 50%;
  }
  .yarn-ball::before { transform: rotate(35deg); }
  .yarn-ball::after  { transform: rotate(-25deg) scale(0.8); }
  .tama-feather {
    font-size: 24px;
    filter: drop-shadow(0 4px 8px rgba(75, 55, 37, 0.25));
    transform: rotate(16deg);
    animation: feather-float 0.45s ease-in-out infinite alternate;
    line-height: 1;
  }

  /* ══ Keyframes ═════════════════════════════════════════ */

  @keyframes kitten-step-a {
    0%   { transform: rotate(20deg); }
    100% { transform: rotate(-20deg); }
  }
  @keyframes kitten-step-b {
    0%   { transform: rotate(-20deg); }
    100% { transform: rotate(20deg); }
  }
  @keyframes kitten-bob {
    0%   { transform: translateY(0); }
    100% { transform: translateY(-2px); }
  }
  @keyframes kitten-blink {
    0%   { transform: scaleY(1); }
    90%  { transform: scaleY(1); }
