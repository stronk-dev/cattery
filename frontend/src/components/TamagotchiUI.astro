---
---

<div class="tama-panel" id="tama-panel" data-state="collapsed">
  <!-- Mobile toggle (hidden on desktop) -->
  <button class="tama-toggle" id="tama-toggle" aria-label="Tamagotchi paneel">
    <span class="tama-toggle-icon">🐾</span>
    <span class="tama-toggle-badge" id="tama-badge" style="display:none"></span>
  </button>

  <div class="tama-header" role="button" aria-expanded="false" aria-controls="tama-content">
    <div class="tama-header-copy">
      <span class="tama-title">Kattenspel</span>
      <span class="tama-mobile-hint" id="tama-mobile-hint">Tik om te openen</span>
    </div>
    <div class="tama-header-right">
      <span class="tama-connected" id="tama-status" title="Verbonden">●</span>
      <span class="tama-mobile-toggle-pill" aria-hidden="true">
        <span class="tama-mobile-pill-label" id="tama-mobile-pill-label">Open</span>
        <span class="tama-mobile-chevron" id="tama-mobile-chevron">▾</span>
      </span>
      <button class="tama-dismiss" id="tama-dismiss" aria-label="Stuur alle katten weg" title="Stuur alle katten weg">
        <span class="tama-dismiss-icon" aria-hidden="true">↗</span>
        <span class="tama-dismiss-label">Wegsturen</span>
      </button>
    </div>
  </div>

  <div class="tama-body">
    <!-- Item tray (pinned with header) -->
    <div class="tama-tray">
      <div class="tama-tray-head">
        <div>
          <div class="tama-feed-title">Acties</div>
          <div class="tama-tray-hint" id="tama-tray-hint">Klik of sleep</div>
        </div>
        <button class="tama-trash-action" id="tama-clear-action" type="button" hidden aria-label="Laat tool vallen" title="Laat tool vallen">🗑</button>
      </div>
      <div class="tama-tray-items">
        <button class="tama-tray-item" data-item="food" data-default-variant="fish" type="button" title="Voer — klik om klaar te zetten of sleep naar de pagina">
          <span class="tama-tray-icon">🍽️</span>
          <span class="tama-tray-label">Voer</span>
          <span class="tama-tray-variant" data-variant-label-for="food">🐟</span>
        </button>
        <button class="tama-tray-item" data-item="yarn" data-default-variant="yarn" type="button" title="Speelgoed — klik om klaar te zetten of sleep naar de pagina">
          <span class="tama-tray-icon">🪀</span>
          <span class="tama-tray-label">Spelen</span>
          <span class="tama-tray-variant" data-variant-label-for="yarn">🧶</span>
        </button>
        <button class="tama-tray-item" data-item="brush" data-default-variant="brush" type="button" title="Borstel — klik om klaar te zetten of sleep naar een kat">
          <span class="tama-tray-icon">🪮</span>
          <span class="tama-tray-label">Borstel</span>
          <span class="tama-tray-variant" data-variant-label-for="brush">•</span>
        </button>
      </div>
    </div>

    <div class="tama-content" id="tama-content">
      <!-- On-screen tamagotchi cats list -->
      <div class="tama-cats-list" id="tama-cats-list">
        <div class="tama-empty" id="tama-empty">
          Klik op 🐱 om een kat te roepen
        </div>
      </div>

      <!-- Activity feed -->
      <div class="tama-feed" id="tama-feed">
        <div class="tama-feed-title">Activiteit</div>
        <div class="tama-feed-list" id="tama-feed-list"></div>
      </div>
    </div>
  </div>
</div>

<!-- Drag ghost (follows cursor when dragging an item) -->
<div class="tama-drag-ghost" id="tama-drag-ghost" style="display:none"></div>
<div class="tama-cursor-preview" id="tama-cursor-preview" style="display:none"></div>

<script>
  import { tamagotchi, type CareVariant, type TamagotchiCat } from '../lib/tamagotchi';
  import { initTamagotchiSounds } from '../lib/tamagotchi-sounds';

  const panel = document.getElementById('tama-panel')!;
  const toggle = document.getElementById('tama-toggle')!;
  const dismiss = document.getElementById('tama-dismiss')!;
  const catsList = document.getElementById('tama-cats-list')!;
  const emptyEl = document.getElementById('tama-empty')!;
  const feedList = document.getElementById('tama-feed-list')!;
  const statusEl = document.getElementById('tama-status')!;
  const badge = document.getElementById('tama-badge')!;
  const dragGhost = document.getElementById('tama-drag-ghost')!;
  const cursorPreview = document.getElementById('tama-cursor-preview')!;
  const trayHint = document.getElementById('tama-tray-hint')!;
  const clearActionBtn = document.getElementById('tama-clear-action') as HTMLButtonElement;
  const mobileHintEl = document.getElementById('tama-mobile-hint')!;
  const mobilePillLabelEl = document.getElementById('tama-mobile-pill-label')!;
  const mobileChevronEl = document.getElementById('tama-mobile-chevron')!;
  const mainEl = document.getElementById('main')!;
  const isDesktop = () => window.innerWidth > 768;
  initTamagotchiSounds();

  const STAGE_LABELS: Record<string, string> = {
    kitten: 'Kitten',
    adult: 'Volwassen',
    elder: 'Senior',
  };

  const ACTION_LABELS: Record<string, string> = {
    feed: 'voerde',
    pet: 'aaide',
    play: 'speelde met',
    groom: 'verzorgde',
  };

  const CAT_ACTION_LABELS: Record<string, string> = {
    feed: 'at met',
    pet: 'zocht aandacht bij',
    play: 'speelde met',
    groom: 'verzorgde',
  };

  const ACTION_ICONS: Record<string, string> = {
    feed: '🐟',
    pet: '💕',
    play: '🧶',
    groom: '🪮',
  };

  const ITEM_ICONS: Record<string, string> = {
    food: '🍽️',
    yarn: '🪀',
    brush: '🪮',
  };

  const ITEM_TO_ACTION: Record<'food' | 'yarn' | 'brush', 'feed' | 'play' | 'groom'> = {
    food: 'feed',
    yarn: 'play',
    brush: 'groom',
  };

  const VARIANT_LABELS: Record<CareVariant, string> = {
    fish: 'vis',
    pellets: 'brokjes',
    treat: 'treat',
    yarn: 'wol',
    feather: 'veertje',
    brush: 'borstel',
  };

  const VARIANT_ICONS: Record<CareVariant, string> = {
    fish: '🐟',
    pellets: '• •',
    treat: '🍤',
    yarn: '🧶',
    feather: '🪶',
    brush: '🪮',
  };

  type TrayItem = 'food' | 'yarn' | 'brush';
  const ITEM_VARIANTS: Record<TrayItem, CareVariant[]> = {
    food: ['fish', 'pellets', 'treat'],
    yarn: ['yarn', 'feather'],
    brush: ['brush'],
  };
  const selectedVariants: Record<TrayItem, CareVariant> = {
    food: 'fish',
    yarn: 'yarn',
    brush: 'brush',
  };
  let activeItem: TrayItem | null = null;

  // Toggle panel (mobile: tap header, desktop: toggle button)
  const header = document.querySelector('.tama-header')!;
  function syncPanelStateUi() {
    const isOpen = panel.dataset.state === 'open';
    header.setAttribute('aria-expanded', String(isOpen));
    mobileHintEl.textContent = isOpen ? 'Tik om te sluiten' : 'Tik om te openen';
    mobilePillLabelEl.textContent = isOpen ? 'Dicht' : 'Open';
    mobileChevronEl.textContent = isOpen ? '▾' : '▴';
  }
  function togglePanel() {
    const isCollapsed = panel.dataset.state === 'collapsed';
    panel.dataset.state = isCollapsed ? 'open' : 'collapsed';
    if (isCollapsed) badge.style.display = 'none';
    syncPanelStateUi();
  }
  toggle.addEventListener('click', togglePanel);
  // On mobile, header acts as toggle
  header.addEventListener('click', (e) => {
    if (window.innerWidth <= 768) {
      // Don't toggle if clicking dismiss button
      if ((e.target as HTMLElement).closest('.tama-dismiss')) return;
      togglePanel();
    }
  });

  // Dismiss button closes the sidebar and shoos all tamagotchi cats
  let dismissed = false;
  dismiss.addEventListener('click', (e) => {
    e.stopPropagation(); // don't trigger header toggle
    dismissed = true;
    panel.style.display = 'none';
    document.dispatchEvent(new CustomEvent('tama-dismiss-all'));
  });

  function emitLocalSound(kind: string, detail: Record<string, unknown> = {}) {
    document.dispatchEvent(new CustomEvent('tama-sound', { detail: { kind, ...detail } }));
  }

  function getVariantForItem(item: TrayItem): CareVariant {
    return selectedVariants[item];
  }

  function describeActiveAction(): string {
    if (!activeItem) return '';
    const variant = getVariantForItem(activeItem);
    const icon = VARIANT_ICONS[variant] || ITEM_ICONS[activeItem];
    const label = VARIANT_LABELS[variant] || variant;
    if (activeItem === 'brush') return `${icon} Borstel`;
    return `${icon} ${label}`;
  }

  function setVariantVisual(target: HTMLElement, variant: CareVariant, fallback: string) {
    if (variant === 'pellets') {
      target.innerHTML = `
        <span class="tama-ui-pellets" aria-hidden="true">
          <span class="tama-ui-pellet tama-ui-pellet--a"></span>
          <span class="tama-ui-pellet tama-ui-pellet--b"></span>
          <span class="tama-ui-pellet tama-ui-pellet--c"></span>
          <span class="tama-ui-pellet tama-ui-pellet--d"></span>
        </span>
      `;
      return;
    }
    target.textContent = VARIANT_ICONS[variant] || fallback;
  }

  function syncActiveActionUi() {
    clearActionBtn.hidden = !activeItem;
    trayHint.textContent = activeItem
      ? describeActiveAction()
      : 'Klik of sleep';

    document.querySelectorAll('.tama-tray-item').forEach((item) => {
      const el = item as HTMLElement;
      el.classList.toggle('is-selected', activeItem === el.dataset.item);
    });

    (['food', 'yarn', 'brush'] as TrayItem[]).forEach((item) => {
      const label = document.querySelector(`[data-variant-label-for="${item}"]`) as HTMLElement | null;
      if (!label) return;
      const variant = selectedVariants[item];
      setVariantVisual(label, variant, '•');
      label.classList.toggle('is-active', activeItem === item);
    });

    mainEl.classList.toggle('tama-main-armed', !!activeItem);
    if (!activeItem) {
      cursorPreview.style.display = 'none';
    }
  }

  function setActiveItem(item: TrayItem | null) {
    activeItem = activeItem === item ? null : item;
    syncActiveActionUi();
  }

  function cycleVariant(item: TrayItem) {
    const variants = ITEM_VARIANTS[item];
    if (variants.length <= 1) return;
    const current = selectedVariants[item];
    const nextIndex = (variants.indexOf(current) + 1) % variants.length;
    selectedVariants[item] = variants[nextIndex];
    syncActiveActionUi();
  }

  function getCatIntent(cat: TamagotchiCat, onScreenCats: TamagotchiCat[], state = tamagotchi.getState()): string {
    if (cat.energy < 25) return 'Moe';
    if (cat.hunger < 35) return 'Hongerig';
    if (cat.cleanliness < 35) return 'Wil een borstel';

    const bondedNearby = onScreenCats.some((other) => {
      if (other.id === cat.id || !state) return false;
      const family = state.family.some(
        (rel) =>
          (rel.catId === cat.id && rel.relatedCatId === other.id) ||
          (rel.catId === other.id && rel.relatedCatId === cat.id)
      );
      const [a, b] = cat.id < other.id ? [cat.id, other.id] : [other.id, cat.id];
      const bond = state.bonds.find((bo) => bo.catAId === a && bo.catBId === b);
      return family || (bond?.affinity || 0) > 25;
    });

    if (cat.happiness < 45 && !bondedNearby) return 'Zoekt aandacht';
    if (cat.personality === 'curious') return 'Aan het observeren';
    if (cat.personality === 'playful') return 'Klaar om te spelen';
    if (cat.personality === 'sassy') return 'Kijkt kritisch';
    return 'Op zijn gemak';
  }

  /* ═══ Cats list (all on-screen tamagotchi cats) ══════════ */

  function updateCatsList() {
    const state = tamagotchi.getState();
    if (!state) return;

    // Find which tamagotchi cats are on screen via DOM
    const onScreenIds = new Set<string>();
    document.querySelectorAll('.kitten--tamagotchi').forEach(el => {
      const id = (el as HTMLElement).dataset.tamagotchiId;
      if (id) onScreenIds.add(id);
    });

    const onScreenCats = state.cats.filter(c => c.isTamagotchi && onScreenIds.has(c.id));

    if (onScreenCats.length === 0) {
      emptyEl.style.display = 'block';
      // Remove old cat cards
      catsList.querySelectorAll('.tama-cat-card').forEach(el => el.remove());
      return;
    }

    emptyEl.style.display = 'none';

    // Update or create cat cards
    const existingCards = new Map<string, HTMLElement>();
    catsList.querySelectorAll('.tama-cat-card').forEach(el => {
      existingCards.set((el as HTMLElement).dataset.catId!, el as HTMLElement);
    });

    for (const cat of onScreenCats) {
      let card = existingCards.get(cat.id);
      if (!card) {
        card = createCatCard(cat);
        catsList.appendChild(card);
      }
      updateCardStats(card, cat, getCatIntent(cat, onScreenCats, state));
      existingCards.delete(cat.id);
    }

    // Remove cards for cats no longer on screen
    for (const [, card] of existingCards) {
      card.remove();
    }
  }

  function createCatCard(cat: TamagotchiCat): HTMLElement {
    const { id, name, stage } = cat;
    const card = document.createElement('div');
    card.className = 'tama-cat-card';
    card.dataset.catId = id;
    card.innerHTML = `
      <div class="tama-card-header">
        <div class="tama-card-title">
          <span class="tama-card-name-row">
            <span class="tama-card-name">${name}</span>
            <a class="tama-card-link" href="${getCatPageHref(cat) || '#'}" data-card-link ${cat.slug ? '' : 'hidden'}>Info</a>
          </span>
          <span class="tama-card-meta"><span class="tama-card-intent" data-intent>Op zijn gemak</span></span>
        </div>
        <span class="tama-card-stage">${STAGE_LABELS[stage] || stage}</span>
      </div>
      <div class="tama-card-stats">
        <div class="tama-mini-stat" title="Honger"><span>🍽️</span><div class="tama-mini-bar"><div class="tama-mini-fill" data-stat="hunger"></div></div></div>
        <div class="tama-mini-stat" title="Geluk"><span>😺</span><div class="tama-mini-bar"><div class="tama-mini-fill" data-stat="happiness"></div></div></div>
        <div class="tama-mini-stat" title="Energie"><span>⚡</span><div class="tama-mini-bar"><div class="tama-mini-fill" data-stat="energy"></div></div></div>
        <div class="tama-mini-stat" title="Netheid"><span>✨</span><div class="tama-mini-bar"><div class="tama-mini-fill" data-stat="cleanliness"></div></div></div>
      </div>
    `;

    // Click card → scroll to the cat on the page
    card.addEventListener('click', () => {
      const catEl = document.querySelector(`[data-tamagotchi-id="${id}"]`) as HTMLElement;
      if (catEl) {
        catEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });

    // Hover card → highlight the cat on the page
    card.addEventListener('mouseenter', () => {
      const catEl = document.querySelector(`[data-tamagotchi-id="${id}"]`) as HTMLElement;
      if (catEl) catEl.classList.add('kitten--highlighted');
    });
    card.addEventListener('mouseleave', () => {
      const catEl = document.querySelector(`[data-tamagotchi-id="${id}"]`) as HTMLElement;
      if (catEl) catEl.classList.remove('kitten--highlighted');
    });

    const link = card.querySelector('[data-card-link]') as HTMLAnchorElement | null;
    if (link) {
      link.addEventListener('click', (e) => e.stopPropagation());
    }

    return card;
  }

  function getCatPageHref(cat: TamagotchiCat): string {
    if (!cat.slug) return '';
    return cat.source === 'katten' ? `/onze-katten/${cat.slug}` : `/kittens/${cat.slug}`;
  }

  function updateCardStats(card: HTMLElement, cat: TamagotchiCat, intent: string) {
    const intentEl = card.querySelector('[data-intent]') as HTMLElement | null;
    if (intentEl) intentEl.textContent = intent;
    const link = card.querySelector('[data-card-link]') as HTMLAnchorElement | null;
    if (link) {
      const href = getCatPageHref(cat);
      link.hidden = !href;
      if (href) link.href = href;
    }

    for (const stat of ['hunger', 'happiness', 'energy', 'cleanliness'] as const) {
      const fill = card.querySelector(`[data-stat="${stat}"]`) as HTMLElement;
      if (!fill) continue;
      const val = Math.round(cat[stat]);
      fill.style.width = `${val}%`;
      if (val > 60) fill.style.background = 'var(--tama-stat-good, #5a9e4b)';
      else if (val > 30) fill.style.background = 'var(--tama-stat-warn, #c9a227)';
      else fill.style.background = 'var(--tama-stat-bad, #c94a4a)';
      // Update tooltip value
      const statEl = fill.closest('.tama-mini-stat') as HTMLElement;
      if (statEl) statEl.dataset.value = String(val);
    }
  }

  function dispatchItemUse(item: TrayItem, pageX: number, pageY: number, variant?: CareVariant, targetCatId?: string, vx = 0, vy = 0) {
    document.dispatchEvent(new CustomEvent('tama-drop-item', {
      detail: { item, variant: variant || getVariantForItem(item), x: pageX, y: pageY, vx, vy, targetCatId }
    }));
  }

  /* ═══ Drag / click from tray ═════════════════════════════ */

  let dragItem: TrayItem | null = null;
  let dragStartX = 0;
  let dragStartY = 0;
  let dragPrevX = 0;
  let dragPrevY = 0;
  let dragVx = 0;
  let dragVy = 0;
  let dragPageSamples: Array<{ x: number; y: number; t: number }> = [];
  let pointerStartedDrag = false;
  let pointerCleanup: (() => void) | null = null;

  function finishPointerTracking() {
    pointerCleanup?.();
    pointerCleanup = null;
    dragItem = null;
    pointerStartedDrag = false;
    dragGhost.style.display = 'none';
  }

  clearActionBtn.addEventListener('click', () => setActiveItem(null));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setActiveItem(null);
  });

  document.querySelectorAll('.tama-tray-item').forEach((item) => {
    const el = item as HTMLElement;
    const itemName = el.dataset.item as TrayItem;

    el.addEventListener('pointerdown', (e) => {
      if (e.button !== 0) return;
      dragItem = itemName;
      dragStartX = e.clientX;
      dragStartY = e.clientY;
      dragPrevX = e.clientX;
      dragPrevY = e.clientY;
      dragVx = 0;
      dragVy = 0;
      dragPageSamples = [];
      pointerStartedDrag = false;

      let brushInterval: ReturnType<typeof setInterval> | null = null;
      const onMove = (event: PointerEvent) => {
        if (!dragItem) return;
        dragVx = event.clientX - dragPrevX;
        dragVy = event.clientY - dragPrevY;
        dragPrevX = event.clientX;
        dragPrevY = event.clientY;

        const moveTarget = event.target as HTMLElement | null;
        if (!moveTarget?.closest('.tama-panel')) {
          dragPageSamples.push({ x: event.clientX, y: event.clientY, t: event.timeStamp });
          if (dragPageSamples.length > 6) dragPageSamples.shift();
        }

        if (!pointerStartedDrag) {
          const dist = Math.hypot(event.clientX - e.clientX, event.clientY - e.clientY);
          if (dist < 8) return;
          pointerStartedDrag = true;
          setVariantVisual(dragGhost, getVariantForItem(dragItem), ITEM_ICONS[dragItem]);
          dragGhost.style.display = 'block';
          moveDragGhost(event.clientX, event.clientY);
          if (dragItem === 'brush') {
            brushInterval = setInterval(() => {
              dispatchItemUse('brush', dragPrevX + window.scrollX, dragPrevY + window.scrollY);
            }, 800);
          }
        }

        if (pointerStartedDrag) {
          moveDragGhost(event.clientX, event.clientY);
        }
      };

      const onUp = (event: PointerEvent) => {
        if (brushInterval) clearInterval(brushInterval);
        if (dragItem && pointerStartedDrag) {
          const gestureDx = event.clientX - dragStartX;
          const gestureDy = event.clientY - dragStartY;
          const throwBias = dragItem === 'food' ? 1.25 : 1;
          let throwVx = ((dragVx * 1.1) + (gestureDx * 0.16)) * throwBias;
          let throwVy = ((dragVy * 1.1) + (gestureDy * 0.16)) * throwBias;

          if (dragItem === 'yarn' && dragPageSamples.length >= 2) {
            const first = dragPageSamples[0];
            const last = dragPageSamples[dragPageSamples.length - 1];
            const pageDx = last.x - first.x;
            const pageDy = last.y - first.y;
            throwVx = (dragVx * 1.35) + (pageDx * 0.28);
            throwVy = (dragVy * 1.35) + (pageDy * 0.28);
          }

          emitLocalSound(ITEM_TO_ACTION[dragItem], { variant: getVariantForItem(dragItem) });
          dispatchItemUse(
            dragItem,
            event.pageX,
            event.pageY,
            getVariantForItem(dragItem),
            undefined,
            throwVx,
            throwVy,
          );
          setActiveItem(null);
        } else {
          if (activeItem === itemName) cycleVariant(itemName);
          else setActiveItem(itemName);
        }
        document.removeEventListener('pointermove', onMove);
        document.removeEventListener('pointerup', onUp);
        document.removeEventListener('pointercancel', onUp);
        finishPointerTracking();
      };

      pointerCleanup = () => {
        document.removeEventListener('pointermove', onMove);
        document.removeEventListener('pointerup', onUp);
        document.removeEventListener('pointercancel', onUp);
      };

      document.addEventListener('pointermove', onMove);
      document.addEventListener('pointerup', onUp);
      document.addEventListener('pointercancel', onUp);
    });
  });

  function moveDragGhost(cx: number, cy: number) {
    dragGhost.style.left = `${cx - 16}px`;
    dragGhost.style.top = `${cy - 16}px`;
  }

  mainEl.addEventListener('click', (e) => {
    if (!activeItem) return;
    const target = e.target as HTMLElement;
    if (target.closest('.tama-panel')) return;
    e.preventDefault();
    e.stopPropagation();
    emitLocalSound(ITEM_TO_ACTION[activeItem], { variant: getVariantForItem(activeItem) });
    dispatchItemUse(activeItem, e.pageX, e.pageY, getVariantForItem(activeItem));
    setActiveItem(null);
  }, true);

  document.addEventListener('pointermove', (e) => {
    if (!activeItem) return;
    if (dragItem || pointerStartedDrag) {
      cursorPreview.style.display = 'none';
      return;
    }
    const target = e.target as HTMLElement | null;
    if (target?.closest('.tama-panel')) {
      cursorPreview.style.display = 'none';
      return;
    }
    setVariantVisual(cursorPreview, getVariantForItem(activeItem), ITEM_ICONS[activeItem]);
    cursorPreview.style.left = `${e.clientX + 14}px`;
    cursorPreview.style.top = `${e.clientY + 12}px`;
    cursorPreview.style.display = 'flex';
  });

  /* ═══ Activity feed ══════════════════════════════════════ */

  function updateFeed() {
    const state = tamagotchi.getState();
    if (!state) return;

    feedList.innerHTML = '';
    const recent = state.recentActions.slice(0, 10);
    for (const action of recent) {
      const div = document.createElement('div');
      div.className = 'tama-feed-item';
      const ago = timeAgo(action.createdAt);
      const icon = ACTION_ICONS[action.action] || '❓';
      div.textContent = formatFeedItem(action, icon, ago);
      feedList.appendChild(div);
    }
  }

  function formatFeedItem(
    action: {
      action: string;
      catName?: string;
      sourceType?: string;
      sourceCatName?: string;
    },
    icon: string,
    ago: string
  ): string {
    const target = action.catName || 'een kat';
    if (action.sourceType === 'cat' && action.sourceCatName) {
      const verb = CAT_ACTION_LABELS[action.action] || ACTION_LABELS[action.action] || action.action;
      return `${icon} ${action.sourceCatName} ${verb} ${target} — ${ago}`;
    }
    if (action.sourceType === 'system') {
      const verb = ACTION_LABELS[action.action] || action.action;
      return `${icon} ${target} ${verb} vanzelf — ${ago}`;
    }
    const verb = ACTION_LABELS[action.action] || action.action;
    return `${icon} Iemand ${verb} ${target} — ${ago}`;
  }

  function timeAgo(ts: number): string {
    const diff = Math.floor(Date.now() / 1000) - ts;
    if (diff < 60) return 'zojuist';
    if (diff < 3600) return `${Math.floor(diff / 60)}m geleden`;
    if (diff < 86400) return `${Math.floor(diff / 3600)}u geleden`;
    return `${Math.floor(diff / 86400)}d geleden`;
  }

  /* ═══ Event listeners ════════════════════════════════════ */

  tamagotchi.on('state-update', () => {
    updateCatsList();
    updateFeed();
  });

  tamagotchi.on('care-result', (data: any) => {
    if (panel.dataset.state === 'collapsed') {
      badge.style.display = 'inline-block';
    }
    // Trigger care animation on the cat element
    triggerCarePopup(data.catId, data.action, data.variant);
    // Trigger behavior reaction
    document.dispatchEvent(new CustomEvent('tamagotchi-care-react', {
      detail: {
        catId: data.catId,
        action: data.action,
        variant: data.variant,
        sourceType: data.sourceType,
        sourceCatId: data.sourceCatId,
      }
    }));
    updateCatsList();
  });

  tamagotchi.on('connected', () => {
    statusEl.style.color = 'var(--tama-stat-good, #5a9e4b)';
    statusEl.title = 'Verbonden';
  });

  tamagotchi.on('disconnected', () => {
    statusEl.style.color = 'var(--tama-stat-bad, #c94a4a)';
    statusEl.title = 'Verbinding verbroken';
  });

  // Periodically refresh cat list (catches cats walking on/off screen)
  setInterval(updateCatsList, 2000);

  // Show/hide panel based on tamagotchi cats on screen
  function updatePanelVisibility() {
    if (dismissed) return;
    const hasTamaCats = document.querySelectorAll('.kitten--tamagotchi').length > 0;
    if (!hasTamaCats) {
      panel.style.display = 'none';
      return;
    }
    panel.style.display = '';
    // Desktop: always open (no toggle needed)
    if (isDesktop()) {
      panel.dataset.state = 'open';
    }
    syncPanelStateUi();
  }

  // Initially hidden
  panel.style.display = 'none';

  tamagotchi.on('state-update', updatePanelVisibility);
  document.addEventListener('tama-cats-changed', () => {
    // New cats spawned — reset dismissed state so panel can reappear
    const hasTamaCats = document.querySelectorAll('.kitten--tamagotchi').length > 0;
    if (hasTamaCats) dismissed = false;
    updatePanelVisibility();
    updateCatsList();
  });
  setInterval(updatePanelVisibility, 2000);

  function triggerCarePopup(catId: string, action: string, variant?: CareVariant) {
    const catEl = document.querySelector(`[data-tamagotchi-id="${catId}"]`) as HTMLElement;
    if (!catEl) return;

    const icon = (variant && VARIANT_ICONS[variant]) || ACTION_ICONS[action] || '💕';
    const popup = document.createElement('div');
    popup.className = 'tama-care-popup';
    popup.textContent = icon;
    catEl.appendChild(popup);
    popup.addEventListener('animationend', () => popup.remove());
  }

  syncActiveActionUi();
  syncPanelStateUi();
</script>

