---
interface Props {
  catteryNaam?: string;
  email?: string;
  telefoon?: string;
  adres?: string;
  facebookUrl?: string;
  instagramUrl?: string;
}

const {
  catteryNaam = 'Cattery',
  email,
  telefoon,
  adres,
  facebookUrl,
  instagramUrl,
} = Astro.props;
---

<footer class="footer">
  <div class="container footer-grid">
    <!-- Left: Brand -->
    <div class="footer-brand">
      <p class="footer-name">{catteryNaam}</p>
      <p class="footer-tagline">Met liefde grootgebracht</p>
    </div>

    <!-- Middle: Quick links -->
    <div class="footer-links">
      <p class="footer-heading">Navigatie</p>
      <ul class="footer-link-list">
        <li><a href="/">Home</a></li>
        <li><a href="/onze-katten">Katten</a></li>
        <li><a href="/kittens">Kittens</a></li>
        <li><a href="/gallerij">Gallerij</a></li>
        <li><a href="/informatie">Informatie</a></li>
        <li><a href="/ervaringen">Ervaringen</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>

    <!-- Right: Contact + Social -->
    <div class="footer-contact">
      <p class="footer-heading">Contact</p>
      {email && (
        <p class="footer-contact-item">
          <a href={`mailto:${email}`}>{email}</a>
        </p>
      )}
      {telefoon && (
        <p class="footer-contact-item">{telefoon}</p>
      )}
      {adres && (
        <p class="footer-contact-item">{adres}</p>
      )}
      {(facebookUrl || instagramUrl) && (
        <div class="footer-social">
          {facebookUrl && (
            <a href={facebookUrl} target="_blank" rel="noopener noreferrer" class="footer-social-link" aria-label="Facebook">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
              </svg>
            </a>
          )}
          {instagramUrl && (
            <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="footer-social-link" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
              </svg>
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container">
      <p class="footer-copy">&copy; {new Date().getFullYear()} {catteryNaam}. Alle rechten voorbehouden.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: auto;
    background: var(--color-bg-dark);
    color: var(--color-bg-alt);
    padding-top: var(--space-2xl);
  }

  .footer-brand,
  .footer-links,
  .footer-bottom,
  .footer-social {
    -webkit-user-select: none;
    user-select: none;
  }

  .footer-contact,
  .footer-contact-item,
  .footer-contact-item a {
    -webkit-user-select: text;
    user-select: text;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr 1fr;
    gap: var(--space-xl);
    padding-bottom: var(--space-xl);
  }

  /* Brand column */
  .footer-name {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-bg);
    margin-bottom: var(--space-xs);
  }

  .footer-tagline {
    font-size: 0.95rem;
    color: var(--color-text-light);
    font-style: italic;
  }

  /* Column headings */
  .footer-heading {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-light);
    margin-bottom: var(--space-md);
  }

  /* Quick links */
  .footer-link-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer-link-list a {
    color: var(--color-bg-alt);
    font-size: 0.925rem;
    transition: color 0.2s ease;
  }

  .footer-link-list a:hover {
    color: var(--color-white);
  }

  /* Contact column */
  .footer-contact-item {
    font-size: 0.925rem;
    color: var(--color-bg-alt);
    margin-bottom: var(--space-xs);
  }

  .footer-contact-item a {
    color: var(--color-bg-alt);
    transition: color 0.2s ease;
  }

  .footer-contact-item a:hover {
    color: var(--color-white);
  }

  /* Social icons */
  .footer-social {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-bg-alt);
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .footer-social-link:hover {
    background: var(--color-accent);
    color: var(--color-white);
    transform: scale(1.1);
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-block: var(--space-md);
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>
