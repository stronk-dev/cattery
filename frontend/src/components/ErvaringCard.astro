---
import { getImageURL } from '../lib/directus';
import type { Ervaring } from '../lib/types';

interface Props {
  ervaring: Ervaring;
}

const { ervaring } = Astro.props;
---

<div class="ervaring-card card">
  {ervaring.foto && (
    <img
      class="ervaring-foto"
      src={getImageURL(ervaring.foto.id, { width: 400, height: 300, fit: 'cover', format: 'webp', quality: 80 })}
      alt={`Foto van ${ervaring.naam}`}
      width="400"
      height="300"
      loading="lazy"
      decoding="async"
    />
  )}
  <div class="ervaring-body">
    <blockquote class="ervaring-tekst">{ervaring.tekst}</blockquote>
    <div class="ervaring-footer">
      <p class="ervaring-naam">&mdash; {ervaring.naam}</p>
      {ervaring.kitten && (
        <a class="ervaring-kitten" href={`/kittens/${ervaring.kitten.slug}`}>
          {ervaring.kitten.naam}
        </a>
      )}
    </div>
  </div>
</div>

<style>
  .ervaring-card {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: var(--transition-smooth);
  }

  .ervaring-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .ervaring-foto {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
  }

  .ervaring-body {
    padding: var(--space-lg);
  }

  .ervaring-tekst {
    font-style: italic;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-md);
    quotes: "\201C" "\201D";
  }

  .ervaring-tekst::before {
    content: open-quote;
    font-size: 1.5rem;
    color: var(--color-accent);
    font-weight: 700;
    margin-right: 2px;
  }

  .ervaring-tekst::after {
    content: close-quote;
    font-size: 1.5rem;
    color: var(--color-accent);
    font-weight: 700;
    margin-left: 2px;
  }

  .ervaring-footer {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .ervaring-naam {
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .ervaring-kitten {
    font-size: 0.85rem;
    color: var(--color-accent);
  }
</style>
