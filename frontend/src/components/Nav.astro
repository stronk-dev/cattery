---
import { getImageURL } from '../lib/directus';
import CatFace from './CatFace.astro';

interface Props {
  catteryNaam?: string;
  logoId?: string;
}

const { catteryNaam = 'Cattery', logoId } = Astro.props;
const currentPath = Astro.url.pathname;
const logoUrl = logoId
  ? getImageURL(logoId, { height: 80, format: 'webp', quality: 85 })
  : undefined;

const catLinks = [
  { href: '/onze-katten', label: 'Katten' },
  { href: '/kittens', label: 'Kittens' },
  { href: '/nesten', label: 'Nesten' },
  { href: '/gallerij', label: 'Gallerij' },
];

const infoLinks = [
  { href: '/over-ons', label: 'Over Ons' },
  { href: '/informatie', label: 'Informatie' },
  { href: '/ervaringen', label: 'Ervaringen' },
];

const allLinks = [
  { href: '/', label: 'Home' },
  ...catLinks,
  { href: '/blog', label: 'Blog' },
  ...infoLinks,
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<nav class="nav" aria-label="Hoofdnavigatie">
  <div class="nav-inner container">
    <a href="/" class="nav-logo">
      {logoUrl && <img src={logoUrl} alt="" class="nav-logo-img" />}
      <span class="nav-logo-text">
        <span class="nav-logo-full">{catteryNaam}</span>
        <span class="nav-logo-short">Cattery</span>
      </span>
    </a>

    <!-- Desktop + Tablet links -->
    <ul class="nav-links">
      <!-- Flat cat links (wide only) -->
      {catLinks.map(({ href, label }) => (
        <li class="nav-cat-flat">
          <a href={href} class:list={['nav-link', { active: isActive(href) }]}>{label}</a>
        </li>
      ))}

      <!-- Cat dropdown (medium only) -->
      <li class="nav-cat-dropdown nav-dropdown-item">
        <details class="nav-dropdown-wrap">
          <summary class:list={['nav-link', 'nav-dropdown-btn', { active: catLinks.some(l => isActive(l.href)) }]}>
            Katten <span class="nav-chevron">&#9662;</span>
          </summary>
          <ul class="nav-dropdown">
            {catLinks.map(({ href, label }) => (
              <li>
                <a href={href} class:list={['nav-dropdown-link', { active: isActive(href) }]}>{label}</a>
              </li>
            ))}
          </ul>
        </details>
      </li>

      <li>
        <a href="/blog" class:list={['nav-link', { active: isActive('/blog') }]}>Blog</a>
      </li>
      <li class="nav-dropdown-item">
        <details class="nav-dropdown-wrap">
          <summary class:list={['nav-link', 'nav-dropdown-btn', { active: infoLinks.some(l => isActive(l.href)) }]}>
            Info <span class="nav-chevron">&#9662;</span>
          </summary>
          <ul class="nav-dropdown">
            {infoLinks.map(({ href, label }) => (
              <li>
                <a href={href} class:list={['nav-dropdown-link', { active: isActive(href) }]}>{label}</a>
              </li>
            ))}
          </ul>
        </details>
      </li>
      <li>
        <a href="/contact" class:list={['nav-link', 'nav-cta', { active: isActive('/contact') }]}>Contact</a>
      </li>
    </ul>

    <!-- CatFace on the right (wide + medium) — click to spawn a kitten -->
    <button class="nav-catface" id="catface-btn" type="button" aria-label="Spawn een kitten">
      <CatFace />
    </button>

    <!-- Mobile hamburger -->
    <details class="nav-mobile">
      <summary class="nav-toggle" aria-label="Menu openen">
        <span class="nav-hamburger"></span>
      </summary>
      <div class="nav-backdrop"></div>
      <button class="nav-close" aria-label="Menu sluiten">&times;</button>
      <ul class="nav-mobile-links">
        {allLinks.map(({ href, label }) => (
          <li>
            <a href={href} class:list={['nav-link', { active: isActive(href) }]}>{label}</a>
          </li>
        ))}
        <li>
          <a href="/contact" class:list={['nav-link', 'nav-cta', { active: isActive('/contact') }]}>Contact</a>
        </li>
      </ul>
    </details>
  </div>
</nav>

<script>
  // Close dropdowns when clicking outside
  document.addEventListener('click', (e) => {
    document.querySelectorAll('.nav-dropdown-wrap[open]').forEach((el) => {
      if (!el.contains(e.target as Node)) {
        el.removeAttribute('open');
      }
    });
  });

  // Click cat face to spawn a walking kitten
  document.getElementById('catface-btn')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('spawn-kitten'));
  });

  // Close mobile menu via X button or backdrop tap
  document.querySelector('.nav-close')?.addEventListener('click', () => {
    document.querySelector('.nav-mobile')?.removeAttribute('open');
  });
  document.querySelector('.nav-backdrop')?.addEventListener('click', () => {
    document.querySelector('.nav-mobile')?.removeAttribute('open');
  });
</script>

<style>
  .nav {
    background: var(--color-white);
    box-shadow: 0 1px 8px rgba(44, 36, 32, 0.07);
    position: sticky;
    top: 0;
    z-index: 100;
    -webkit-user-select: none;
    user-select: none;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-sm);
    min-height: 3.5rem;
  }

  /* ── Logo ──────────────────────────────────────────────── */

  .nav-logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .nav-logo:hover {
    color: var(--color-accent);
  }

  .nav-logo-img {
    height: 2.5rem;
    width: auto;
    display: block;
  }

  .nav-logo-text {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .nav-logo-short {
    display: none;
  }

  /* Logo short name — hidden by default, shown on narrow */

  /* ── Desktop + Tablet inline links ────────────────────── */

  .nav-links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .nav-link {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--space-xs) 0;
    border-bottom: 2px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  .nav-link.active {
    color: var(--color-accent);
    font-weight: 600;
    border-bottom-color: var(--color-accent);
  }

  /* Contact CTA */
  .nav-cta {
    background: var(--color-accent);
    color: var(--color-white) !important;
    border: none;
    border-radius: var(--radius);
    padding: 0.4rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .nav-cta:hover {
    background: var(--color-accent-hover);
    color: var(--color-white) !important;
    transform: scale(1.03);
  }

  .nav-cta.active {
    background: var(--color-accent-hover);
    border-bottom: none;
  }

  /* ── CatFace accent — right side (wide + medium) ───────── */

  .nav-catface {
    flex-shrink: 0;
    margin-left: var(--space-sm);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: transform 0.15s ease;
  }

  .nav-catface:hover {
    transform: scale(1.1);
  }

  .nav-catface:active {
    transform: scale(0.95);
  }

  /* ── Cat links visibility (wide vs medium) ─────────────── */

  /* Wide (>1024px): flat cat links shown, cat dropdown hidden */
  .nav-cat-dropdown {
    display: none;
  }

  .nav-cat-flat {
    display: list-item;
  }

  /* ── Dropdowns ─────────────────────────────────────────── */

  .nav-dropdown-wrap {
    position: relative;
  }

  .nav-dropdown-btn {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    border-bottom: none;
  }

  .nav-dropdown-btn::-webkit-details-marker {
    display: none;
  }

  .nav-chevron {
    font-size: 0.75rem;
    line-height: 1;
    transition: transform 0.2s ease;
  }

  .nav-dropdown-wrap[open] .nav-chevron {
    transform: rotate(180deg);
  }

  .nav-dropdown {
    position: absolute;
    top: calc(100% + var(--space-sm));
    right: 0;
    list-style: none;
    background: var(--color-white);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    min-width: 160px;
    padding: var(--space-sm) 0;
    z-index: 200;
  }

  .nav-dropdown-link {
    display: block;
    padding: var(--space-sm) var(--space-md);
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: background 0.15s ease, color 0.15s ease;
    white-space: nowrap;
  }

  .nav-dropdown-link:hover {
    background: var(--color-bg-alt);
    color: var(--color-accent);
  }

  .nav-dropdown-link.active {
    color: var(--color-accent);
    font-weight: 600;
  }

  /* ── Mobile hamburger — hidden on desktop/tablet ──────── */

  .nav-mobile {
    display: none;
  }

  .nav-toggle {
    cursor: pointer;
    list-style: none;
    padding: var(--space-sm);
  }

  .nav-toggle::-webkit-details-marker {
    display: none;
  }

  .nav-hamburger {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    position: relative;
    transition: background 0.2s ease;
  }

  .nav-hamburger::before,
  .nav-hamburger::after {
    content: '';
    position: absolute;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    left: 0;
    transition: transform 0.3s ease;
  }

  .nav-hamburger::before { top: -6px; }
  .nav-hamburger::after { top: 6px; }

  .nav-close {
    display: none;
  }

  .nav-backdrop {
    display: none;
  }

  .nav-mobile-links {
    content-visibility: visible;
    list-style: none;
    display: none;
  }

  /* ── Tablet (769px – 1024px) ──────────────────────────── */

  @media (max-width: 1024px) {
    .nav-links {
      gap: var(--space-md);
      margin-left: auto;
    }

    /* Medium: hide flat cat links, show cat dropdown */
    .nav-cat-flat {
      display: none;
    }

    .nav-cat-dropdown {
      display: list-item;
    }
  }

  /* ── Mobile (≤768px) ──────────────────────────────────── */

  @media (max-width: 768px) {
    .nav-inner {
      justify-content: space-between;
    }

    .nav-links {
      display: none;
      margin-left: 0;
    }

    .nav-catface {
      order: 2;
    }

    .nav-mobile {
      display: block;
      order: 1;
      margin-left: auto;
    }

    .nav-logo-full {
      display: none;
    }

    .nav-logo-short {
      display: inline;
    }

    .nav-backdrop {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(44, 36, 32, 0.35);
      z-index: 99;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .nav-mobile[open] .nav-backdrop {
      display: block;
      opacity: 1;
    }

    .nav-mobile-links {
      flex-direction: column;
      align-items: stretch;
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(280px, 80vw);
      background: var(--color-white);
      box-shadow: -4px 0 20px rgba(44, 36, 32, 0.15);
      padding: var(--space-2xl) var(--space-lg) var(--space-lg);
      gap: 0;
      z-index: 100;
      transform: translateX(100%);
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .nav-mobile[open] .nav-mobile-links {
      display: flex;
      transform: translateX(0);
    }

    .nav-mobile-links .nav-link {
      display: block;
      padding: var(--space-sm) var(--space-md);
      font-size: 0.9rem;
      border-bottom: none;
    }

    .nav-mobile-links .nav-link.active {
      border-bottom: none;
      background: var(--color-bg-alt);
      border-radius: var(--radius);
    }

    .nav-close {
      display: block;
      position: fixed;
      top: var(--space-md);
      right: var(--space-md);
      z-index: 110;
      background: none;
      border: none;
      font-size: 1.75rem;
      line-height: 1;
      color: var(--color-text-muted);
      cursor: pointer;
      padding: var(--space-xs) var(--space-sm);
      box-shadow: none;
      transition: color 0.2s ease;
    }

    .nav-close:hover {
      color: var(--color-text);
      background: none;
      box-shadow: none;
      transform: none;
    }

    .nav-mobile-links .nav-cta {
      margin-top: var(--space-sm);
      text-align: center;
      padding: 0.6rem var(--space-md);
    }
  }
</style>
